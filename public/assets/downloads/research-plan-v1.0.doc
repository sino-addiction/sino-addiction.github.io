  <table>
    <tr>
      <th>拟纳入成瘾类型</th>
      <td><span class="blank wide"></span></td>
    </tr>
    <tr>
      <th>是否包含健康对照</th>
      <td><span class="blank short"></span></td>
    </tr>
    <tr>
      <th>申请模态</th>
      <td>结构 MRI / 静息态 MRI / 任务 MRI / 静息态 EEG / 任务 EEG / 其他：<span class="blank"></span></td>
    </tr>
    <tr>
      <th>关键临床变量</th>
      <td><span class="blank wide"></span></td>
    </tr>
    <tr>
