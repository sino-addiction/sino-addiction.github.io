---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import ProcessIcon from "../components/ProcessIcon.astro";
import { siteData } from "../data/site";
import { requirePage } from "../lib/content";

type JoinFlowAction = {
  label: string;
  href: string;
  download?: string;
  variant: "primary" | "secondary";
};

type JoinFlowMeta = {
  icon: "upload" | "check" | "share" | "database" | "play";
  direction: "left" | "right";
  action?: JoinFlowAction;
};

type JoinFlowStep = {
  title: string;
  description: string;
  icon: "upload" | "check" | "share" | "database" | "play";
  direction: "left" | "right";
  action?: JoinFlowAction;
};

const page = await requirePage("join-us");
const { Content } = await render(page);

const joinFlowMeta: JoinFlowMeta[] = [
  {
    icon: "upload",
    direction: "left",
    action: {
      label: "填写数据调查表",
      href: "/site-survey/",
      variant: "primary",
    },
  },
  {
    icon: "check",
    direction: "right",
    action: {
      label: "下载合作备忘录",
      href: "/assets/downloads/sani-cooperation-mou-v1.doc",
      download: "SANI合作备忘录v1.doc",
      variant: "secondary",
    },
  },
  {
    icon: "share",
    direction: "left",
  },
  {
    icon: "database",
    direction: "right",
  },
  {
    icon: "play",
    direction: "left",
  },
];

const joinFlowSteps = (page.data.steps ?? []).map((step, index): JoinFlowStep => {
  const meta = joinFlowMeta[index] ?? {
    icon: index % 2 === 0 ? "upload" : "play",
    direction: index % 2 === 0 ? "left" : "right",
  };

  return {
    ...step,
    ...meta,
  };
});

const flowCardClass =
  "surface-card flex h-full w-full flex-col border-t-4 border-t-accent transition-shadow hover:shadow-md md:max-w-[520px]";

const flowIndexBadgeClass =
  "mt-[2px] inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-ink-deep text-[12px] font-semibold leading-none text-white shadow-sm tabular-nums md:h-9 md:w-9 md:text-[13px]";

const flowTitleClass =
  "flex items-start gap-3 text-[24px] leading-[1.18] font-bold text-ink-deep md:text-[28px]";

const buttonClass = (variant: "primary" | "secondary") =>
  variant === "primary"
    ? "btn-primary h-11 w-fit px-5 text-[13px] shadow-sm"
    : "btn-secondary h-11 w-fit px-5 text-[13px]";
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Hero {...page.data.hero} compact={true} />

  <section id="join-flow" class="page-wrap py-20 md:py-32 scroll-mt-24">
    <SectionHeading
      eyebrow="How To Join"
      title="加入流程"
      description="从提交数据概况到中心站点统一处理，形成长期协作。"
      center={true}
    />

    <div class="relative mx-auto mt-10 max-w-6xl md:mt-12" data-join-flow-timeline>
      <div class="flow-axis" aria-hidden="true"></div>

      <div class="space-y-[10px] md:space-y-[13px]">
        {joinFlowSteps.map((step, index) => (
          <div data-reveal style={`--reveal-delay:${index * 110}ms;`}>
            <div class="relative pl-10 md:hidden">
              <div class="flow-node flow-node--compact absolute left-0 top-4" data-join-flow-node>
                <span class="flow-node-ring"></span>
                <span class="flow-node-core">
                  <ProcessIcon name={step.icon} class="h-4 w-4" />
                </span>
              </div>

              <article class={flowCardClass}>
                <h3 class={flowTitleClass}>
                  <span class={flowIndexBadgeClass}>
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span class="min-w-0 flex-1">
                    {step.title}
                  </span>
                </h3>
                <p class="mt-4 text-[15px] leading-[1.85] text-text-secondary md:text-[16px]">
                  {step.description}
                </p>

                {step.action && (
                  <a
                    href={step.action.href}
                    class:list={[buttonClass(step.action.variant), "mt-5 self-start"]}
                    download={step.action.download}
                  >
                    {step.action.label}
                    <span aria-hidden="true" class="ml-2 font-normal opacity-70">&rarr;</span>
                  </a>
                )}
              </article>
            </div>

            <div class="hidden md:grid md:grid-cols-[minmax(0,1fr)_56px_minmax(0,1fr)] md:items-center md:gap-[8px]">
              {step.direction === "left" ? (
                <>
                  <article class={`${flowCardClass} md:justify-self-end`}>
                    <h3 class={flowTitleClass}>
                      <span class={flowIndexBadgeClass}>
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      <span class="min-w-0 flex-1">
                        {step.title}
                      </span>
                    </h3>
                    <p class="mt-4 text-[16px] leading-[1.85] text-text-secondary">
                      {step.description}
                    </p>

                    {step.action && (
                      <a
                        href={step.action.href}
                        class:list={[buttonClass(step.action.variant), "mt-5 self-start"]}
                        download={step.action.download}
                      >
                        {step.action.label}
                        <span aria-hidden="true" class="ml-2 font-normal opacity-70">&rarr;</span>
                      </a>
                    )}
                  </article>

                  <div class="flow-node hidden md:flex md:justify-self-center" aria-hidden="true" data-join-flow-node>
                    <span class="flow-node-ring"></span>
                    <span class="flow-node-core">
                      <ProcessIcon name={step.icon} class="h-5 w-5" />
                    </span>
                  </div>

                  <div aria-hidden="true"></div>
                </>
              ) : (
                <>
                  <div aria-hidden="true"></div>

                  <div class="flow-node hidden md:flex md:justify-self-center" aria-hidden="true" data-join-flow-node>
                    <span class="flow-node-ring"></span>
                    <span class="flow-node-core">
                      <ProcessIcon name={step.icon} class="h-5 w-5" />
                    </span>
                  </div>

                  <article class={`${flowCardClass} md:justify-self-start`}>
                    <h3 class={flowTitleClass}>
                      <span class={flowIndexBadgeClass}>
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      <span class="min-w-0 flex-1">
                        {step.title}
                      </span>
                    </h3>
                    <p class="mt-4 text-[16px] leading-[1.85] text-text-secondary">
                      {step.description}
                    </p>

                    {step.action && (
                      <a
                        href={step.action.href}
                        class:list={[buttonClass(step.action.variant), "mt-5 self-start"]}
                        download={step.action.download}
                      >
                        {step.action.label}
                        <span aria-hidden="true" class="ml-2 font-normal opacity-70">&rarr;</span>
                      </a>
                    )}
                  </article>
                </>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <p class="mt-8 text-center text-[14px] leading-[1.8] text-text-muted">
      中心站点将定期更新数据处理进展，并在数据积累成熟后向成员发布可提研究计划。
    </p>
  </section>

  {page.data.highlights && (
    <section class="page-wrap section-shell pt-0">
      <SectionHeading
        eyebrow="Why Join"
        title="为什么加入 SANI"
        description="在统一规则下共享数据、问题与研究体系，减少重复建设。"
        center={true}
      />
      <div class="mt-12">
        <FeatureGrid items={page.data.highlights} columns={4} />
      </div>
    </section>
  )}

  <section class="page-wrap section-shell pt-0">
    <div class="max-w-5xl mx-auto flex flex-col items-center">
      <SectionHeading
        eyebrow="Contact Mode"
        title="机构联系方式"
        center={true}
      />

      <div class="mt-12 w-full grid gap-10 lg:grid-cols-[1.2fr_1fr] items-stretch surface-card p-10 md:p-12">
        <div class="prose-shell flex flex-col justify-center">
          <Content />
        </div>

        <div class="h-full flex flex-col justify-center bg-surface-alt p-8 rounded-lg border border-border">
          <span class="eyebrow ring-1 ring-inset ring-accent/10 mb-5 max-w-min">Email</span>
          <h3 class="text-[20px] leading-snug font-bold text-ink-deep font-sans break-all">
            {siteData.contact.email}
          </h3>
          <p class="mt-4 text-[15px] leading-relaxed text-text-secondary">{siteData.contact.note}</p>
          <div class="mt-8 pt-6 border-t border-border">
            <a href={`mailto:${siteData.contact.email}`} class="btn-primary w-full shadow-sm text-[14px]">
              发送合作邮件
              <span aria-hidden="true" class="ml-2 font-normal opacity-70">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const revealNodes = document.querySelectorAll("[data-reveal]");
      const timeline = document.querySelector("[data-join-flow-timeline]");
      const timelineNodes = timeline ? Array.from(timeline.querySelectorAll("[data-join-flow-node]")) : [];

      const visibleNodes = () => timelineNodes.filter((node) => node.getClientRects().length > 0);

      const updateTimeline = () => {
        if (!timeline) return;

        const nodes = visibleNodes();
        if (nodes.length === 0) return;

        const firstNode = nodes[0];
        const lastNode = nodes[nodes.length - 1];
        const timelineRect = timeline.getBoundingClientRect();
        const firstRect = firstNode.getBoundingClientRect();
        const lastRect = lastNode.getBoundingClientRect();

        const topOffset = firstRect.top + firstRect.height / 2 - timelineRect.top;
        const bottomOffset = timelineRect.bottom - (lastRect.top + lastRect.height / 2);

        timeline.style.setProperty("--timeline-line-top", `${Math.max(0, topOffset)}px`);
        timeline.style.setProperty("--timeline-line-bottom", `${Math.max(0, bottomOffset)}px`);
      };

      const scheduleTimelineUpdate = () => {
        if (typeof window.requestAnimationFrame === "function") {
          window.requestAnimationFrame(updateTimeline);
        } else {
          updateTimeline();
        }
      };

      if (!("IntersectionObserver" in window)) {
        revealNodes.forEach((node) => node.classList.add("is-visible"));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.18,
            rootMargin: "0px 0px -8% 0px",
          },
        );

        revealNodes.forEach((node) => observer.observe(node));
      }

      scheduleTimelineUpdate();
      window.addEventListener("load", scheduleTimelineUpdate, { once: true });
      window.addEventListener("resize", scheduleTimelineUpdate);

      if ("ResizeObserver" in window && timeline) {
        const resizeObserver = new ResizeObserver(scheduleTimelineUpdate);
        resizeObserver.observe(timeline);
        timelineNodes.forEach((node) => resizeObserver.observe(node));
      }
    })();
  </script>

  <style>
    .flow-axis {
      position: absolute;
      left: 18px;
      top: var(--timeline-line-top, 0px);
      bottom: var(--timeline-line-bottom, 0px);
      width: 2px;
      transform: translateX(-50%);
      pointer-events: none;
      border-radius: 9999px;
      background: rgba(31, 107, 102, 0.36);
      z-index: 0;
    }

    @media (min-width: 768px) {
      .flow-axis {
        left: 50%;
      }
    }

    .flow-node {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 64px;
      height: 64px;
      z-index: 1;
    }

    .flow-node--compact {
      width: 36px;
      height: 36px;
    }

    .flow-node-ring {
      position: absolute;
      inset: 0;
      border-radius: 9999px;
      border: 1px solid rgba(215, 223, 219, 0.95);
      background: rgba(252, 253, 252, 0.82);
    }

    .flow-node-core {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 9999px;
      background: var(--color-accent);
      color: white;
    }

    .flow-node--compact .flow-node-core {
      width: 24px;
      height: 24px;
    }

    .flow-node-core svg {
      width: 18px;
      height: 18px;
    }

    .flow-node--compact .flow-node-core svg {
      width: 12px;
      height: 12px;
    }

    [data-reveal] {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 700ms cubic-bezier(0.2, 0.75, 0.2, 1),
        transform 700ms cubic-bezier(0.2, 0.75, 0.2, 1);
      transition-delay: var(--reveal-delay, 0ms);
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      [data-reveal] {
        opacity: 1;
        transform: none;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</BaseLayout>
