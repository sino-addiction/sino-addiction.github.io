---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import Timeline from "../components/Timeline.astro";
import CtaPanel from "../components/CtaPanel.astro";
import { siteData } from "../data/site";
import { requirePage } from "../lib/content";

const page = await requirePage("join-us");
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Hero {...page.data.hero} compact={true} />

  {page.data.highlights && (
    <section class="page-wrap section-shell">
      <SectionHeading eyebrow="Why Join" title="为什么加入 SANI" description="在保持联盟规则清晰的前提下，让更多机构能够共享数据、问题与研究体系。" center={true} />
      <div class="mt-12">
        <FeatureGrid items={page.data.highlights} columns={4} />
      </div>
    </section>
  )}

  <section class="page-wrap section-shell pt-0">
    {page.data.cta ? (
      <div class="grid gap-12 lg:grid-cols-[1fr_360px] items-start">
        <div class="flex flex-col">
          <SectionHeading eyebrow="How To Join" title="加入流程" description="当前阶段重点是通过邮件把合作意向、数据边界与角色预期说明清楚。" />
          {page.data.steps && (
            <div class="mt-8 surface-card p-8 md:p-12 border-t-4 border-t-accent">
              <Timeline steps={page.data.steps} />
            </div>
          )}
        </div>
        <div class="sticky top-24 w-full">
          <CtaPanel {...page.data.cta} />
        </div>
      </div>
    ) : (
      <div class="max-w-4xl mx-auto flex flex-col">
        <SectionHeading eyebrow="How To Join" title="加入流程" description="联系意向说明。" />
        {page.data.steps && (
           <div class="mt-8 surface-card p-8 md:p-12 border-t-4 border-t-accent w-full">
              <Timeline steps={page.data.steps} />
           </div>
        )}
      </div>
    )}
  </section>

  <section class="page-wrap section-shell pt-0">
    <div class="max-w-5xl mx-auto flex flex-col items-center">
      <SectionHeading eyebrow="Contact Mode" title="机构联系方式" description="当前提供官方邮箱接口对接学术服务。" center={true} />
      <div class="mt-12 w-full grid gap-10 lg:grid-cols-[1.2fr_1fr] items-stretch surface-card p-10 md:p-12">
        <div class="prose-shell flex flex-col justify-center">
          <Content />
        </div>
        <div class="h-full flex flex-col justify-center bg-surface-alt p-8 rounded-lg border border-border">
          <span class="eyebrow ring-1 ring-inset ring-accent/10 mb-5 max-w-min">Email</span>
          <h3 class="text-[20px] leading-snug font-bold text-ink-deep font-sans break-all">{siteData.contact.email}</h3>
          <p class="mt-4 text-[15px] leading-relaxed text-text-secondary">{siteData.contact.note}</p>
          <div class="mt-8 pt-6 border-t border-border">
            <a href={`mailto:${siteData.contact.email}`} class="btn-primary w-full shadow-sm text-[14px]">
              发送合作邮件
              <span aria-hidden="true" class="ml-2 font-normal opacity-70">↗</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
