---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import StatsGrid from "../components/StatsGrid.astro";
import MetricGrid from "../components/MetricGrid.astro";
import NewsCard from "../components/NewsCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CtaPanel from "../components/CtaPanel.astro";
import { siteData } from "../data/site";
import { listPublishedNews, requirePage, sortFeaturedFirst } from "../lib/content";

const page = await requirePage("index");
const { Content } = await render(page);
const news = (await listPublishedNews()).slice(0, 3);
const projects = sortFeaturedFirst(await getCollection("projects")).slice(0, 2);

const getStatusClass = (status: "available" | "integrating" | "planned") => {
  if (status === "available") return "status-available";
  if (status === "integrating") return "status-integrating";
  return "status-planned";
};
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Hero {...page.data.hero} accentLabel={siteData.collaborationFlow} />

  <!-- Intro / Collaboration Pathway -->
  <section class="page-wrap section-shell">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      <div class="lg:col-span-4 flex flex-col justify-start">
        <SectionHeading eyebrow="Collaboration Pathway" title="合作与参与方式" description="统一工作流、标准化流程和透明协作边界，是 SANI 作为研究联盟长期运行的基础。" />
        <div class="prose-shell mt-6">
          <Content />
        </div>
        <div class="mt-8 rounded-lg border-l-4 border-accent bg-surface-alt px-5 py-4 text-[14px] leading-relaxed text-ink-deep font-medium shadow-sm">
          协作流程采用统一的版本管理与质量控制，不依赖单中心临时流程。
        </div>
      </div>

      <div class="lg:col-span-8">
        <div class="grid gap-6 md:grid-cols-3">
          <article class="surface-card h-full">
            <span class="status-badge status-available">1. 接入</span>
            <h3 class="card-title mt-5">数据汇聚</h3>
            <p class="mt-3 text-[15px] leading-7 text-text-secondary">多中心影像与临床数据按统一字段规范接入，形成可治理、追踪的数据资产。</p>
          </article>
          <article class="surface-card h-full">
            <span class="status-badge status-integrating">2. 质控</span>
            <h3 class="card-title mt-5">标准化处理</h3>
            <p class="mt-3 text-[15px] leading-7 text-text-secondary">统一预处理和派生指标策略，降低站点差异带来的方法偏差与解释噪声。</p>
          </article>
          <article class="surface-card h-full">
            <span class="status-badge status-planned">3. 产出</span>
            <h3 class="card-title mt-5">协作分析</h3>
            <p class="mt-3 text-[15px] leading-7 text-text-secondary">通过项目申请和联合发表机制，沉淀代码、报告和可持续扩展的研究成果。</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- Scale / Stats -->
  <section class="page-wrap section-shell pt-0">
    <div class="rounded-[24px] bg-ink-deep py-12 px-6 md:px-12 text-white shadow-sm overflow-hidden relative">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_150%,_rgba(31,107,102,0.4),_transparent_60%)]"></div>
      <div class="relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-8 border-b border-surface/10 pb-8 mb-8">
        <div class="max-w-xl">
          <SectionHeading title="当前协作规模" description="下列指标为当前示例值，可持续在站点级配置中更新。" inverted />
        </div>
      </div>
      <div class="relative z-10">
        <StatsGrid items={siteData.homepage.stats} />
      </div>
    </div>
  </section>

  <!-- Data & Typology -->
  <section class="page-wrap section-shell pt-0">
    <div class="grid gap-12 xl:grid-cols-2 items-stretch">
      <div class="flex flex-col">
        <SectionHeading eyebrow="Data Modalities" title="数据模态" description="按统一流程接入和标准化处理的影像与临床数据模态。" />
        <div class="mt-8 flex-1">
          <MetricGrid items={siteData.homepage.modalities} />
        </div>
      </div>

      <div class="flex flex-col">
        <SectionHeading eyebrow="Cohort Taxonomy" title="成瘾队列图谱" description="覆盖多种行为与物质成瘾，支持大规模跨模态分析。" />
        <div class="mt-8 grid gap-4 sm:grid-cols-2 flex-1 items-start">
          {siteData.homepage.addictionTypes.map((item, index) => (
            <article class="surface-card flex flex-col p-6 h-full items-start">
              <span class:list={["status-badge mb-3", getStatusClass(item.status)]}>
                {item.status === "available" ? "可用" : item.status === "integrating" ? "整合中" : "规划中"}
              </span>
              <h3 class="card-title line-clamp-2">{item.name}</h3>
              <p class="mt-2 text-sm leading-[1.6] text-text-secondary flex-1">{item.note}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  {projects.length > 0 && (
    <section class="page-wrap section-shell pt-0">
      <SectionHeading eyebrow="Featured Projects" title="重点在研项目" description="涵盖多中心联合分析、预处理管线开发与数据标准化等研究方向。" />
      
      <div class="mt-8 grid gap-6 lg:grid-cols-[380px_1fr]">
        <div class="lg:col-span-1">
          {page.data.cta ? (
            <aside class="surface-card p-6 h-auto sticky top-24 border-l-4 border-l-accent">
              <p class="eyebrow inline-flex mb-4">{page.data.cta.eyebrow || 'Notice'}</p>
              <h3 class="card-title">数据门户将稍后开放</h3>
              <p class="mt-3 text-sm leading-[1.6] text-text-secondary">{page.data.cta.description}</p>
              <div class="mt-6">
                <a href={page.data.cta.href} class="btn-secondary text-[13px] w-full" target={page.data.cta.external ? "_blank" : undefined}>
                  了解更多指南
                </a>
              </div>
            </aside>
          ) : (
            <div class="hidden lg:block"></div>
          )}
        </div>

        <div class="lg:col-span-1">
          <div class="grid gap-6 auto-rows-fr sm:grid-cols-2">
            {projects.map((entry) => (
              <ProjectCard entry={entry} />
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- News -->
  {news.length > 0 && (
    <section id="news" class="page-wrap section-shell pt-0">
      <SectionHeading eyebrow="Latest" title="新闻与动态" description="联盟最新进展、研究发布与平台建设更新。" center={true} />
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {news.map((entry) => (
          <NewsCard entry={entry} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
