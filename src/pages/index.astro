---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import FeaturedCarousel from "../components/FeaturedCarousel.astro";
import { siteData } from "../data/site";
import { listPublishedNews, sortFeaturedFirst } from "../lib/content";

// Only need featured items
const news = (await listPublishedNews()).slice(0, 1);
const projects = sortFeaturedFirst(await getCollection("projects")).slice(0, 1);

const carouselItems: { type: "项目" | "新闻"; title: string; description: string; url: string; meta: string; }[] = [];

projects.forEach(p => {
  carouselItems.push({
    type: "项目",
    title: p.data.title,
    description: p.body,
    url: "/working-groups",
    meta: p.data.lead || "SANI Team"
  });
});

news.forEach(n => {
  const dateStr = n.data.date.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" });
  carouselItems.push({
    type: "新闻",
    title: n.data.title,
    description: n.data.summary,
    url: `/news/${n.slug}/`,
    meta: dateStr
  });
});
---

<BaseLayout title={siteData.siteName} description={siteData.description}>
  
  <!-- Hero Section -->
  <section class="page-wrap pt-16 md:pt-32 pb-16 md:pb-24 flex flex-col items-center text-center">
    <div class="max-w-4xl w-full flex flex-col items-center">
      <h1 class="text-[40px] md:text-[56px] lg:text-[64px] font-serif font-bold text-ink-deep leading-[1.15] mb-4">
        中国成瘾神经影像协作计划
      </h1>
      <h2 class="text-[20px] md:text-[24px] font-[700] uppercase tracking-[0.14em] text-accent mb-8">
        Sino-Addiction Neuroimaging Initiatives
      </h2>
      <p class="text-[16px] md:text-[20px] leading-[1.7] text-text-secondary max-w-3xl text-balance">
        致力于构建标准化、可复现的多中心成瘾神经影像网络，<br class="hidden md:block"/>
        通过规范化数据治理与透明的协作机制，推动成瘾研究与转化。
      </p>
    </div>
  </section>

  <!-- Key Statistics -->
  <section class="page-wrap pb-20 md:pb-32">
    <div class="border-y border-border py-12 md:py-16">
      <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 text-center divide-y md:divide-y-0 md:divide-x divide-border">
        {siteData.homepage.stats.map((stat, i) => (
          <div class:list={["flex flex-col items-center", i !== 0 ? "pt-10 md:pt-0" : ""]}>
            <span class="text-[48px] md:text-[56px] font-serif font-bold text-ink-deep mb-3 leading-none">{stat.value}</span>
            <span class="text-[16px] font-semibold text-text-secondary uppercase tracking-widest bg-surface-alt px-3 py-1 rounded-sm border border-border">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Carousel -->
  {carouselItems.length > 0 && (
    <section class="page-wrap pb-24 md:pb-32">
       <div class="max-w-5xl mx-auto">
         <SectionHeading title="联盟动态" center={true} />
         <div class="mt-12">
           <FeaturedCarousel items={carouselItems} />
         </div>
       </div>
    </section>
  )}

  <!-- Collaboration Flow -->
  <section class="page-wrap pb-24 md:pb-32">
    <SectionHeading title="协作与产出链路" description="统一预处理、质量控制和数据管理，为多中心协同扫除方法偏差。" center={true} />
    
    <div class="mt-16 max-w-5xl mx-auto hidden md:block relative">
      <div class="absolute top-[40px] left-[16%] right-[16%] h-[2px] bg-border z-0"></div>
      
      <div class="grid grid-cols-3 gap-8 relative z-10">
        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center group">
          <div class="w-[80px] h-[80px] rounded-full bg-surface-alt border-2 border-border flex items-center justify-center text-[24px] font-bold text-ink-deep mb-6 group-hover:border-accent transition-colors shadow-sm bg-surface">
            01
          </div>
          <h3 class="text-[20px] font-bold text-ink-deep mb-4">数据汇聚</h3>
          <p class="text-[15px] leading-relaxed text-text-secondary w-full px-4">
            多中心影像与临床数据按规范字段接入，实现物理隔离下的统一治理。
          </p>
        </div>
        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center group">
          <div class="w-[80px] h-[80px] rounded-full bg-surface-alt border-2 border-border flex items-center justify-center text-[24px] font-bold text-ink-deep mb-6 group-hover:border-accent transition-colors shadow-sm bg-surface">
            02
          </div>
          <h3 class="text-[20px] font-bold text-ink-deep mb-4">标准化处理</h3>
          <p class="text-[15px] leading-relaxed text-text-secondary w-full px-4">
            采用集中部署的预处理管线与质量控制逻辑，减少跨站点非生物方差。
          </p>
        </div>
        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center group">
          <div class="w-[80px] h-[80px] rounded-full bg-surface-alt border-2 border-border flex items-center justify-center text-[24px] font-bold text-ink-deep mb-6 group-hover:border-accent transition-colors shadow-sm bg-surface">
            03
          </div>
          <h3 class="text-[20px] font-bold text-ink-deep mb-4">协作分析</h3>
          <p class="text-[15px] leading-relaxed text-text-secondary w-full px-4">
            发起科学假说驱动的联合研究申请，沉淀高复用代码和公开转化成果。
          </p>
        </div>
      </div>
    </div>

    <!-- Mobile view -->
    <div class="mt-12 md:hidden flex flex-col gap-10 relative">
      <div class="absolute left-[31px] top-4 bottom-4 w-[2px] bg-border z-0"></div>
      
      <div class="flex items-start gap-5 relative z-10">
        <div class="w-[64px] h-[64px] shrink-0 rounded-full bg-surface-alt border-2 border-border flex items-center justify-center text-[20px] font-bold text-ink-deep shadow-sm bg-surface">01</div>
        <div class="pt-2">
          <h3 class="text-[18px] font-bold text-ink-deep mb-2">数据汇聚</h3>
          <p class="text-[15px] leading-relaxed text-text-secondary">多中心影像与临床数据统一治理，隔离共享机制保障安全。</p>
        </div>
      </div>
      
      <div class="flex items-start gap-5 relative z-10">
        <div class="w-[64px] h-[64px] shrink-0 rounded-full bg-surface-alt border-2 border-border flex items-center justify-center text-[20px] font-bold text-ink-deep shadow-sm bg-surface">02</div>
        <div class="pt-2">
          <h3 class="text-[18px] font-bold text-ink-deep mb-2">标准化处理</h3>
          <p class="text-[15px] leading-relaxed text-text-secondary">部署全自动预处理管线控制质量，抹除设备与协议偏移。</p>
        </div>
      </div>

      <div class="flex items-start gap-5 relative z-10">
        <div class="w-[64px] h-[64px] shrink-0 rounded-full bg-surface-alt border-2 border-border flex items-center justify-center text-[20px] font-bold text-ink-deep shadow-sm bg-surface">03</div>
        <div class="pt-2">
          <h3 class="text-[18px] font-bold text-ink-deep mb-2">协作分析</h3>
          <p class="text-[15px] leading-relaxed text-text-secondary">发起科学假说导向分析并在平台注册审查，产生长效论著。</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
