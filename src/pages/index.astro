---
import BaseLayout from "../layouts/BaseLayout.astro";
import WhySaniStory from "../components/WhySaniStory.astro";
import { siteData } from "../data/site";
import { requirePage } from "../lib/content";

// Fetch contents
const joinPage = await requirePage("join-us");
---

<BaseLayout title={siteData.siteName} description={siteData.description}>
  <!-- Title Intro Section -->
  <section class="page-wrap flex min-h-[calc(100svh-76px)] items-center justify-center overflow-hidden py-8 md:min-h-[calc(100svh-84px)] md:py-10">
    <div class="mx-auto flex max-w-5xl flex-col items-center text-center">
      <h1 class="text-[42px] md:text-[52px] lg:text-[58px] font-serif font-bold text-ink-deep leading-[1.15] mb-4">
        中国成瘾神经影像协作计划
      </h1>
      <h2 class="text-[18px] md:text-[22px] font-bold text-accent mb-8 font-sans tracking-wide">
        Sino-Addiction Neuroimaging Initiatives
      </h2>
      <p class="text-[17px] md:text-[19px] leading-[1.85] text-text-secondary w-full text-balance mb-10">
        致力于构建标准化、可复现的多中心成瘾神经影像网络。通过透明的数据治理与跨站点协作逻辑，深耕具有临床转化价值的生物标志物发现与验证。
      </p>
      <div class="flex flex-wrap justify-center gap-6 items-center">
        <a href="#why-sani-story" class="btn-link text-[16px] font-bold group">
          下滑了解更多
          <span class="ml-2 group-hover:translate-y-1 transition-transform inline-block">↓</span>
        </a>
      </div>
    </div>
  </section>

  <WhySaniStory joinHighlights={joinPage.data.highlights ?? []} />
</BaseLayout>
