---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import FeaturedCarousel from "../components/FeaturedCarousel.astro";
import NetworkMap from "../components/NetworkMap.astro";
import { siteData } from "../data/site";
import { listPublishedNews, sortFeaturedFirst } from "../lib/content";

// Fetch contents
const news = (await listPublishedNews()).slice(0, 1);
const projects = sortFeaturedFirst(await getCollection("projects")).slice(0, 1);
const publications = sortFeaturedFirst(await getCollection("publications")).slice(0, 1);

const carouselItems: { type: "项目" | "新闻" | "成果"; title: string; description: string; url: string; meta: string; }[] = [];

news.forEach(n => {
  const dateStr = n.data.date.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" });
  carouselItems.push({
    type: "新闻",
    title: n.data.title,
    description: n.data.summary,
    url: `/news/${n.data.slug}/`,
    meta: dateStr
  });
});

projects.forEach(p => {
  carouselItems.push({
    type: "项目",
    title: p.data.title,
    description: p.body ?? "",
    url: "/working-groups",
    meta: p.data.lead || "SANI Team"
  });
});

publications.forEach(p => {
  carouselItems.push({
    type: "成果",
    title: p.data.title,
    description: p.body || p.data.authors,
    url: p.data.externalUrl || "/publications",
    meta: `${p.data.journal} / ${p.data.year}`
  });
});
---

<BaseLayout title={siteData.siteName} description={siteData.description}>
  
  <!-- Hero Section -->
  <section class="page-wrap pt-20 pb-24 md:pt-32 md:pb-32 overflow-hidden">
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-16 lg:gap-24 relative">
      <!-- Left Hero Text -->
      <div class="flex-1 max-w-2xl flex flex-col items-start text-left">
        <h1 class="text-[42px] md:text-[52px] lg:text-[58px] font-serif font-bold text-ink-deep leading-[1.15] mb-4">
          中国成瘾神经影像协作计划
        </h1>
        <h2 class="text-[18px] md:text-[22px] font-bold text-accent mb-10 font-sans tracking-wide">
          Sino-Addiction Neuroimaging Initiatives
        </h2>
        <p class="text-[17px] md:text-[19px] leading-[1.85] text-text-secondary w-full text-balance mb-12">
          致力于构建标准化、可复现的多中心成瘾神经影像网络。通过透明的数据治理与跨站点协作逻辑，深耕具有临床转化价值的生物标志物发现与验证。
        </p>
        <div class="flex flex-wrap gap-6 items-center">
           <a href="/join-us" class="btn-primary px-10 shadow-lg shadow-accent/20">加入我们</a>
           <a href="/about" class="btn-link text-[16px] font-bold group">
             了解更多联盟使命 
             <span class="ml-2 group-hover:translate-x-1 transition-transform inline-block">→</span>
           </a>
        </div>
      </div>
      
      <!-- Right Stats KPIs Pane -->
      <div class="w-full lg:w-[360px] shrink-0 flex flex-col gap-10 lg:pl-12 lg:border-l border-border/80 relative">
        {siteData.homepage.stats.map((stat) => (
          <div class="flex flex-col items-start">
            <span class="text-[13px] font-[750] text-text-muted uppercase tracking-[0.2em] mb-3 flex items-center gap-3">
              <span class="w-2 h-2 bg-accent/40 rounded-full block"></span>
              {stat.label}
            </span>
            <span class="text-[56px] xl:text-[68px] font-serif font-bold text-ink-deep leading-none tracking-tighter">{stat.value}</span>
            <p class="mt-3 text-[14px] text-text-muted/80 leading-relaxed max-w-[240px]">{stat.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Network Map Hub - Natural Transition -->
  <section class="relative pt-20 pb-10 md:pt-24 md:pb-8 bg-surface-alt/35">
     <div class="page-wrap flex flex-col items-center">
       <div class="w-full max-w-4xl mb-10 md:mb-12 text-center">
         <SectionHeading title="多中心协作版图" description="立足规模化建设的样本枢纽，实现分布式站点间的高度方法论一致性。" center={true} />
       </div>
       <!-- Map without white box -->
       <div class="w-full max-w-[1240px]">
         <NetworkMap variant="home" />
       </div>
     </div>
  </section>

  <!-- Featured Carousel - Soft Background Shift -->
  {carouselItems.length > 0 && (
    <section class="page-wrap pt-12 pb-24 md:pt-14 md:pb-28">
       <div class="max-w-5xl mx-auto">
         <div class="mb-16">
            <SectionHeading eyebrow="Alliance Updates" title="联盟动态" description="最新的科研项目进展、学术成果沉淀与机构新闻。" center={true} />
         </div>
         <FeaturedCarousel items={carouselItems} />
       </div>
    </section>
  )}

</BaseLayout>
