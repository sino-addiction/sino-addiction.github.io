---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/HomeHero.astro";
import ChinaCollaborationMap from "../components/ChinaCollaborationMap.astro";
import AllianceUpdates from "../components/AllianceUpdates.astro";
import { listPublishedNews, requirePage, sortFeaturedFirst } from "../lib/content";

const page = await requirePage("index");
const news = (await listPublishedNews()).slice(0, 4);
const projects = sortFeaturedFirst(await getCollection("projects")).slice(0, 3);
const publications = sortFeaturedFirst(await getCollection("publications"))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const truncate = (text: string, length = 86) => (text.length > length ? `${text.slice(0, length)}…` : text);

const updateItems = [
  ...news.map((entry) => ({
    type: "新闻" as const,
    title: entry.data.title,
    summary: truncate(entry.data.summary, 90),
    meta: entry.data.date.toLocaleDateString("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" }),
    href: `/news/${entry.data.slug}/`,
  })),
  ...projects.map((entry) => ({
    type: "项目" as const,
    title: entry.data.title,
    summary: truncate(entry.body ?? "项目详情请见工作组页面。", 90),
    meta: `${entry.data.lead} · ${entry.data.dateStart}-${entry.data.dateEnd}`,
    href: "/working-groups/#current-projects",
  })),
  ...publications.map((entry) => ({
    type: "成果" as const,
    title: entry.data.title,
    summary: truncate(entry.body ?? `${entry.data.journal} ${entry.data.year}`, 90),
    meta: `${entry.data.journal} · ${entry.data.year}`,
    href: "/publications/",
  })),
];
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <HomeHero
    kicker={page.data.hero.kicker}
    title={page.data.hero.title}
    subtitle={page.data.hero.subtitle}
    primaryCta={{ label: "了解更多", href: "/collaboration" }}
    secondaryCta={{ label: "加入我们", href: "/join-us" }}
  />

  <ChinaCollaborationMap />

  <AllianceUpdates items={updateItems} />
</BaseLayout>
