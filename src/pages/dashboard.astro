---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import MetricGrid from "../components/MetricGrid.astro";
import { siteData } from "../data/site";
import { requirePage, render } from "../lib/content";

// Use same hero pattern from pages
const page = await requirePage("dashboard").catch(() => null);

const getStatusClass = (status: "available" | "integrating" | "planned") => {
  if (status === "available") return "status-available";
  if (status === "integrating") return "status-integrating";
  return "status-planned";
};
---

<BaseLayout title="数据看板 | SANI" description="展示 SANI 合作网络核心的数据模态类型与专病队列建设情况。">
  <section class="page-wrap pt-16 md:pt-24 pb-12 flex flex-col items-center text-center">
    <SectionHeading title="数据看板" description="展示本合作网络的核心模态类型与专病队列建设情况" center={true} />
    {page && page.body && (
      <p class="mt-4 text-[16px] text-text-secondary max-w-3xl">{page.body}</p>
    )}
  </section>

  <section class="page-wrap section-shell py-12 md:py-16 border-t border-border">
    <SectionHeading eyebrow="Data Modalities" title="数据模态引擎" description="多维度神经影像学与电生理数据，配合标准化的特征提取流。" />
    <div class="mt-10 max-w-5xl">
      <MetricGrid items={siteData.homepage.modalities} />
    </div>
  </section>

  <section class="page-wrap section-shell py-12 md:py-16 pt-0">
    <div class="pt-12 md:pt-16 border-t border-border">
      <SectionHeading eyebrow="Cohort Taxonomy" title="成瘾队列图谱" description="支持跨种类依赖比较分析的大样本支撑体系。" />
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 max-w-6xl">
        {siteData.homepage.addictionTypes.map((item) => (
          <article class="surface-card flex flex-col p-6 h-full items-start border-t-4 border-t-accent hover:shadow-md transition-shadow">
            <span class:list={["status-badge mb-4 shrink-0", getStatusClass(item.status)]}>
              {item.status === "available" ? "已就绪" : item.status === "integrating" ? "清洗整合中" : "入组规划中"}
            </span>
            <h3 class="card-title line-clamp-2 text-[20px] mb-2">{item.name}</h3>
            <p class="mt-2 text-[14px] leading-[1.6] text-text-secondary flex-1">{item.note}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
