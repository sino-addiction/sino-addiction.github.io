                </g>

                <g font-family="Inter, Noto Sans SC, sans-serif" fill="#102132">
                  <text x="188" y="108" font-size="14" font-weight="700">中心 A</text>
                  <text x="188" y="130" font-size="12" fill="#4F6373">结构像与任务范式</text>
                  <text x="188" y="264" font-size="14" font-weight="700">中心 B</text>
                  <text x="188" y="286" font-size="12" fill="#4F6373">脑电同步与行为数据</text>
                  <text x="188" y="420" font-size="14" font-weight="700">中心 N</text>
                  <text x="188" y="442" font-size="12" fill="#4F6373">近红外与持续扩展接入</text>
                </g>

                <g font-family="Inter, Noto Sans SC, sans-serif" font-size="11" font-weight="700">
                  <rect x="188" y="146" width="40" height="20" rx="10" fill="#e6eef8" />
                  <rect x="232" y="146" width="42" height="20" rx="10" fill="#e6f3f0" />
                  <rect x="188" y="302" width="40" height="20" rx="10" fill="#e6eef8" />
                  <rect x="232" y="302" width="42" height="20" rx="10" fill="#e6f3f0" />
                  <rect x="188" y="458" width="40" height="20" rx="10" fill="#e6eef8" />
                  <rect x="232" y="458" width="42" height="20" rx="10" fill="#f7ecdd" />
                  <text x="208" y="160" text-anchor="middle" fill="#31597a">MRI</text>
                  <text x="253" y="160" text-anchor="middle" fill="#1F6B66">EEG</text>
                  <text x="208" y="316" text-anchor="middle" fill="#31597a">MRI</text>
                  <text x="253" y="316" text-anchor="middle" fill="#1F6B66">EEG</text>
                  <text x="208" y="472" text-anchor="middle" fill="#31597a">MRI</text>
                  <text x="253" y="472" text-anchor="middle" fill="#a16e2c">fNIRS</text>
                </g>
              </g>

              <path d="M284 124C322 124 336 148 352 198" fill="none" stroke="url(#accentLine)" stroke-width="2.4" stroke-linecap="round" />
              <path d="M284 280C332 280 340 276 352 280" fill="none" stroke="url(#accentLine)" stroke-width="2.4" stroke-linecap="round" />
              <path d="M284 436C322 436 336 412 352 362" fill="none" stroke="url(#accentLine)" stroke-width="2.4" stroke-linecap="round" />

              <g filter="url(#softShadow)">
                <rect x="354" y="52" width="426" height="456" rx="34" fill="#fcfdfc" stroke="#d7dfdb" stroke-width="2" />
                <text x="387" y="92" font-family="Inter, Noto Sans SC, sans-serif" font-size="16" font-weight="700" fill="#102132">多模态采集实体图</text>
                <text x="387" y="116" font-family="Inter, Noto Sans SC, sans-serif" font-size="12" fill="#4F6373">MRI、EEG 与 fNIRS 在同一研究框架内同步设计</text>

                <rect x="387" y="136" width="52" height="22" rx="11" fill="#e6eef8" />
                <rect x="447" y="136" width="52" height="22" rx="11" fill="#e6f3f0" />
                <rect x="507" y="136" width="58" height="22" rx="11" fill="#f7ecdd" />
                <text x="413" y="151" text-anchor="middle" font-family="Inter, Noto Sans SC, sans-serif" font-size="11" font-weight="700" fill="#31597a">MRI</text>
                <text x="473" y="151" text-anchor="middle" font-family="Inter, Noto Sans SC, sans-serif" font-size="11" font-weight="700" fill="#1F6B66">EEG</text>
                <text x="536" y="151" text-anchor="middle" font-family="Inter, Noto Sans SC, sans-serif" font-size="11" font-weight="700" fill="#a16e2c">fNIRS</text>

                <ellipse cx="562" cy="286" rx="154" ry="190" fill="#f4f8f6" stroke="#c7d7d2" stroke-width="3" />
                <ellipse cx="562" cy="286" rx="124" ry="156" fill="none" stroke="#95bcb7" stroke-width="2" stroke-dasharray="9 7" />
                <ellipse cx="562" cy="286" rx="96" ry="120" fill="#fcfdfc" stroke="#22384B" stroke-width="2.5" />
                <rect x="518" y="396" width="88" height="48" rx="24" fill="#f8fbfa" stroke="#22384B" stroke-width="2.5" />
                <circle cx="471" cy="286" r="10" fill="#f8fbfa" stroke="#22384B" stroke-width="2" />
                <circle cx="653" cy="286" r="10" fill="#f8fbfa" stroke="#22384B" stroke-width="2" />

                <path d="M514 251c18-18 64-18 82 0 18 18 18 58 0 86-20 30-62 42-82 28-22-14-30-40-30-72 0-16 8-30 30-42Z" fill="#edf3f1" stroke="#22384B" stroke-width="2" />
                <path d="M522 286c8-22 34-34 58-28 24 6 36 24 34 52M520 326c22 18 60 16 82-6" fill="none" stroke="#1F6B66" stroke-width="2.5" stroke-linecap="round" />
                <path d="M520 210c14-10 34-16 52-16 18 0 38 6 52 16" fill="none" stroke="#1F6B66" stroke-width="2.2" stroke-linecap="round" />
                <path d="M448 214c18-20 34-24 56-24 24 0 42 8 58 20 16 12 34 18 62 18" fill="none" stroke="#1F6B66" stroke-width="2.2" stroke-linecap="round" />
                <path d="M438 230c28 0 42 14 60 14 18 0 30-14 48-14 18 0 26 14 44 14 18 0 30-14 48-14 18 0 26 10 38 18" fill="none" stroke="#1F6B66" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />

                <g fill="#1F6B66" stroke="#ffffff" stroke-width="1.5">
                  <circle cx="496" cy="216" r="6" />
                  <circle cx="520" cy="202" r="6" />
                  <circle cx="550" cy="194" r="6" />
                  <circle cx="580" cy="194" r="6" />
                  <circle cx="608" cy="202" r="6" />
                  <circle cx="632" cy="216" r="6" />
                </g>

                <g fill="#d89a3f" stroke="#ffffff" stroke-width="1.5">
                  <circle cx="606" cy="244" r="7" />
                  <circle cx="628" cy="256" r="7" />
                  <circle cx="628" cy="286" r="7" />
                  <circle cx="606" cy="298" r="7" />
                </g>
                <g stroke="#d89a3f" stroke-width="2" stroke-linecap="round">
                  <path d="M606 244 628 256" />
                  <path d="M628 256 628 286" />
                  <path d="M628 286 606 298" />
                  <path d="M606 298 590 280" />
                </g>

                <rect x="392" y="355" width="94" height="72" rx="20" fill="#f6faf8" stroke="#d7dfdb" stroke-width="2" />
                <path d="M410 390c8-12 14-12 22 0s14 12 22 0 14-12 22 0" fill="none" stroke="#1F6B66" stroke-width="2.4" stroke-linecap="round" />
                <text x="439" y="376" text-anchor="middle" font-family="Inter, Noto Sans SC, sans-serif" font-size="11" font-weight="700" fill="#1F6B66">EEG</text>

                <rect x="637" y="355" width="104" height="72" rx="20" fill="#fbf7ef" stroke="#e6d3b2" stroke-width="2" />
                <path d="M660 399c10-18 18-26 32-34M688 391c8-16 18-24 30-30" fill="none" stroke="#d89a3f" stroke-width="2.4" stroke-linecap="round" />
                <circle cx="658" cy="401" r="5" fill="#d89a3f" />
                <circle cx="684" cy="393" r="5" fill="#d89a3f" />
                <circle cx="710" cy="377" r="5" fill="#d89a3f" />
                <text x="689" y="376" text-anchor="middle" font-family="Inter, Noto Sans SC, sans-serif" font-size="11" font-weight="700" fill="#a16e2c">fNIRS</text>

                <rect x="500" y="448" width="124" height="26" rx="13" fill="#e6eef8" />
                <text x="562" y="466" text-anchor="middle" font-family="Inter, Noto Sans SC, sans-serif" font-size="11" font-weight="700" fill="#31597a">MRI 扫描与统一序列</text>
              </g>

              <path d="M780 280H816" fill="none" stroke="#1F6B66" stroke-width="2.4" stroke-linecap="round" marker-end="url(#flowArrow)" />

              <g filter="url(#softShadow)">
                <rect x="820" y="52" width="336" height="456" rx="34" fill="#fcfdfc" stroke="#d7dfdb" stroke-width="2" />
                <text x="852" y="92" font-family="Inter, Noto Sans SC, sans-serif" font-size="16" font-weight="700" fill="#102132">协作流程</text>
                <text x="852" y="116" font-family="Inter, Noto Sans SC, sans-serif" font-size="12" fill="#4F6373">从脱敏接入到联合产出，保持跨站点方法一致性</text>

                <rect x="850" y="144" width="122" height="96" rx="22" fill="#f6faf8" stroke="#d7dfdb" stroke-width="2" />
                <rect x="1002" y="144" width="122" height="96" rx="22" fill="#f6faf8" stroke="#d7dfdb" stroke-width="2" />
                <rect x="850" y="266" width="122" height="96" rx="22" fill="#f6faf8" stroke="#d7dfdb" stroke-width="2" />
                <rect x="1002" y="266" width="122" height="96" rx="22" fill="#f6faf8" stroke="#d7dfdb" stroke-width="2" />

                <g stroke="#1F6B66" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none">
                  <path d="M877 176h28M891 162v28M1032 167h28M1032 183h28M893 292l16 16 26-30M1032 294h22M1032 306h22M1032 318h22" />
                </g>

                <g font-family="Inter, Noto Sans SC, sans-serif" fill="#102132">
                  <text x="911" y="202" text-anchor="middle" font-size="14" font-weight="700">脱敏接入</text>
                  <text x="911" y="223" text-anchor="middle" font-size="11" fill="#4F6373">BIDS 与元数据</text>
                  <text x="1063" y="202" text-anchor="middle" font-size="14" font-weight="700">统一质控</text>
                  <text x="1063" y="223" text-anchor="middle" font-size="11" fill="#4F6373">跨模态校准</text>
                  <text x="911" y="324" text-anchor="middle" font-size="14" font-weight="700">融合分析</text>
                  <text x="911" y="345" text-anchor="middle" font-size="11" fill="#4F6373">联合特征建模</text>
                  <text x="1063" y="324" text-anchor="middle" font-size="14" font-weight="700">协作产出</text>
                  <text x="1063" y="345" text-anchor="middle" font-size="11" fill="#4F6373">论文、代码、衍生库</text>
                </g>

                <path d="M972 192H998" fill="none" stroke="#1F6B66" stroke-width="2" marker-end="url(#flowArrow)" />
                <path d="M1063 240v20" fill="none" stroke="#1F6B66" stroke-width="2" marker-end="url(#flowArrow)" />
                <path d="M1002 314H976" fill="none" stroke="#1F6B66" stroke-width="2" marker-end="url(#flowArrow)" />

                <path d="M911 362v26" fill="none" stroke="#1F6B66" stroke-width="2" marker-end="url(#flowArrow)" />

                <rect x="852" y="398" width="270" height="74" rx="24" fill="#f7faf8" stroke="#d7dfdb" stroke-width="2" />
                <g font-family="Inter, Noto Sans SC, sans-serif">
                  <circle cx="912" cy="435" r="18" fill="#e6eef8" />
                  <ellipse cx="912" cy="431" rx="11" ry="5" fill="none" stroke="#31597a" stroke-width="1.8" />
                  <path d="M901 431v8c0 3 5 5 11 5s11-2 11-5v-8" fill="none" stroke="#31597a" stroke-width="1.8" />
                  <text x="912" y="462" text-anchor="middle" font-size="11" font-weight="700" fill="#31597a">数据集</text>

                  <circle cx="988" cy="435" r="18" fill="#e6f3f0" />
                  <path d="M979 440h18M988 431v18" fill="none" stroke="#1F6B66" stroke-width="1.8" stroke-linecap="round" />
                  <text x="988" y="462" text-anchor="middle" font-size="11" font-weight="700" fill="#1F6B66">流程</text>

                  <circle cx="1064" cy="435" r="18" fill="#f7ecdd" />
                  <path d="M1055 426h12M1055 432h12M1055 438h12" fill="none" stroke="#a16e2c" stroke-width="1.8" stroke-linecap="round" />
                  <text x="1064" y="462" text-anchor="middle" font-size="11" font-weight="700" fill="#a16e2c">论文</text>
                </g>
              </g>
            </svg>
          </div>

          <div class="mt-6 grid gap-4 md:hidden">
            <div class="rounded-[24px] border border-border/70 bg-white/85 p-4 shadow-[0_10px_28px_rgba(16,33,50,0.06)]">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p class="text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Core Visual</p>
                  <h3 class="mt-1 text-[20px] font-bold text-ink-deep">多模态采集实体图</h3>
                </div>
                <span class="rounded-full border border-accent/15 bg-accent/5 px-3 py-1 text-[12px] font-semibold text-accent">MRI + EEG + fNIRS</span>
              </div>

              <div class="mt-4 overflow-hidden rounded-[22px] border border-border/60 bg-[linear-gradient(180deg,#f8fbfa_0%,#f2f7f5_100%)] p-4">
                <svg viewBox="0 0 320 220" class="w-full h-auto" role="img" aria-label="移动端多模态测量示意图">
                  <ellipse cx="160" cy="112" rx="94" ry="104" fill="#f4f8f6" stroke="#c7d7d2" stroke-width="2.5" />
                  <ellipse cx="160" cy="112" rx="72" ry="84" fill="#fcfdfc" stroke="#22384B" stroke-width="2.2" />
                  <path d="M115 66c18-14 34-18 45-18 11 0 27 4 45 18" fill="none" stroke="#1F6B66" stroke-width="2.5" stroke-linecap="round" />
                  <path d="M92 82c20 0 30 12 42 12 12 0 22-12 34-12 12 0 22 12 34 12s22-12 34-12 22 8 32 14" fill="none" stroke="#1F6B66" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                  <g fill="#1F6B66" stroke="#ffffff" stroke-width="1.3">
                    <circle cx="116" cy="66" r="5" />
                    <circle cx="138" cy="56" r="5" />
                    <circle cx="160" cy="52" r="5" />
                    <circle cx="182" cy="56" r="5" />
                    <circle cx="204" cy="66" r="5" />
                  </g>
                  <path d="M136 112c8-20 34-28 56-22 18 5 28 18 30 40M134 146c20 14 48 12 66-6" fill="none" stroke="#1F6B66" stroke-width="2.5" stroke-linecap="round" />
                  <g fill="#d89a3f" stroke="#ffffff" stroke-width="1.2">
                    <circle cx="196" cy="96" r="6" />
                    <circle cx="212" cy="110" r="6" />
                    <circle cx="210" cy="132" r="6" />
                    <circle cx="194" cy="144" r="6" />
                  </g>
                  <rect x="98" y="176" width="124" height="26" rx="13" fill="#e6eef8" />
                  <text x="160" y="193" text-anchor="middle" font-family="Inter, Noto Sans SC, sans-serif" font-size="12" font-weight="700" fill="#31597a">统一采集与协作分析</text>
                </svg>
              </div>
            </div>

            <div class="grid gap-3">
              {collaborationVisual.sites.map((site) => (
                <article class="rounded-[22px] border border-border/70 bg-white/85 p-4 shadow-[0_10px_28px_rgba(16,33,50,0.06)]">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <h3 class="text-[18px] font-bold text-ink-deep">{site.name}</h3>
                      <p class="mt-1 text-[14px] leading-relaxed text-text-secondary">{site.note}</p>
                    </div>
                    <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-border/70 bg-surface-alt/70 text-accent">
                      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" aria-hidden="true">
                        <path d="M5 20V6.5h14V20M9 6.5v-3h6v3M8 11h1M11.5 11h1M15 11h1M8 15h1M11.5 15h1M15 15h1" />
                      </svg>
                    </div>
                  </div>
                  <div class="mt-3 flex flex-wrap gap-2">
                    {collaborationVisual.modalities.map((item) => (
                      <span class:list={["modality-chip", `modality-chip-${item.tone}`]}>{item.label}</span>
                    ))}
                  </div>
                </article>
              ))}
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              {collaborationVisual.steps.map((step, idx) => (
                <article class="rounded-[22px] border border-border/70 bg-white/85 p-4 shadow-[0_10px_28px_rgba(16,33,50,0.06)]">
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-[13px] font-semibold uppercase tracking-[0.14em] text-accent">0{idx + 1}</span>
                    <span class="h-2.5 w-2.5 rounded-full bg-accent/70"></span>
                  </div>
                  <h3 class="mt-3 text-[18px] font-bold text-ink-deep">{step.title}</h3>
                  <p class="mt-1 text-[14px] leading-relaxed text-text-secondary">{step.note}</p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Core Process Flow - Moved from Homepage -->
