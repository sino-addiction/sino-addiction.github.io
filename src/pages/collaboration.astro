---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import { siteData } from "../data/site";
import { requirePage } from "../lib/content";

const page = await requirePage("collaboration");
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Hero {...page.data.hero} compact={true} accentLabel={siteData.collaborationFlow} />

  <section class="page-wrap section-shell">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <div class="flex flex-col h-full justify-center">
        <SectionHeading eyebrow="System Design" title="从数据到成果的协作链路" description="SANI 的协作重点不是单次数据汇总，而是让治理、处理、分析和成果沉淀形成可持续复用的模式。" />
        <div class="prose-shell mt-8 surface-card p-8 md:p-10 border-l-4 border-l-status-integrating">
          <Content />
        </div>
      </div>
      <div class="h-full w-full">
        <div class="grid gap-4 auto-rows-fr h-full">
          {siteData.collaborationFlow.map((item, index) => (
            <article class="surface-card flex items-center gap-4 p-5 md:p-6 hover:border-accent hover:shadow-md transition-all">
              <span class="flex shrink-0 h-10 w-10 bg-surface-alt border border-border text-ink-deep font-bold items-center justify-center rounded-lg text-sm">{index + 1}</span>
              <div class="min-w-0 flex flex-col justify-center">
                <span class="text-[12px] font-bold text-accent uppercase tracking-wider">Phase {index + 1}</span>
                <h3 class="card-title text-[18px] opacity-90 mt-1">{item}</h3>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  {page.data.sections && (
    <section class="page-wrap section-shell pt-0">
      <SectionHeading eyebrow="Governance Details" title="协作原则" description="把角色分工、工作流与署名规则写清楚，是联盟持续运行的前提。" center={true} />
      <div class="mt-12">
        <FeatureGrid
          items={page.data.sections.map((section) => ({
            label: "SANI",
            title: section.title,
            description: section.body,
          }))}
          columns={2}
        />
      </div>
    </section>
  )}
</BaseLayout>
