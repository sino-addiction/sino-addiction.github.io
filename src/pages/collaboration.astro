---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { siteData } from "../data/site";
import { requirePage } from "../lib/content";

const page = await requirePage("collaboration");
const { Content } = await render(page);

const collaborationVisual = {
  modalities: [
    { label: "MRI", tone: "mri" },
    { label: "EEG", tone: "eeg" },
    { label: "fNIRS", tone: "fnirs" },
  ],
  sites: [
    { name: "中心 A", note: "结构像与任务范式" },
    { name: "中心 B", note: "脑电同步与行为数据" },
    { name: "中心 N", note: "近红外与持续扩展接入" },
  ],
  steps: [
    { title: "脱敏接入", note: "BIDS 与元数据整理" },
    { title: "统一质控", note: "跨模态校准与核查" },
    { title: "融合分析", note: "时空特征联合建模" },
    { title: "协作产出", note: "论文、代码与衍生库" },
  ],
  outputs: ["数据集", "流程", "论文"],
};
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <!-- Compact Hero -->
  <Hero title={page.data.title} subtitle={page.data.description} compact={true} />

  <section class="page-wrap pb-20 md:pb-24">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        eyebrow="Multimodal"
        title="多模态协作测量"
        description="用实体图、流程图与图标把多中心采集、MRI/EEG/fNIRS 联合测量以及后续协作分析放在同一张视觉框架里。"
        center={true}
      />

      <div class="collaboration-visual-shell mt-10 md:mt-12 rounded-[32px] border border-border/80 p-4 md:p-6 shadow-[0_18px_48px_rgba(16,33,50,0.06)]">
        <div class="collaboration-visual-core rounded-[28px] border border-white/80 px-4 py-5 md:px-6 md:py-7">
          <div class="flex flex-wrap items-center justify-center gap-2 md:gap-3">
            {collaborationVisual.modalities.map((item) => (
              <span class:list={["modality-chip", `modality-chip-${item.tone}`]}>{item.label}</span>
            ))}
          </div>

          <div class="mt-6 hidden md:block">
            <svg
              viewBox="0 0 1200 560"
              class="w-full h-auto"
              role="img"
              aria-label="多中心 MRI、EEG 与 fNIRS 协作测量和分析流程图"
            >
              <defs>
                <filter id="softShadow" x="-20%" y="-20%" width="140%" height="140%">
                  <feDropShadow dx="0" dy="10" stdDeviation="14" flood-color="#102132" flood-opacity="0.08" />
                </filter>
                <linearGradient id="panelGlow" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="#ffffff" stop-opacity="0.92" />
                  <stop offset="100%" stop-color="#f4f8f6" stop-opacity="0.98" />
                </linearGradient>
                <linearGradient id="accentLine" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color="#9bbdb9" />
                  <stop offset="100%" stop-color="#1F6B66" />
                </linearGradient>
                <marker id="flowArrow" viewBox="0 0 12 12" refX="10" refY="6" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
                  <path d="M1 1 10 6 1 11" fill="none" stroke="#1F6B66" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </marker>
              </defs>

              <rect x="8" y="8" width="1184" height="544" rx="30" fill="url(#panelGlow)" />
              <circle cx="1088" cy="86" r="56" fill="#e3eeea" opacity="0.55" />
              <circle cx="178" cy="488" r="72" fill="#eef4f2" opacity="0.92" />
              <path d="M736 36c88 24 154 72 202 144" fill="none" stroke="#dbe8e3" stroke-width="2" stroke-dasharray="5 8" />

              <g filter="url(#softShadow)">
                <rect x="44" y="70" width="240" height="108" rx="24" fill="#fcfdfc" stroke="#d7dfdb" stroke-width="2" />
                <rect x="44" y="226" width="240" height="108" rx="24" fill="#fcfdfc" stroke="#d7dfdb" stroke-width="2" />
                <rect x="44" y="382" width="240" height="108" rx="24" fill="#fcfdfc" stroke="#d7dfdb" stroke-width="2" />

                <g stroke="#22384B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none">
                  <rect x="64" y="95" width="52" height="52" rx="16" fill="#f6faf8" />
                  <path d="M78 126h24M82 116h4M92 116h4M102 116h4M82 106h4M92 106h4M102 106h4M90 95v10" />
                  <circle cx="145" cy="120" r="24" fill="#f6faf8" />
                  <path d="M131 122c4-12 24-12 28 0M132 128c6 8 20 8 26 0M139 110c1 7 9 7 10 0M151 110c1 7 9 7 10 0" />

                  <rect x="64" y="251" width="52" height="52" rx="16" fill="#f6faf8" />
                  <path d="M78 282h24M82 272h4M92 272h4M102 272h4M82 262h4M92 262h4M102 262h4M90 251v10" />
                  <circle cx="145" cy="276" r="24" fill="#f6faf8" />
                  <path d="M131 278c4-12 24-12 28 0M132 284c6 8 20 8 26 0M139 266c1 7 9 7 10 0M151 266c1 7 9 7 10 0" />

                  <rect x="64" y="407" width="52" height="52" rx="16" fill="#f6faf8" />
                  <path d="M78 438h24M82 428h4M92 428h4M102 428h4M82 418h4M92 418h4M102 418h4M90 407v10" />
                  <circle cx="145" cy="432" r="24" fill="#f6faf8" />
