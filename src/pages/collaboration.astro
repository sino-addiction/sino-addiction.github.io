---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProcessIcon from "../components/ProcessIcon.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { siteData } from "../data/site";
import { requirePage } from "../lib/content";

const page = await requirePage("collaboration");
const { Content } = await render(page);

const modalityLegend = [
  { label: "MRI", tone: "mri" },
  { label: "EEG", tone: "eeg" },
  { label: "fNIRS", tone: "fnirs" },
];

const collaborationHubModules = [
  { title: "任务范式统一", note: "刺激范式对齐与事件标记规范", icon: "play", position: "top-left" },
  { title: "采集协议统一", note: "MRI、EEG 与 fNIRS 采集口径统一", icon: "upload", position: "top-right" },
  { title: "BIDS 与元数据", note: "脱敏整理、字段映射与版本管理", icon: "database", position: "bottom-left" },
  { title: "统一质控与校准", note: "模态内 QC 与跨站点一致性检查", icon: "check", position: "bottom-right" },
] as const;

const collaborationWorkflow = [
  { title: "多中心接入", note: "统一纳入标准与元数据准备", icon: "upload" },
  { title: "脱敏与 BIDS", note: "原始数据标准化整理、归档与映射", icon: "database" },
  { title: "统一质控", note: "跨站点一致性检查与校准", icon: "check" },
  { title: "融合分析", note: "多模态联合建模与特征提取", icon: "share" },
  { title: "协作产出", note: "形成数据、流程、代码与论文等共享成果", icon: "play" },
] as const;

const collaborationOutputs = [
  { title: "数据集", icon: "database" },
  { title: "协议/流程", icon: "upload" },
  { title: "代码/工具", icon: "share" },
  { title: "论文/报告", icon: "play" },
] as const;

const networkConnections = [
  ["北京", "上海"], ["北京", "武汉"], ["上海", "武汉"], ["武汉", "广州"], ["武汉", "西安"], ["西安", "成都"], ["成都", "武汉"]
];
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Hero title={page.data.title} subtitle={page.data.description} compact={true} />

  <section class="page-wrap pb-20 md:pb-28">
    <div class="max-w-[1320px] mx-auto">
      <SectionHeading
        eyebrow="Framework"
        title="SANI 多中心多模态协作框架"
        description="以多中心参与网络、统一协议与数据治理中枢、联合分析工作流三部分呈现 SANI 的协作机制。"
        center={true}
      />

      <div class="collaboration-visual-shell mt-10 md:mt-12 rounded-[36px] border border-border/80 p-4 md:p-6 lg:p-7 shadow-[0_18px_48px_rgba(16,33,50,0.06)]">
        <div class="grid gap-4 lg:grid-cols-[minmax(280px,1fr)_72px_minmax(380px,1.18fr)_72px_minmax(280px,1fr)] lg:items-stretch">
          <article class="framework-panel">
            <span class="panel-label">多中心参与网络</span>
            <h3 class="panel-title mt-4">全国多中心协作节点</h3>
            <p class="panel-description mt-3">各中心围绕 MRI、EEG 与 fNIRS 参与协作，先完成本地伦理、采集与元数据准备，再按联盟标准进入统一流程。</p>

            <div class="network-map-frame mt-6">
              <img src="/assets/china-map.svg" alt="SANI 多中心参与网络地图" class="network-map-image" />
              
              <svg class="absolute inset-0 w-full h-full pointer-events-none" style="z-index: 0;">
                {networkConnections.map((conn) => {
                  const p1 = siteData.networkMap.find(p => p.city === conn[0]);
                  const p2 = siteData.networkMap.find(p => p.city === conn[1]);
                  if (!p1 || !p2) return null;
                  return (
                    <line
                      x1={`${p1.x}%`} y1={`${p1.y * 700 / 950}%`}
                      x2={`${p2.x}%`} y2={`${p2.y * 700 / 950}%`}
                      stroke="rgba(31, 107, 102, 0.4)"
                      stroke-width="1.5"
                      stroke-dasharray="4 4"
                    />
                  );
                })}
              </svg>

              {siteData.networkMap.map((point) => (
                <div class="network-map-node" style={`left:${point.x}%; top:${point.y * 700 / 950}%; z-index: 10;`} aria-label={`${point.city} ${point.count}`}>
                  <span class="network-map-dot"></span>
                  <span
                    class:list={[
                      "network-map-label",
                      point.dir === "top" && "network-map-label-top",
                      point.dir === "right" && "network-map-label-right",
                      point.dir === "bottom" && "network-map-label-bottom",
                      point.dir === "left" && "network-map-label-left",
                    ]}
                  >
                    <strong>{point.city}</strong>
                    <span>{point.count}</span>
                  </span>
                </div>
              ))}
            </div>

            <div class="mt-8 flex items-center justify-between text-[13px] font-bold text-accent px-4 py-3 bg-accent/5 rounded-[18px] border border-accent/10">
              <span class="flex items-center gap-1.5"><ProcessIcon name="upload" class="h-4 w-4" />本地采集</span>
              <span class="text-accent/30">→</span>
              <span class="flex items-center gap-1.5"><ProcessIcon name="check" class="h-4 w-4" />本地质控</span>
              <span class="text-accent/30">→</span>
              <span class="flex items-center gap-1.5"><ProcessIcon name="database" class="h-4 w-4" />脱敏整理</span>
              <span class="text-accent/30">→</span>
              <span class="flex items-center gap-1.5"><ProcessIcon name="share" class="h-4 w-4" />联盟接入</span>
            </div>

            <div class="network-footnote mt-5">
              <span class="network-footnote-icon" aria-hidden="true"><ProcessIcon name="upload" class="h-5 w-5" /></span>
              <span>各中心保留原始数据，仅将去标识化、标准化副本接入联盟协作流程。</span>
            </div>
          </article>

          <div class="framework-connector hidden lg:flex" aria-hidden="true">
            <span class="framework-connector-pill">标准化接入</span>
            <span class="framework-connector-line"></span>
            <span class="framework-connector-arrow">→</span>
          </div>

          <article class:list={["framework-panel", "framework-panel-highlight"]}>
            <span class="panel-label">统一协议与数据治理</span>
            <h3 class="panel-title mt-4">统一多中心与多模态协作框架</h3>
            <p class="panel-description mt-3">在统一任务、协议、标准与质控框架下，提高跨站点一致性，支撑后续联合分析的可比较、可复现与可扩展。</p>

            <div class="hub-desktop mt-8 hidden md:block">
              <svg class="hub-lines" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                <path d="M24 22C34 26 42 34 50 50" />
                <path d="M76 22C66 26 58 34 50 50" />
                <path d="M24 78C34 74 42 66 50 50" />
                <path d="M76 78C66 74 58 66 50 50" />
                <circle cx="50" cy="50" r="18" />
              </svg>

              <div class="hub-core">
                <span class="hub-core-kicker">SANI</span>
                <h4 class="hub-core-title">协作中枢</h4>
                <p class="hub-core-note">统一协议 · 数据治理<br/>MRI / EEG / fNIRS</p>
              </div>

              {collaborationHubModules.map((module) => (
                <article class:list={["hub-module-card", `hub-module-${module.position}`]}>
                  <span class="hub-module-icon" aria-hidden="true"><ProcessIcon name={module.icon} class="h-5 w-5" /></span>
                  <h4 class="hub-module-title">{module.title}</h4>
                  <p class="hub-module-note">{module.note}</p>
                </article>
              ))}
            </div>

            <div class="mt-6 grid gap-3 md:hidden">
              <div class="hub-core hub-core-mobile">
                <span class="hub-core-kicker">SANI</span>
                <h4 class="hub-core-title">协作中枢</h4>
                <p class="hub-core-note">统一协议 · 数据治理<br/>MRI / EEG / fNIRS</p>
              </div>

              {collaborationHubModules.map((module) => (
                <article class="hub-module-card-mobile">
                  <span class="hub-module-icon" aria-hidden="true"><ProcessIcon name={module.icon} class="h-5 w-5" /></span>
                  <div>
                    <h4 class="hub-module-title">{module.title}</h4>
                    <p class="hub-module-note">{module.note}</p>
                  </div>
                </article>
              ))}
            </div>
          </article>

          <div class="framework-connector hidden lg:flex" aria-hidden="true">
            <span class="framework-connector-pill">联合分析</span>
            <span class="framework-connector-line"></span>
            <span class="framework-connector-arrow">→</span>
          </div>

          <article class="framework-panel">
            <span class="panel-label">联合分析与协作产出</span>
            <h3 class="panel-title mt-4">从标准化接入到开放产出</h3>
            <p class="panel-description mt-3">流程单向推进，减少跨站点协作中的协议漂移与数据口径偏差，使结果更稳定地沉淀为共享资源。</p>

            <div class="workflow-stack mt-6">
              <div class="workflow-rail" aria-hidden="true"></div>
              {collaborationWorkflow.map((step, idx) => (
                <div class="flex flex-col gap-5">
                  <article class="workflow-step relative">
                    <span class="workflow-step-icon" aria-hidden="true"><ProcessIcon name={step.icon} class="h-5 w-5" /></span>
                    <div class="workflow-step-body">
                      <span class="workflow-step-index">0{idx + 1}</span>
                      <h4 class="workflow-step-title">{step.title}</h4>
                      <p class="workflow-step-note">{step.note}</p>
                    </div>
                  </article>
                  {idx === 4 && (
                    <div class="outputs-grid ml-[4.6rem] relative z-10">
                      {collaborationOutputs.map((item) => (
                        <article class="output-card shadow-[0_4px_12px_rgba(16,33,50,0.04)] hover:-translate-y-0.5 transition-transform duration-200">
                          <span class="output-icon" aria-hidden="true"><ProcessIcon name={item.icon} class="h-5 w-5" /></span>
                          <span class="output-title">{item.title}</span>
                        </article>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-alt/40 py-24 md:py-32">
    <div class="page-wrap">
      <div class="grid gap-16 lg:grid-cols-2 max-w-6xl mx-auto items-start">
        <div class="sticky top-28">
          <SectionHeading eyebrow="Governance" title="联盟管理与数据规则" description="构建透明、公平的协作机制是 SANI 长期运行的基石。" />
          <div class="mt-10 prose-shell surface-card p-10 border-l-4 border-accent text-[15px] leading-[1.85]">
            <Content />
          </div>
        </div>

        <div class="grid gap-8">
          {page.data.sections && page.data.sections.map((section) => (
            <article class="surface-card p-8 border-t-4 border-accent/20 hover:border-accent transition-colors">
              <span class="inline-block px-2 py-0.5 bg-accent/5 rounded text-[11px] font-bold text-accent uppercase mb-4">Protocol</span>
              <h3 class="text-[20px] font-bold text-ink-deep mb-4">{section.title}</h3>
              <p class="text-[15px] leading-[1.7] text-text-secondary">{section.body}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <style>
    .collaboration-visual-shell {
      background:
        radial-gradient(circle at 12% 18%, rgba(31, 107, 102, 0.09), transparent 26%),
        radial-gradient(circle at 88% 14%, rgba(49, 89, 122, 0.08), transparent 24%),
        linear-gradient(180deg, rgba(252, 253, 252, 0.98) 0%, rgba(244, 248, 246, 0.96) 100%);
    }

    .framework-panel {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(215, 223, 219, 0.88);
      border-radius: 30px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(252, 253, 252, 0.98) 100%);
      padding: 1.5rem;
      box-shadow: 0 16px 36px rgba(16, 33, 50, 0.05);
    }

    .framework-panel-highlight {
      background:
        radial-gradient(circle at 50% 14%, rgba(31, 107, 102, 0.08), transparent 30%),
        linear-gradient(180deg, rgba(252, 253, 252, 0.98) 0%, rgba(248, 251, 250, 0.98) 100%);
    }

    .framework-panel::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.22), transparent 32%);
      pointer-events: none;
    }

    .panel-label {
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      padding: 0 0.8rem;
      border-radius: 9999px;
      background: rgba(31, 107, 102, 0.08);
      color: #1f6b66;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
    }

    .panel-title {
      font-family: var(--font-serif);
      font-size: clamp(1.6rem, 1.2rem + 1vw, 2rem);
      line-height: 1.2;
      color: var(--color-ink-deep);
    }

    .panel-description {
      color: var(--color-text-secondary);
      font-size: 0.97rem;
      line-height: 1.8;
      max-width: 36rem;
    }

    .framework-connector {
      position: relative;
      align-items: center;
      justify-content: center;
      min-height: 100%;
    }

    .framework-connector-line {
      position: absolute;
      left: 0;
      right: 0;
      top: 50%;
      height: 1px;
      background: linear-gradient(90deg, rgba(151, 178, 174, 0.2), rgba(31, 107, 102, 0.85), rgba(151, 178, 174, 0.2));
      transform: translateY(-50%);
    }

    .framework-connector-pill {
      position: relative;
      z-index: 1;
      padding: 0.38rem 0.75rem;
      border-radius: 9999px;
      background: rgba(252, 253, 252, 0.96);
      border: 1px solid rgba(31, 107, 102, 0.12);
      color: #1f6b66;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
    }

    .framework-connector-arrow {
      position: absolute;
      right: 0;
      top: 50%;
      z-index: 1;
      display: flex;
      width: 2.25rem;
      height: 2.25rem;
      align-items: center;
      justify-content: center;
      transform: translateY(-50%);
      border-radius: 9999px;
      background: rgba(31, 107, 102, 0.1);
      color: #1f6b66;
      font-size: 1.1rem;
      font-weight: 700;
    }

    .network-map-frame {
      position: relative;
      overflow: hidden;
      border-radius: 26px;
      border: 1px solid rgba(215, 223, 219, 0.9);
      background:
        radial-gradient(circle at 50% 50%, rgba(31, 107, 102, 0.06), transparent 46%),
        linear-gradient(180deg, rgba(248, 251, 250, 1) 0%, rgba(243, 247, 245, 1) 100%);
      aspect-ratio: 11 / 8;
      min-height: 280px;
    }

    .network-map-image {
      width: 100%;
      height: 100%;
      object-fit: contain;
      opacity: 0.55;
      transform: scale(1.04);
      user-select: none;
      pointer-events: none;
    }

    .network-map-node {
      position: absolute;
      transform: translate(-50%, -50%);
    }

    .network-map-dot {
      display: block;
      width: 0.8rem;
      height: 0.8rem;
      border-radius: 9999px;
      background: var(--color-accent);
      border: 3px solid rgba(255, 255, 255, 0.95);
      box-shadow: 0 0 0 6px rgba(31, 107, 102, 0.12), 0 8px 18px rgba(16, 33, 50, 0.15);
    }

    .network-map-label {
      position: absolute;
      display: inline-flex;
      flex-direction: column;
      gap: 0.1rem;
      min-width: max-content;
      padding: 0.45rem 0.7rem;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(215, 223, 219, 0.9);
      box-shadow: 0 10px 24px rgba(16, 33, 50, 0.08);
      line-height: 1.2;
    }

    .network-map-label strong {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--color-ink-deep);
    }

    .network-map-label span {
      font-size: 0.72rem;
      color: var(--color-text-muted);
      font-weight: 600;
    }

    .network-map-label-top {
      left: 50%;
      bottom: calc(100% + 0.55rem);
      transform: translateX(-50%);
    }

    .network-map-label-right {
      left: calc(100% + 0.55rem);
      top: 50%;
      transform: translateY(-50%);
    }

    .network-map-label-bottom {
      left: 50%;
      top: calc(100% + 0.55rem);
      transform: translateX(-50%);
    }

    .network-map-label-left {
      right: calc(100% + 0.55rem);
      top: 50%;
      transform: translateY(-50%);
    }

    .network-footnote {
      display: flex;
      gap: 0.85rem;
      align-items: center;
      padding: 0.95rem 1rem;
      border-radius: 20px;
      background: rgba(247, 249, 248, 0.92);
      border: 1px solid rgba(215, 223, 219, 0.86);
      color: var(--color-text-secondary);
      font-size: 0.9rem;
      line-height: 1.7;
    }

    .network-footnote-icon,
    .hub-module-icon,
    .workflow-step-icon,
    .output-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: var(--color-accent);
      background: rgba(31, 107, 102, 0.08);
    }

    .network-footnote-icon {
      width: 2.4rem;
      height: 2.4rem;
      border-radius: 16px;
    }

    .hub-desktop {
      position: relative;
      min-height: 430px;
    }

    .hub-lines {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      overflow: visible;
      pointer-events: none;
    }

    .hub-lines path,
    .hub-lines circle {
      fill: none;
      stroke: rgba(31, 107, 102, 0.3);
      stroke-width: 1.3;
      stroke-dasharray: 5 5;
    }

    .hub-core {
      position: absolute;
      left: 50%;
      top: 50%;
      display: flex;
      width: 236px;
      min-height: 236px;
      transform: translate(-50%, -50%);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      border-radius: 9999px;
      border: 1px solid rgba(31, 107, 102, 0.22);
      background: radial-gradient(circle at 50% 30%, rgba(31, 107, 102, 0.14), rgba(252, 253, 252, 0.98) 55%);
      box-shadow: 0 24px 44px rgba(16, 33, 50, 0.08), inset 0 0 0 12px rgba(31, 107, 102, 0.05);
      padding: 1.5rem;
      text-align: center;
      z-index: 10;
    }

    .hub-core-mobile {
      position: relative;
      left: auto;
      top: auto;
      width: 100%;
      min-height: auto;
      transform: none;
      border-radius: 28px;
    }

    .hub-core-kicker {
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      color: var(--color-accent);
      text-transform: uppercase;
    }

    .hub-core-title {
      margin-top: 0.45rem;
      font-family: var(--font-serif);
      font-size: 1.55rem;
      line-height: 1.15;
      color: var(--color-ink-deep);
    }

    .hub-core-note {
      margin-top: 0.55rem;
      font-size: 0.84rem;
      line-height: 1.65;
      color: var(--color-text-secondary);
    }

    .hub-module-card {
      position: absolute;
      width: 176px;
      border-radius: 22px;
      border: 1px solid rgba(215, 223, 219, 0.92);
      background: rgba(255, 255, 255, 0.92);
      padding: 1rem;
      box-shadow: 0 12px 28px rgba(16, 33, 50, 0.06);
    }

    .hub-module-top-left { left: 0; top: 1rem; }
    .hub-module-top-right { right: 0; top: 1rem; }
    .hub-module-bottom-left { left: 0; bottom: 1rem; }
    .hub-module-bottom-right { right: 0; bottom: 1rem; }

    .hub-module-card-mobile {
      display: grid;
      grid-template-columns: 2.9rem minmax(0, 1fr);
      gap: 0.9rem;
      align-items: start;
      border-radius: 22px;
      border: 1px solid rgba(215, 223, 219, 0.92);
      background: rgba(255, 255, 255, 0.92);
      padding: 1rem;
      box-shadow: 0 10px 24px rgba(16, 33, 50, 0.05);
    }

    .hub-module-icon,
    .workflow-step-icon,
    .output-icon {
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 16px;
    }

    .hub-module-title {
      margin-top: 0.75rem;
      font-size: 1rem;
      line-height: 1.35;
      font-weight: 700;
      color: var(--color-ink-deep);
    }

    .hub-module-card-mobile .hub-module-title { margin-top: 0.15rem; }

    .hub-module-note {
      margin-top: 0.35rem;
      font-size: 0.84rem;
      line-height: 1.65;
      color: var(--color-text-secondary);
    }

    .workflow-stack {
      position: relative;
      display: grid;
      gap: 1rem;
    }

    .workflow-rail {
      position: absolute;
      left: 1.35rem;
      top: 1rem;
      bottom: 2rem;
      width: 2px;
      background: linear-gradient(180deg, rgba(31, 107, 102, 0.15), rgba(31, 107, 102, 0.85));
      z-index: 0;
    }

    .workflow-rail::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: -0.15rem;
      width: 0.72rem;
      height: 0.72rem;
      border-right: 2px solid rgba(31, 107, 102, 0.75);
      border-bottom: 2px solid rgba(31, 107, 102, 0.75);
      transform: translateX(-50%) rotate(45deg);
    }

    .workflow-step {
      position: relative;
      display: grid;
      grid-template-columns: 3.6rem minmax(0, 1fr);
      gap: 1rem;
      align-items: start;
      border-radius: 24px;
      border: 1px solid rgba(215, 223, 219, 0.92);
      background: rgba(255, 255, 255, 0.96);
      padding: 1rem;
      box-shadow: 0 10px 24px rgba(16, 33, 50, 0.06);
      z-index: 1;
    }

    .workflow-step::after {
      content: "↓";
      position: absolute;
      bottom: -1.45rem;
