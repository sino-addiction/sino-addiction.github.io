---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { requirePage } from "../lib/content";

const page = await requirePage("collaboration");

const sourceCenters = ["站点1", "站点2", "站点3"] as const;
const processingSteps = ["脱敏", "质控", "标准化", "入库"] as const;
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Hero {...page.data.hero} compact={true} />

  <section class="page-wrap pb-20 md:pb-28">
    <SectionHeading eyebrow="Collaboration Map" title="多中心数据汇聚" center={true} />

    <div class="convergence-board mt-10 md:mt-12" aria-label="多中心数据汇聚示意图">
      <div class="board-section-copy board-section-copy-left">
        <span>参与中心</span>
        <p>完成本地伦理、授权、脱敏与数据准备。</p>
      </div>
      <div class="board-section-copy board-section-copy-center">
        <span>中心站点</span>
        <p>统一质控、标准映射、版本管理与入库。</p>
      </div>
      <div class="board-section-copy board-section-copy-right">
        <span>联盟数据库</span>
        <p>支持项目申请、数据分析与成果复用。</p>
      </div>

      <div class="site-cluster">
        {sourceCenters.map((center, index) => (
          <article class="site-card" style={`--delay:${index * 120}ms;`}>
            <div class="site-card-head">
              <span class="site-dot" aria-hidden="true"></span>
              <h3>{center}</h3>
            </div>
            <div class="modality-icons" aria-hidden="true">
              <div class="modality-icon">
                <svg viewBox="0 0 80 80">
                  <path d="M26 34c0-9 6-15 14-15s14 6 14 15" />
                  <path d="M27 33c4-5 22-5 26 0" />
                  <circle cx="40" cy="37" r="13" />
                  <path d="M28 50c5 6 19 6 24 0" />
                  <path d="M22 56c3-8 33-8 36 0" />
                  <circle cx="31" cy="26" r="2" />
                  <circle cx="40" cy="23" r="2" />
                  <circle cx="49" cy="26" r="2" />
                  <path d="M31 26 24 18" />
                  <path d="M40 23V14" />
                  <path d="M49 26 56 18" />
                  <path d="M24 34h-7v10" />
                  <path d="M56 34h7v10" />
                </svg>
                <strong>EEG</strong>
              </div>
              <div class="modality-icon">
                <svg viewBox="0 0 80 80">
                  <rect x="14" y="22" width="52" height="38" rx="10" />
                  <circle cx="39" cy="41" r="13" />
                  <circle cx="39" cy="41" r="5" />
                  <path d="M52 41h15" />
                  <path d="M24 60v7" />
                  <path d="M56 60v7" />
                  <path d="M20 67h40" />
                  <path d="M18 29h8" />
                </svg>
                <strong>fMRI</strong>
              </div>
            </div>
            <div class="packet-row" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </article>
        ))}
      </div>

      <div class="stream-lane stream-lane-in" aria-hidden="true">
        <span class="stream-packet"></span>
        <span class="stream-packet stream-packet-delay"></span>
      </div>

      <article class="hub-node">
        <div class="hub-mark" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <h3>中心站点</h3>
        <div class="processing-row">
          {processingSteps.map((step, index) => (
            <span style={`--delay:${index * 140}ms;`}>{step}</span>
          ))}
        </div>
      </article>

      <div class="stream-lane stream-lane-out" aria-hidden="true">
        <span class="stream-packet"></span>
        <span class="stream-packet stream-packet-delay"></span>
      </div>

      <div class="database-area">
        <article class="database-node">
          <div class="database-cylinder" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <h3>标准化数据库</h3>
          <div class="asset-row" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <style>
    .convergence-board {
      position: relative;
      display: grid;
      grid-template-columns: minmax(340px, 1.12fr) 78px minmax(220px, 0.64fr) 78px minmax(230px, 0.72fr);
      grid-template-rows: auto 1fr;
      row-gap: 1.45rem;
      align-items: center;
      min-height: 600px;
      overflow: hidden;
      border: 1px solid rgba(215, 223, 219, 0.96);
      border-radius: 24px;
      background:
        linear-gradient(90deg, rgba(31, 107, 102, 0.04) 1px, transparent 1px),
        linear-gradient(180deg, rgba(31, 107, 102, 0.035) 1px, transparent 1px),
        linear-gradient(180deg, rgba(252, 253, 252, 0.98), rgba(247, 249, 248, 0.96));
      background-size: 44px 44px, 44px 44px, auto;
      box-shadow: 0 22px 46px rgba(16, 33, 50, 0.07);
      padding: 1.35rem;
    }

    .board-section-copy {
      position: relative;
      z-index: 2;
      justify-self: center;
      max-width: 290px;
      text-align: center;
    }

    .board-section-copy span {
      display: inline-flex;
      min-height: 28px;
      align-items: center;
      border: 1px solid rgba(31, 107, 102, 0.14);
      border-radius: 9999px;
      background: rgba(227, 238, 234, 0.78);
      padding: 0 0.78rem;
      color: var(--color-accent);
      font-size: 0.76rem;
      font-weight: 760;
      letter-spacing: 0.04em;
    }

    .board-section-copy p {
      margin: 0.55rem 0 0;
      color: var(--color-text-secondary);
      font-size: 0.82rem;
      line-height: 1.55;
    }

    .board-section-copy-left {
      grid-column: 1;
      grid-row: 1;
    }

    .board-section-copy-center {
      grid-column: 3;
      grid-row: 1;
    }

    .board-section-copy-right {
      grid-column: 5;
      grid-row: 1;
    }

    .site-cluster {
      position: relative;
      z-index: 1;
      display: grid;
      grid-column: 1;
      grid-row: 2;
      gap: 0.9rem;
    }

    .site-card,
    .hub-node,
    .database-node {
      border: 1px solid rgba(215, 223, 219, 0.92);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 14px 28px rgba(16, 33, 50, 0.055);
    }

    .site-card {
      display: grid;
      gap: 0.75rem;
      min-height: 168px;
      padding: 0.95rem;
      animation: card-rise 620ms ease both;
      animation-delay: var(--delay, 0ms);
    }

    .site-card-head {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      min-height: 1.6rem;
    }

    .site-card h3 {
      margin: 0;
      color: var(--color-ink-deep);
      font-size: 1.06rem;
      font-weight: 760;
      line-height: 1.25;
    }

    .site-dot {
      width: 0.52rem;
      height: 0.52rem;
      flex: 0 0 auto;
      border-radius: 9999px;
      background: var(--color-accent);
      box-shadow: 0 0 0 4px rgba(31, 107, 102, 0.1);
    }

    .modality-icons {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.65rem;
    }

    .modality-icon {
      display: grid;
      min-height: 86px;
      justify-items: center;
      align-content: center;
      gap: 0.28rem;
      border: 1px solid rgba(215, 223, 219, 0.78);
      border-radius: 12px;
      background: rgba(247, 249, 248, 0.88);
      color: var(--color-accent);
      padding: 0.45rem;
    }

    .modality-icon svg {
      width: 3.35rem;
      height: 3.35rem;
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 2.25;
    }

    .modality-icon strong {
      color: var(--color-ink-deep);
      font-size: 0.76rem;
      font-weight: 740;
      line-height: 1;
    }

    .packet-row,
    .asset-row {
      display: flex;
      gap: 0.45rem;
      margin-top: 0.1rem;
    }

    .packet-row span,
    .asset-row span {
      height: 0.45rem;
      flex: 1;
      border-radius: 9999px;
      background: rgba(31, 107, 102, 0.16);
    }

    .stream-lane {
      position: relative;
      z-index: 0;
      grid-row: 2;
      min-height: 260px;
    }

    .stream-lane-in {
      grid-column: 2;
    }

    .stream-lane-out {
      grid-column: 4;
    }

    .stream-lane::before {
      content: "";
      position: absolute;
      left: 0.45rem;
      right: 0.45rem;
      top: 50%;
      height: 2px;
      border-radius: 9999px;
      background: linear-gradient(90deg, rgba(31, 107, 102, 0.14), rgba(31, 107, 102, 0.72));
      transform: translateY(-50%);
    }

    .stream-lane::after {
      content: "";
      position: absolute;
      right: 0.4rem;
      top: 50%;
      width: 0.62rem;
      height: 0.62rem;
      border-right: 2px solid rgba(31, 107, 102, 0.7);
      border-bottom: 2px solid rgba(31, 107, 102, 0.7);
      transform: translateY(-50%) rotate(-45deg);
    }

    .stream-packet {
      position: absolute;
      left: 0.55rem;
      top: calc(50% - 4px);
      width: 8px;
      height: 8px;
      border-radius: 9999px;
      background: var(--color-accent);
      box-shadow: 0 0 0 6px rgba(31, 107, 102, 0.12);
      animation: flow-pulse 2.9s ease-in-out infinite;
    }

    .stream-packet-delay {
      animation-delay: 1.25s;
    }

    .hub-node {
      position: relative;
      z-index: 1;
      grid-column: 3;
      grid-row: 2;
      width: min(100%, 240px);
      justify-self: center;
      padding: 1.35rem;
      text-align: center;
      animation: node-breathe 4.6s ease-in-out infinite;
    }

    .hub-mark {
      position: relative;
      width: 5.25rem;
      height: 5.25rem;
      margin: 0 auto;
      border-radius: 9999px;
      background: rgba(227, 238, 234, 0.74);
      box-shadow: inset 0 0 0 1px rgba(31, 107, 102, 0.16);
    }

    .hub-mark span {
      position: absolute;
      border-radius: 9999px;
      background: rgba(31, 107, 102, 0.72);
    }

    .hub-mark span:nth-child(1) {
      left: 50%;
      top: 50%;
      width: 1.05rem;
      height: 1.05rem;
      transform: translate(-50%, -50%);
    }

    .hub-mark span:nth-child(2) {
      left: 1.05rem;
      top: 1.15rem;
      width: 0.7rem;
      height: 0.7rem;
    }

    .hub-mark span:nth-child(3) {
      right: 1rem;
      bottom: 1.05rem;
      width: 0.7rem;
      height: 0.7rem;
    }

    .hub-node h3,
    .database-node h3 {
      margin: 1rem 0 0;
      color: var(--color-ink-deep);
      font-family: var(--font-serif);
      font-size: 1.65rem;
      font-weight: 760;
      line-height: 1.18;
    }

    .processing-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 1.1rem;
    }

    .processing-row span {
      border: 1px solid rgba(31, 107, 102, 0.14);
      border-radius: 9999px;
      background: rgba(227, 238, 234, 0.72);
      color: var(--color-accent);
      font-size: 0.78rem;
      font-weight: 700;
      line-height: 1;
      padding: 0.5rem 0.65rem;
      animation: chip-glow 3.2s ease-in-out infinite;
      animation-delay: var(--delay, 0ms);
    }

    .database-area {
      position: relative;
      z-index: 1;
      display: grid;
      grid-column: 5;
      grid-row: 2;
      align-self: center;
    }

    .database-node {
      width: min(100%, 250px);
      justify-self: center;
      padding: 1.35rem;
      text-align: center;
    }

    .database-cylinder {
      position: relative;
      width: 8.4rem;
      height: 4.6rem;
      margin: 0 auto 0.5rem;
    }

    .database-cylinder span {
      position: absolute;
      left: 50%;
      width: 7rem;
      height: 2rem;
      border: 1px solid rgba(16, 33, 50, 0.2);
      border-radius: 9999px;
      transform: translateX(-50%);
    }

    .database-cylinder span:nth-child(1) {
      top: 0;
      background: rgba(31, 107, 102, 0.12);
    }

    .database-cylinder span:nth-child(2) {
      top: 1.05rem;
      background: rgba(31, 107, 102, 0.09);
    }

    .database-cylinder span:nth-child(3) {
      top: 2.1rem;
      background: rgba(16, 33, 50, 0.08);
    }

    @keyframes flow-pulse {
      0% {
        opacity: 0;
        transform: translateX(0) scale(0.75);
      }

      18% {
        opacity: 1;
      }

      72% {
        opacity: 1;
      }

      100% {
        opacity: 0;
        transform: translateX(58px) scale(1);
      }
    }

    @keyframes node-breathe {
      0%,
      100% {
        box-shadow: 0 14px 28px rgba(16, 33, 50, 0.055);
      }

      50% {
        box-shadow: 0 20px 42px rgba(31, 107, 102, 0.14);
      }
    }

    @keyframes chip-glow {
      0%,
      100% {
        border-color: rgba(31, 107, 102, 0.14);
      }

      50% {
        border-color: rgba(31, 107, 102, 0.46);
      }
    }

    @keyframes card-rise {
      from {
        opacity: 0;
        transform: translateY(12px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 1120px) {
      .convergence-board {
        grid-template-columns: 1fr;
        gap: 1rem;
        min-height: auto;
        padding: 1rem;
      }

      .board-section-copy {
        position: static;
        width: auto;
        max-width: none;
        text-align: left;
        transform: none;
      }

      .board-section-copy,
      .site-cluster,
      .stream-lane,
      .hub-node,
      .database-area {
        grid-column: 1;
        grid-row: auto;
      }

      .board-section-copy-left {
        order: 1;
      }

      .site-cluster {
        order: 2;
      }

      .stream-lane-in {
        order: 3;
      }

      .board-section-copy-center {
        order: 4;
      }

      .hub-node {
        order: 5;
      }

      .stream-lane-out {
        order: 6;
      }

      .board-section-copy-right {
        order: 7;
      }

      .database-area {
        order: 8;
      }

      .stream-lane {
        min-height: 52px;
      }

      .stream-lane::before {
        left: 50%;
        right: auto;
        top: 0.3rem;
        bottom: 0.3rem;
        width: 2px;
        height: auto;
        background: linear-gradient(180deg, rgba(31, 107, 102, 0.14), rgba(31, 107, 102, 0.72));
        transform: translateX(-50%);
      }

      .stream-lane::after {
        left: 50%;
        right: auto;
        top: auto;
        bottom: 0.25rem;
        transform: translateX(-50%) rotate(45deg);
      }

      .stream-packet {
        left: calc(50% - 4px);
        top: 0.45rem;
        animation-name: flow-pulse-mobile;
      }
    }

    @media (max-width: 720px) {
      .convergence-board {
        border-radius: 18px;
      }

      .site-card,
      .hub-node,
      .database-node {
        border-radius: 14px;
      }

    }

    @keyframes flow-pulse-mobile {
      0% {
        opacity: 0;
        transform: translateY(0) scale(0.75);
      }

      18% {
        opacity: 1;
      }

      72% {
        opacity: 1;
      }

      100% {
        opacity: 0;
        transform: translateY(40px) scale(1);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .site-card,
      .hub-node,
      .stream-packet,
      .processing-row span {
        animation: none !important;
      }
    }
  </style>
</BaseLayout>
