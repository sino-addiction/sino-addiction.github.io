---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProcessIcon from "../components/ProcessIcon.astro";
import SectionHeading from "../components/SectionHeading.astro";

type FlowStep = {
  title: string;
  description: string;
  icon: "upload" | "check" | "share" | "database" | "play";
  direction: "left" | "right";
};

const flowSteps: FlowStep[] = [
  {
    title: "提交研究计划",
    description:
      "参与站点提交研究计划与基础信息，明确研究目标、样本范围、执行条件和协作边界。",
    icon: "upload",
    direction: "left",
  },
  {
    title: "可行性评估与反馈",
    description:
      "中心站点评估方案匹配度、资源条件与实施风险，并给出修改建议或确认反馈。",
    icon: "check",
    direction: "right",
  },
  {
    title: "研究计划分发",
    description:
      "根据评估结果将确认后的研究计划分发到相关站点，完成协作确认与同步。",
    icon: "share",
    direction: "left",
  },
  {
    title: "数据准备",
    description:
      "围绕采集规范、字段映射和上传规则完成数据配置、校验与准备工作。",
    icon: "database",
    direction: "right",
  },
  {
    title: "项目启动",
    description:
      "项目正式进入执行阶段，开始后续协同、研究实施与持续沟通。",
    icon: "play",
    direction: "left",
  },
];
---

<BaseLayout
  title="项目管理 - SANI"
  description="展示研究计划从提交到项目启动的标准化流程，以及当前在研项目的横向卡片展示位。"
>
  <Hero
    title="项目管理"
    subtitle="围绕研究计划的提交、评估、分发、数据准备和项目启动，统一展示标准化协作流程。"
    compact={true}
    primaryCta={{ label: "项目申请流程", href: "#project-flow" }}
    secondaryCta={{ label: "浏览当前项目", href: "#current-projects" }}
  />

  <section id="project-flow" class="page-wrap py-20 md:py-32 scroll-mt-24">
    <SectionHeading eyebrow="Workflow" title="项目申请流程" center={true} />

    <div class="relative mx-auto mt-16 max-w-6xl md:mt-20">
      <div class="flow-axis hidden md:block" aria-hidden="true"></div>
      <div class="flow-axis-mobile md:hidden" aria-hidden="true"></div>

      <div class="space-y-6 md:space-y-10">
        {flowSteps.map((step, index) => (
          <div class="group" data-reveal style={`--reveal-delay:${index * 120}ms;`}>
            <div class="relative pl-14 md:hidden">
              <div class="flow-node flow-node--compact absolute left-0 top-4 transition-transform duration-300 group-hover:scale-105">
                <span class="flow-node-ring"></span>
                <span class="flow-node-core">
                  <ProcessIcon name={step.icon} class="h-4 w-4" />
                </span>
              </div>

              <article class="flow-card">
                <h3 class="text-h3 text-[24px] leading-[1.2] md:text-[28px]">
                  {step.title}
                </h3>
                <p class="mt-4 text-[15px] leading-[1.85] text-text-secondary md:text-[16px]">
                  {step.description}
                </p>
              </article>
            </div>

            <div class="hidden md:grid md:grid-cols-[minmax(0,1fr)_96px_minmax(0,1fr)] md:items-center md:gap-6">
              {step.direction === "left" ? (
                <>
                  <article class="flow-card md:justify-self-end">
                    <h3 class="text-h3 text-[24px] leading-[1.18]">
                      {step.title}
                    </h3>
                    <p class="mt-4 text-[16px] leading-[1.85] text-text-secondary">
                      {step.description}
                    </p>
                  </article>

                  <div class="flow-node hidden md:flex transition-transform duration-300 group-hover:scale-105" aria-hidden="true">
                    <span class="flow-node-ring"></span>
                    <span class="flow-node-core">
                      <ProcessIcon name={step.icon} class="h-5 w-5" />
                    </span>
                  </div>

                  <div aria-hidden="true"></div>
                </>
              ) : (
                <>
                  <div aria-hidden="true"></div>

                  <div class="flow-node hidden md:flex transition-transform duration-300 group-hover:scale-105" aria-hidden="true">
                    <span class="flow-node-ring"></span>
                    <span class="flow-node-core">
                      <ProcessIcon name={step.icon} class="h-5 w-5" />
                    </span>
                  </div>

                  <article class="flow-card md:justify-self-start">
                    <h3 class="text-h3 text-[24px] leading-[1.18]">
                      {step.title}
                    </h3>
                    <p class="mt-4 text-[16px] leading-[1.85] text-text-secondary">
                      {step.description}
                    </p>
                  </article>
                </>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="current-projects" class="bg-surface-alt/40 py-24 md:py-32 scroll-mt-24">
    <div class="page-wrap">
      <SectionHeading eyebrow="Projects" title="当前在研项目" center={true} />

      <div class="project-strip mt-16 overflow-x-auto pb-4 md:mt-20">
        <div class="flex min-w-max gap-6 pr-2">
          <article class="project-placeholder group relative w-[min(100%,720px)] shrink-0 overflow-hidden rounded-[32px] border border-border/80 bg-[rgba(252,253,252,0.9)] p-6 shadow-[0_18px_42px_rgba(16,33,50,0.06)] transition-all duration-300 hover:-translate-y-1 hover:border-accent/25 hover:shadow-[0_24px_56px_rgba(16,33,50,0.1)] md:p-7">
            <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(31,107,102,0.12),transparent_52%)]"></div>
            <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(135deg,rgba(31,107,102,0.08),transparent_36%,rgba(255,255,255,0.4))] opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>

            <div class="relative grid gap-6 md:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] md:items-end">
              <div>
                <span class="inline-flex items-center rounded-full bg-accent-soft px-3 py-1 text-[12px] font-semibold text-accent">
                  Placeholder
                </span>
                <h3 class="mt-4 text-[28px] font-serif font-bold text-ink-deep md:text-[34px]">
                  在研项目横向卡片位
                </h3>
                <p class="mt-4 max-w-xl text-[16px] leading-[1.85] text-text-secondary md:text-[17px]">
                  后续在研项目将以横向卡片流展示，单卡固定宽度，适合桌面端浏览与移动端横滑。
                </p>
              </div>

              <div class="rounded-[28px] border border-dashed border-accent/25 bg-accent-soft/35 p-5">
                <div class="space-y-3">
                  <div class="h-3 w-28 rounded-full bg-accent/20"></div>
                  <div class="h-3 w-full rounded-full bg-accent/12"></div>
                  <div class="h-3 w-5/6 rounded-full bg-accent/10"></div>
                </div>

                <div class="mt-5 grid grid-cols-3 gap-3">
                  <div class="h-24 rounded-3xl bg-white/70"></div>
                  <div class="h-[72px] rounded-3xl bg-white/55"></div>
                  <div class="h-28 rounded-3xl bg-white/80"></div>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const revealNodes = document.querySelectorAll("[data-reveal]");

      if (!("IntersectionObserver" in window)) {
        revealNodes.forEach((node) => node.classList.add("is-visible"));
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.18,
          rootMargin: "0px 0px -8% 0px",
        },
      );

      revealNodes.forEach((node) => observer.observe(node));
    })();
  </script>

  <style>
    .flow-axis {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 2px;
      transform: translateX(-50%);
      background: linear-gradient(
        180deg,
        rgba(31, 107, 102, 0.05) 0%,
        rgba(31, 107, 102, 0.35) 50%,
        rgba(31, 107, 102, 0.05) 100%
      );
      box-shadow: 0 0 30px rgba(31, 107, 102, 0.15);
    }

    .flow-axis::after {
      content: "";
      position: absolute;
      left: 50%;
      top: -14%;
      width: 16px;
      height: 28%;
      transform: translateX(-50%);
      background: linear-gradient(
        180deg,
        transparent 0%,
        rgba(31, 107, 102, 0.28) 45%,
        rgba(31, 107, 102, 0.12) 70%,
        transparent 100%
      );
      filter: blur(8px);
      animation: axis-glide 7.5s ease-in-out infinite;
    }

    .flow-axis-mobile {
      position: absolute;
      left: 17px;
      top: 0;
      bottom: 0;
      width: 2px;
      pointer-events: none;
      background: linear-gradient(
        180deg,
        rgba(31, 107, 102, 0.05) 0%,
        rgba(31, 107, 102, 0.32) 50%,
        rgba(31, 107, 102, 0.05) 100%
      );
    }

    .flow-axis-mobile::after {
      content: "";
      position: absolute;
      left: 50%;
      top: 0;
      width: 10px;
      height: 26%;
      transform: translateX(-50%);
      background: linear-gradient(180deg, transparent, rgba(31, 107, 102, 0.25), transparent);
      filter: blur(6px);
      animation: axis-glide 7.5s ease-in-out infinite;
    }

    .flow-node {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 74px;
      height: 74px;
      z-index: 1;
    }

    .flow-node--compact {
      width: 44px;
      height: 44px;
    }

    .flow-node-ring {
      position: absolute;
      inset: 0;
      border-radius: 9999px;
      border: 1px solid rgba(31, 107, 102, 0.16);
      background: radial-gradient(
        circle at 30% 30%,
        rgba(31, 107, 102, 0.12),
        rgba(31, 107, 102, 0.02) 58%,
        rgba(255, 255, 255, 0.88) 100%
      );
      box-shadow:
        0 0 0 12px rgba(31, 107, 102, 0.03),
        0 0 28px rgba(31, 107, 102, 0.16);
    }

    .flow-node-core {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      border-radius: 9999px;
      background: linear-gradient(135deg, rgba(16, 33, 50, 0.96), rgba(31, 107, 102, 0.92));
      color: white;
      box-shadow: 0 12px 24px rgba(16, 33, 50, 0.18);
    }

    .flow-node--compact .flow-node-core {
      width: 30px;
      height: 30px;
    }

    .flow-node-core svg {
      width: 22px;
      height: 22px;
    }

    .flow-node--compact .flow-node-core svg {
      width: 14px;
      height: 14px;
    }

    .flow-card {
      position: relative;
      overflow: hidden;
      border-radius: 30px;
      border: 1px solid rgba(215, 223, 219, 0.82);
      background: rgba(252, 253, 252, 0.9);
      padding: 1.5rem;
      box-shadow: 0 16px 40px rgba(16, 33, 50, 0.06);
      transition:
        transform 300ms ease,
        border-color 300ms ease,
        box-shadow 300ms ease;
    }

    .flow-card::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(135deg, rgba(31, 107, 102, 0.08), transparent 38%, rgba(255, 255, 255, 0.35));
      opacity: 0;
      transition: opacity 300ms ease;
    }

    .flow-card:hover {
      transform: translateY(-4px);
      border-color: rgba(31, 107, 102, 0.25);
      box-shadow: 0 24px 56px rgba(16, 33, 50, 0.1);
    }

    .flow-card:hover::before {
      opacity: 1;
    }

    .project-strip {
      scroll-snap-type: x proximity;
      scrollbar-width: thin;
      scrollbar-color: rgba(31, 107, 102, 0.35) transparent;
    }

    .project-strip::-webkit-scrollbar {
      height: 10px;
    }

    .project-strip::-webkit-scrollbar-track {
      background: transparent;
    }

    .project-strip::-webkit-scrollbar-thumb {
      border-radius: 9999px;
      background: linear-gradient(90deg, rgba(31, 107, 102, 0.18), rgba(31, 107, 102, 0.42));
    }

    [data-reveal] {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 700ms cubic-bezier(0.2, 0.75, 0.2, 1),
        transform 700ms cubic-bezier(0.2, 0.75, 0.2, 1);
      transition-delay: var(--reveal-delay, 0ms);
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes axis-glide {
      0%,
      100% {
        transform: translateX(-50%) translateY(-10%);
        opacity: 0;
      }

      15% {
        opacity: 1;
      }

      50% {
        opacity: 1;
      }

      85% {
        opacity: 1;
      }

      100% {
        transform: translateX(-50%) translateY(170%);
        opacity: 0;
      }
    }

    @media (max-width: 1023px) {
      .flow-card {
        padding: 1.25rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .flow-axis::after,
      .flow-axis-mobile::after {
        animation: none !important;
      }

      [data-reveal] {
        opacity: 1;
        transform: none;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</BaseLayout>
