---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProcessIcon from "../components/ProcessIcon.astro";
import ProjectFlowCard from "../components/ProjectFlowCard.astro";
import { requirePage } from "../lib/content";

const page = await requirePage("projects");
const stepIcons = ["upload", "check", "share", "database", "play"] as const;

type FlowStep = {
  title: string;
  description: string;
  icon: (typeof stepIcons)[number];
  direction: "left" | "right";
};

const flowSteps: FlowStep[] = (page.data.steps ?? []).slice(0, 5).map((step, index) => ({
  title: step.title,
  description: step.description,
  icon: stepIcons[index] ?? "play",
  direction: index % 2 === 0 ? "left" : "right",
}));

const hero = page.data.hero;
const primaryCta = hero.primaryCta ?? { label: "项目申请流程", href: "#project-flow" };
const secondaryCta = hero.secondaryCta ?? { label: "浏览当前项目", href: "#current-projects" };
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="projects-hero">
    <div class="page-wrap relative z-10 pt-16 pb-14 md:pt-24 md:pb-20">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-center">
        <div class="max-w-3xl" data-reveal style="--reveal-delay:0ms;">
          {hero.kicker && (
            <span class="inline-flex items-center rounded-full border border-accent/15 bg-accent-soft px-3 py-1 text-[12px] font-semibold tracking-[0.16em] text-accent">
              {hero.kicker}
            </span>
          )}

          <h1 class="mt-6 font-serif text-[44px] font-bold leading-[1.08] text-ink-deep text-balance md:text-[60px]">
            {hero.title}
          </h1>

          <p class="mt-6 max-w-2xl text-[17px] leading-[1.8] text-text-secondary text-balance md:text-[19px]">
            {hero.subtitle}
          </p>

          <div class="mt-10 flex flex-wrap gap-4">
            <a href={primaryCta.href} class="btn-primary px-7 shadow-[0_14px_30px_rgba(31,107,102,0.18)]">
              {primaryCta.label}
            </a>
            <a href={secondaryCta.href} class="btn-secondary px-7">
              {secondaryCta.label}
            </a>
          </div>
        </div>

        <div class="relative" data-reveal style="--reveal-delay:120ms;">
          <div class="projects-hero-panel relative overflow-hidden rounded-[34px] border border-white/70 bg-[rgba(252,253,252,0.82)] p-6 shadow-[0_18px_50px_rgba(16,33,50,0.08)] backdrop-blur-md md:p-8">
            <div class="pointer-events-none absolute -right-12 -top-12 h-44 w-44 rounded-full bg-accent/10 blur-3xl"></div>
            <div class="pointer-events-none absolute left-4 bottom-4 h-28 w-28 rounded-full bg-ink-deep/5 blur-2xl"></div>

            <div class="relative">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <span class="text-[12px] font-semibold uppercase tracking-[0.18em] text-text-muted">
                    流程预览
                  </span>
                  <h2 class="mt-4 text-[22px] font-serif font-bold text-ink-deep md:text-[26px]">
                    从提交到启动
                  </h2>
                </div>

                <div class="flex h-14 w-14 items-center justify-center rounded-full border border-accent/15 bg-accent-soft text-accent shadow-sm">
                  <ProcessIcon name="share" class="h-6 w-6" />
                </div>
              </div>

              <div class="mt-8 space-y-4">
                {flowSteps.map((step, index) => (
                  <div
                    class="group flex items-center gap-4 rounded-[22px] border border-border/70 bg-[rgba(252,253,252,0.72)] p-3 shadow-[0_10px_26px_rgba(16,33,50,0.04)] backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-accent/20"
                    data-reveal
                    style={`--reveal-delay:${180 + index * 70}ms;`}
                  >
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-border bg-surface text-accent shadow-sm">
                      <ProcessIcon name={step.icon} class="h-4 w-4" />
                    </div>

                    <div class="min-w-0 flex-1">
                      <div class="flex items-center justify-between gap-3">
                        <span class="truncate text-[14px] font-semibold text-ink-deep">
                          {step.title}
                        </span>
                        <span class="text-[12px] font-medium tabular-nums text-text-muted">
                          {String(index + 1).padStart(2, "0")}
                        </span>
                      </div>
                      <div class="hero-step-bar mt-2 h-2 overflow-hidden rounded-full bg-[rgba(215,223,219,0.55)]">
                        <span
                          class="block h-full rounded-full"
                          style={`width:${((index + 1) / flowSteps.length) * 100}%`}
                        ></span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              <div class="mt-8 rounded-[24px] border border-border/70 bg-surface/85 p-5">
                <p class="text-[14px] leading-[1.75] text-text-secondary">
                  页面按照“先总览、再解释、再浏览”的节奏组织信息，适合快速理解协作路径。
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="project-flow" class="page-wrap section-shell scroll-mt-24">
    <div class="mb-10 md:mb-12">
      <h2 class="text-h2">项目申请流程</h2>
    </div>

    <div class="relative mx-auto max-w-6xl">
      <div class="flow-axis hidden md:block" aria-hidden="true"></div>
      <div class="flow-axis-mobile md:hidden" aria-hidden="true"></div>

      <div class="space-y-6 md:space-y-8">
        {flowSteps.map((step, index) => (
          <div data-reveal style={`--reveal-delay:${index * 120}ms;`} class="group">
            <div class="relative pl-11 md:hidden">
              <div class="flow-node flow-node--compact absolute left-0 top-5 md:hidden transition-transform duration-300 group-hover:scale-105">
                <span class="flow-node-ring"></span>
                <span class="flow-node-core">
                  <ProcessIcon name={step.icon} class="h-4 w-4" />
                </span>
              </div>

              <ProjectFlowCard
                index={index}
                title={step.title}
                description={step.description}
                class="w-full"
              />
            </div>

            <div class="hidden items-center gap-6 md:grid md:grid-cols-[minmax(0,1fr)_96px_minmax(0,1fr)] md:items-center">
              {step.direction === "left" ? (
                <>
                  <ProjectFlowCard
                    index={index}
                    title={step.title}
                    description={step.description}
                    class="w-full max-w-[560px] justify-self-end"
                  />
                  <div class="flow-node hidden md:flex transition-transform duration-300 group-hover:scale-105" aria-hidden="true">
                    <span class="flow-node-ring"></span>
                    <span class="flow-node-core">
                      <ProcessIcon name={step.icon} class="h-5 w-5" />
                    </span>
                  </div>
                  <div aria-hidden="true"></div>
                </>
              ) : (
                <>
                  <div aria-hidden="true"></div>
                  <div class="flow-node hidden md:flex transition-transform duration-300 group-hover:scale-105" aria-hidden="true">
                    <span class="flow-node-ring"></span>
                    <span class="flow-node-core">
                      <ProcessIcon name={step.icon} class="h-5 w-5" />
                    </span>
                  </div>
                  <ProjectFlowCard
                    index={index}
                    title={step.title}
                    description={step.description}
                    class="w-full max-w-[560px] justify-self-start"
                  />
                </>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="current-projects" class="page-wrap section-shell scroll-mt-24 pt-0">
    <div class="border-t border-border pt-12 md:pt-16">
      <div class="mb-8 md:mb-10">
        <h2 class="text-h2">当前在研项目</h2>
      </div>

      <div class="project-strip overflow-x-auto pb-4">
        <div class="flex min-w-max gap-6 pr-2">
          <article class="group relative w-full shrink-0 overflow-hidden rounded-[32px] border border-border/80 bg-[rgba(252,253,252,0.88)] p-6 shadow-[0_18px_42px_rgba(16,33,50,0.06)] transition-transform duration-300 hover:-translate-y-1 md:w-[380px] md:p-7 lg:w-[400px]">
            <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(31,107,102,0.10),transparent_56%)]"></div>
            <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(135deg,rgba(31,107,102,0.06),transparent_35%,rgba(255,255,255,0.4))] opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>

            <div class="relative flex h-full flex-col justify-between gap-6">
              <div>
                <span class="inline-flex items-center rounded-full bg-accent-soft px-3 py-1 text-[12px] font-semibold text-accent">
                  Placeholder
                </span>
                <h3 class="mt-4 text-[24px] font-serif font-bold text-ink-deep md:text-[28px]">
                  在研项目横向卡片位
                </h3>
                <p class="mt-4 text-[16px] leading-[1.8] text-text-secondary">
                  这里后续将用于展示在研项目的横向卡片流。每张卡可包含项目名称、摘要、合作站点和阶段说明。
                </p>
              </div>

              <div class="rounded-[24px] border border-dashed border-accent/25 bg-accent-soft/40 p-5">
                <div class="space-y-3">
                  <div class="h-3 w-24 rounded-full bg-accent/18"></div>
                  <div class="h-3 w-full rounded-full bg-accent/12"></div>
                  <div class="h-3 w-5/6 rounded-full bg-accent/10"></div>
                  <div class="mt-4 grid grid-cols-2 gap-3">
                    <div class="h-12 rounded-2xl bg-white/70"></div>
                    <div class="h-12 rounded-2xl bg-white/70"></div>
                  </div>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const revealNodes = document.querySelectorAll("[data-reveal]");

      if (!("IntersectionObserver" in window)) {
        revealNodes.forEach((node) => node.classList.add("is-visible"));
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.18,
          rootMargin: "0px 0px -8% 0px",
        },
      );

      revealNodes.forEach((node) => observer.observe(node));
    })();
  </script>

  <style>
    .projects-hero {
      position: relative;
      overflow: hidden;
      border-bottom: 1px solid var(--color-border);
      background:
        linear-gradient(180deg, rgba(243, 245, 244, 0.96) 0%, rgba(252, 253, 252, 0.88) 100%);
    }

    .projects-hero::before {
      content: "";
      position: absolute;
      inset: -10% -10% auto;
      height: 420px;
      pointer-events: none;
      background:
        radial-gradient(circle at 20% 20%, rgba(31, 107, 102, 0.16), transparent 48%),
        radial-gradient(circle at 82% 18%, rgba(16, 33, 50, 0.1), transparent 36%);
    }

    .projects-hero::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.55;
      background-image:
        linear-gradient(rgba(16, 33, 50, 0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(16, 33, 50, 0.025) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.3), transparent 70%);
    }

    .projects-hero-panel::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(circle at top, rgba(31, 107, 102, 0.1), transparent 56%);
    }

    .flow-axis {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 2px;
      transform: translateX(-50%);
      background: linear-gradient(
        180deg,
        rgba(31, 107, 102, 0.05) 0%,
        rgba(31, 107, 102, 0.35) 50%,
        rgba(31, 107, 102, 0.05) 100%
      );
      box-shadow: 0 0 30px rgba(31, 107, 102, 0.15);
    }

    .flow-axis::after {
      content: "";
      position: absolute;
      left: 50%;
      top: -14%;
      width: 16px;
      height: 28%;
      transform: translateX(-50%);
      background: linear-gradient(
        180deg,
        transparent 0%,
        rgba(31, 107, 102, 0.28) 45%,
        rgba(31, 107, 102, 0.12) 70%,
        transparent 100%
      );
      filter: blur(8px);
      animation: axis-glide 7.5s ease-in-out infinite;
    }

    .flow-axis-mobile {
      position: absolute;
      left: 17px;
      top: 0;
      bottom: 0;
      width: 2px;
      pointer-events: none;
      background: linear-gradient(
        180deg,
        rgba(31, 107, 102, 0.05) 0%,
        rgba(31, 107, 102, 0.32) 50%,
        rgba(31, 107, 102, 0.05) 100%
      );
    }

    .flow-axis-mobile::after {
      content: "";
      position: absolute;
      left: 50%;
      top: 0;
      width: 10px;
      height: 26%;
      transform: translateX(-50%);
      background: linear-gradient(180deg, transparent, rgba(31, 107, 102, 0.25), transparent);
      filter: blur(6px);
      animation: axis-glide 7.5s ease-in-out infinite;
    }

    .flow-node {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 74px;
      height: 74px;
      z-index: 1;
    }

    .flow-node--compact {
      width: 44px;
      height: 44px;
    }

    .flow-node-ring {
      position: absolute;
      inset: 0;
      border-radius: 9999px;
      border: 1px solid rgba(31, 107, 102, 0.16);
      background: radial-gradient(
        circle at 30% 30%,
        rgba(31, 107, 102, 0.12),
        rgba(31, 107, 102, 0.02) 58%,
        rgba(255, 255, 255, 0.88) 100%
      );
      box-shadow:
        0 0 0 12px rgba(31, 107, 102, 0.03),
        0 0 28px rgba(31, 107, 102, 0.16);
    }

    .flow-node-core {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      border-radius: 9999px;
      background: linear-gradient(135deg, rgba(16, 33, 50, 0.96), rgba(31, 107, 102, 0.92));
      color: white;
      box-shadow: 0 12px 24px rgba(16, 33, 50, 0.18);
    }

    .flow-node--compact .flow-node-core {
      width: 30px;
      height: 30px;
    }

    .flow-node-core svg {
      width: 22px;
      height: 22px;
    }

    .flow-node--compact .flow-node-core svg {
      width: 14px;
      height: 14px;
    }

    .hero-step-bar > span {
      position: relative;
      background: linear-gradient(90deg, rgba(31, 107, 102, 0.45), rgba(31, 107, 102, 0.96));
      box-shadow: 0 0 18px rgba(31, 107, 102, 0.18);
    }

    .hero-step-bar > span::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.55), transparent);
      transform: translateX(-100%);
      animation: bar-shine 3.8s ease-in-out infinite;
    }

    .project-strip {
      scroll-snap-type: x proximity;
      scrollbar-width: thin;
      scrollbar-color: rgba(31, 107, 102, 0.35) transparent;
    }

    .project-strip::-webkit-scrollbar {
      height: 10px;
    }

    .project-strip::-webkit-scrollbar-track {
      background: transparent;
    }

    .project-strip::-webkit-scrollbar-thumb {
      border-radius: 9999px;
      background: linear-gradient(90deg, rgba(31, 107, 102, 0.18), rgba(31, 107, 102, 0.42));
    }

    [data-reveal] {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 700ms cubic-bezier(0.2, 0.75, 0.2, 1),
        transform 700ms cubic-bezier(0.2, 0.75, 0.2, 1);
      transition-delay: var(--reveal-delay, 0ms);
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes axis-glide {
      0%,
      100% {
        transform: translateX(-50%) translateY(-10%);
        opacity: 0;
      }

      15% {
        opacity: 1;
      }

      50% {
        opacity: 1;
      }

      85% {
        opacity: 1;
      }

      100% {
        transform: translateX(-50%) translateY(170%);
        opacity: 0;
      }
    }

    @keyframes bar-shine {
      0% {
        transform: translateX(-100%);
      }

      55% {
        transform: translateX(120%);
      }

      100% {
        transform: translateX(120%);
      }
    }

    @media (max-width: 1023px) {
      .projects-hero {
        background:
          linear-gradient(180deg, rgba(243, 245, 244, 0.98) 0%, rgba(252, 253, 252, 0.92) 100%);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .projects-hero::before,
      .projects-hero::after,
      .flow-axis::after,
      .flow-axis-mobile::after,
      .hero-step-bar > span::after {
        animation: none !important;
      }

      [data-reveal] {
        opacity: 1;
        transform: none;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</BaseLayout>
