---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProcessIcon from "../components/ProcessIcon.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { downloadEntries } from "../data/downloads";

type FlowStep = {
  title: string;
  description: string;
  icon: "upload" | "check" | "share" | "database" | "play";
  direction: "left" | "right";
};

const flowSteps: FlowStep[] = [
  {
    title: "提交研究计划",
    description:
      "参与站点提交研究计划与基础信息，明确研究目标、样本范围、执行条件和协作边界。",
    icon: "upload",
    direction: "left",
  },
  {
    title: "可行性评估与反馈",
    description:
      "中心站点评估方案匹配度、资源条件与实施风险，并给出修改建议或确认反馈。",
    icon: "check",
    direction: "right",
  },
  {
    title: "研究计划分发",
    description:
      "根据评估结果将确认后的研究计划分发到相关站点，完成协作确认与同步。",
    icon: "share",
    direction: "left",
  },
  {
    title: "数据准备",
    description:
      "围绕采集规范、字段映射和上传规则完成数据配置、校验与准备工作。",
    icon: "database",
    direction: "right",
  },
  {
    title: "项目启动",
    description:
      "项目正式进入执行阶段，开始后续协同、研究实施与持续沟通。",
    icon: "play",
    direction: "left",
  },
];

const flowCardClass =
  "surface-card flex h-full flex-col border-t-4 border-t-accent transition-shadow hover:shadow-md";
const projectCardClass =
  "surface-card overflow-hidden border-t-4 border-t-accent transition-shadow hover:shadow-md";
const researchPlanDownload = downloadEntries[0];
const flowStepNumberClass =
  "inline-flex h-9 min-w-9 items-center justify-center rounded-full bg-ink-deep px-3 text-[13px] font-semibold tracking-[0.08em] text-white shadow-sm tabular-nums";
---

<BaseLayout
  title="项目管理 - SANI"
  description="展示研究计划从提交到项目启动的标准化流程，以及当前在研项目的横向卡片展示位。"
>
  <Hero
    title="项目管理"
    subtitle="围绕研究计划的提交、评估、分发、数据准备和项目启动，统一展示标准化协作流程。"
    compact={true}
    primaryCta={{ label: "项目申请流程", href: "#project-flow" }}
    secondaryCta={{ label: "浏览当前项目", href: "#current-projects" }}
  />

  <section id="project-flow" class="page-wrap py-20 md:py-32 scroll-mt-24">
    <SectionHeading eyebrow="Workflow" title="项目申请流程" center={true} />

    <div class="mt-8 flex justify-center md:mt-10">
      <a
        href={researchPlanDownload?.href ?? "#"}
        download={researchPlanDownload?.filename}
        class="inline-flex min-w-[240px] h-[64px] items-center justify-center rounded-full bg-accent px-10 text-[16px] font-semibold text-white shadow-[0_16px_34px_rgba(31,107,102,0.22)] transition hover:bg-accent-hover hover:shadow-[0_18px_38px_rgba(31,107,102,0.26)] md:h-[70px] md:px-12 md:text-[17px]"
      >
        下载研究计划
      </a>
    </div>

    <div class="relative mx-auto mt-10 max-w-6xl md:mt-12" data-flow-timeline>
      <div class="flow-axis" aria-hidden="true"></div>

      <div class="space-y-[19px] md:space-y-8">
        {flowSteps.map((step, index) => (
          <div data-reveal style={`--reveal-delay:${index * 120}ms;`}>
            <div class="relative pl-14 md:hidden">
              <div class="flow-node flow-node--compact absolute left-0 top-4" data-flow-node>
                <span class="flow-node-ring"></span>
                <span class="flow-node-core">
                  <ProcessIcon name={step.icon} class="h-4 w-4" />
                </span>
              </div>

              <article class={flowCardClass}>
                <h3 class="flex items-start gap-3 text-[24px] leading-[1.18] font-bold text-ink-deep md:text-[28px]">
                  <span class={flowStepNumberClass}>
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span class="flex-1 pt-1">
                    {step.title}
                  </span>
                </h3>
                <p class="mt-4 text-[15px] leading-[1.85] text-text-secondary md:text-[16px]">
                  {step.description}
                </p>
              </article>
            </div>

            <div class="hidden md:grid md:grid-cols-[minmax(0,1fr)_88px_minmax(0,1fr)] md:items-center md:gap-6">
              {step.direction === "left" ? (
                <>
                  <article class={`${flowCardClass} md:justify-self-end`}>
                    <h3 class="flex items-start gap-3 text-[24px] leading-[1.18] font-bold text-ink-deep">
                      <span class={flowStepNumberClass}>
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      <span class="flex-1 pt-1">
                        {step.title}
                      </span>
                    </h3>
                    <p class="mt-4 text-[16px] leading-[1.85] text-text-secondary">
                      {step.description}
                    </p>
                  </article>

                  <div class="flow-node hidden md:flex md:justify-self-center" aria-hidden="true" data-flow-node>
                    <span class="flow-node-ring"></span>
                    <span class="flow-node-core">
                      <ProcessIcon name={step.icon} class="h-5 w-5" />
                    </span>
                  </div>

                  <div aria-hidden="true"></div>
                </>
              ) : (
                <>
                  <div aria-hidden="true"></div>

                  <div class="flow-node hidden md:flex md:justify-self-center" aria-hidden="true" data-flow-node>
                    <span class="flow-node-ring"></span>
                    <span class="flow-node-core">
                      <ProcessIcon name={step.icon} class="h-5 w-5" />
                    </span>
                  </div>

                  <article class={`${flowCardClass} md:justify-self-start`}>
                    <h3 class="flex items-start gap-3 text-[24px] leading-[1.18] font-bold text-ink-deep">
                      <span class={flowStepNumberClass}>
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      <span class="flex-1 pt-1">
                        {step.title}
                      </span>
                    </h3>
                    <p class="mt-4 text-[16px] leading-[1.85] text-text-secondary">
                      {step.description}
                    </p>
                  </article>
                </>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="current-projects" class="bg-surface-alt/40 py-24 md:py-32 scroll-mt-24">
    <div class="page-wrap">
      <SectionHeading eyebrow="Projects" title="当前在研项目" center={true} />

      <article class={`${projectCardClass} mt-16 md:mt-20`}>
        <div class="grid gap-8 p-8 md:p-10 lg:grid-cols-[minmax(0,1.25fr)_minmax(280px,0.75fr)] lg:items-start lg:gap-10">
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-3">
              <span class="inline-flex items-center rounded-full bg-accent-soft px-3 py-1 text-[12px] font-semibold text-accent">
                数据库建设
              </span>
              <span class="inline-flex items-center rounded-full border border-border/70 bg-white px-3 py-1 text-[12px] font-semibold text-text-secondary">
                结构像
              </span>
              <span class="inline-flex items-center rounded-full border border-border/70 bg-white px-3 py-1 text-[12px] font-semibold text-text-secondary">
                甲基苯丙胺
              </span>
            </div>

            <h3 class="mt-5 max-w-4xl text-[28px] font-serif font-bold leading-[1.18] text-ink-deep md:text-[36px]">
              基于多中心队列的甲基苯丙胺成瘾神经影像数据库建设
            </h3>

            <p class="mt-4 max-w-3xl text-[15px] leading-[1.9] text-text-secondary md:text-[16px]">
              本项目围绕甲基苯丙胺成瘾相关结构像资料，依托多中心协作场景统一采集规范、命名方式、脱敏流程和质量控制标准，逐步完成影像数据整理、元数据编目与标准化入库，建设可持续更新、可检索复用的神经影像数据库，为联盟内后续数据共享和协作研究提供稳定的数据底座。
            </p>

            <div class="mt-8 grid gap-4 sm:grid-cols-2">
              <div class="rounded-[24px] border border-border/70 bg-white/80 p-5">
                <p class="text-[12px] font-semibold uppercase tracking-[0.22em] text-text-tertiary">
                  建设重点
                </p>
                <p class="mt-3 text-[15px] leading-[1.8] text-text-secondary">
                  聚焦结构像数据的统一采集、脱敏、整理、编目和入库，尽量保证跨中心数据格式和字段口径一致。
                </p>
              </div>

              <div class="rounded-[24px] border border-border/70 bg-white/80 p-5">
                <p class="text-[12px] font-semibold uppercase tracking-[0.22em] text-text-tertiary">
                  预期成果
                </p>
                <p class="mt-3 text-[15px] leading-[1.8] text-text-secondary">
                  形成一套可持续维护的数据库、配套数据字典和质控规范，便于后续扩展和复用。
                </p>
              </div>
            </div>
          </div>

          <aside class="rounded-[28px] border border-border/70 bg-surface-alt/45 p-6 md:p-7">
            <div class="space-y-6">
              <div>
                <p class="text-[12px] font-semibold uppercase tracking-[0.22em] text-text-tertiary">
                  项目定位
                </p>
                <p class="mt-2 text-[16px] leading-[1.8] text-text-secondary">
                  数据库建设
                </p>
              </div>

              <div>
                <p class="text-[12px] font-semibold uppercase tracking-[0.22em] text-text-tertiary">
                  数据范围
                </p>
                <p class="mt-2 text-[16px] leading-[1.8] text-text-secondary">
                  多中心队列中的甲基苯丙胺成瘾结构像资料
                </p>
              </div>

              <div>
                <p class="text-[12px] font-semibold uppercase tracking-[0.22em] text-text-tertiary">
                  研究人员
                </p>
                <p class="mt-2 text-[16px] font-semibold text-ink-deep">
                  曹智鹏
                </p>
                <a class="mt-1 inline-flex text-[15px] text-accent transition hover:text-accent-hover" href="mailto:zhipeng30@foxmail.com">
                  zhipeng30@foxmail.com
                </a>
              </div>

              <div class="rounded-[22px] bg-white/80 p-5">
                <p class="text-[12px] font-semibold uppercase tracking-[0.22em] text-text-tertiary">
                  建设说明
                </p>
                <p class="mt-2 text-[15px] leading-[1.8] text-text-secondary">
                  重点把结构像数据整理成统一、规范、可追踪的资源目录，方便后续持续补充与内部共享。
                </p>
              </div>
            </div>
          </aside>
        </div>
      </article>
    </div>
  </section>

  <script is:inline>
    (() => {
      const revealNodes = document.querySelectorAll("[data-reveal]");
      const timeline = document.querySelector("[data-flow-timeline]");
      const timelineNodes = timeline ? Array.from(timeline.querySelectorAll("[data-flow-node]")) : [];

      const visibleNodes = () => timelineNodes.filter((node) => node.getClientRects().length > 0);

      const updateTimeline = () => {
        if (!timeline) return;

        const nodes = visibleNodes();
        if (nodes.length === 0) return;

        const firstNode = nodes[0];
        const lastNode = nodes[nodes.length - 1];
        const timelineRect = timeline.getBoundingClientRect();
        const firstRect = firstNode.getBoundingClientRect();
        const lastRect = lastNode.getBoundingClientRect();

        const topOffset = firstRect.top + firstRect.height / 2 - timelineRect.top;
        const bottomOffset = timelineRect.bottom - (lastRect.top + lastRect.height / 2);

        timeline.style.setProperty("--timeline-line-top", `${Math.max(0, topOffset)}px`);
        timeline.style.setProperty("--timeline-line-bottom", `${Math.max(0, bottomOffset)}px`);
      };

      const scheduleTimelineUpdate = () => {
        if (typeof window.requestAnimationFrame === "function") {
          window.requestAnimationFrame(updateTimeline);
        } else {
          updateTimeline();
        }
      };

      if (!("IntersectionObserver" in window)) {
        revealNodes.forEach((node) => node.classList.add("is-visible"));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.18,
            rootMargin: "0px 0px -8% 0px",
          },
        );

        revealNodes.forEach((node) => observer.observe(node));
      }

      scheduleTimelineUpdate();
      window.addEventListener("load", scheduleTimelineUpdate, { once: true });
      window.addEventListener("resize", scheduleTimelineUpdate);

      if ("ResizeObserver" in window && timeline) {
        const resizeObserver = new ResizeObserver(scheduleTimelineUpdate);
        resizeObserver.observe(timeline);
        timelineNodes.forEach((node) => resizeObserver.observe(node));
      }
    })();
  </script>

  <style>
    .flow-axis {
      position: absolute;
      left: 22px;
      top: var(--timeline-line-top, 0px);
      bottom: var(--timeline-line-bottom, 0px);
      width: 2px;
      transform: translateX(-50%);
      pointer-events: none;
      border-radius: 9999px;
      background: rgba(31, 107, 102, 0.36);
      z-index: 0;
    }

    @media (min-width: 768px) {
      .flow-axis {
        left: 50%;
      }
    }

    .flow-node {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 74px;
      height: 74px;
      z-index: 1;
    }

    .flow-node--compact {
      width: 44px;
      height: 44px;
    }

    .flow-node-ring {
      position: absolute;
      inset: 0;
      border-radius: 9999px;
      border: 1px solid rgba(215, 223, 219, 0.95);
      background: rgba(252, 253, 252, 0.82);
    }

    .flow-node-core {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      border-radius: 9999px;
      background: var(--color-accent);
      color: white;
    }

    .flow-node--compact .flow-node-core {
      width: 30px;
      height: 30px;
    }

    .flow-node-core svg {
      width: 22px;
      height: 22px;
    }

    .flow-node--compact .flow-node-core svg {
      width: 14px;
      height: 14px;
    }

    [data-reveal] {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 700ms cubic-bezier(0.2, 0.75, 0.2, 1),
        transform 700ms cubic-bezier(0.2, 0.75, 0.2, 1);
      transition-delay: var(--reveal-delay, 0ms);
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      [data-reveal] {
        opacity: 1;
        transform: none;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</BaseLayout>
