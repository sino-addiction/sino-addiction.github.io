---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProcessIcon from "../components/ProcessIcon.astro";
import SectionHeading from "../components/SectionHeading.astro";

type FlowStep = {
  title: string;
  description: string;
  icon: "upload" | "check" | "share" | "database" | "play";
  direction: "left" | "right";
};

const flowSteps: FlowStep[] = [
  {
    title: "提交研究计划",
    description:
      "参与站点提交研究计划与基础信息，明确研究目标、样本范围、执行条件和协作边界。",
    icon: "upload",
    direction: "left",
  },
  {
    title: "可行性评估与反馈",
    description:
      "中心站点评估方案匹配度、资源条件与实施风险，并给出修改建议或确认反馈。",
    icon: "check",
    direction: "right",
  },
  {
    title: "研究计划分发",
    description:
      "根据评估结果将确认后的研究计划分发到相关站点，完成协作确认与同步。",
    icon: "share",
    direction: "left",
  },
  {
    title: "数据准备",
    description:
      "围绕采集规范、字段映射和上传规则完成数据配置、校验与准备工作。",
    icon: "database",
    direction: "right",
  },
  {
    title: "项目启动",
    description:
      "项目正式进入执行阶段，开始后续协同、研究实施与持续沟通。",
    icon: "play",
    direction: "left",
  },
];

const flowCardClass =
  "surface-card flex h-full flex-col border-t-4 border-t-accent transition-shadow hover:shadow-md";
const placeholderCardClass =
  "surface-card relative w-[min(100%,720px)] shrink-0 overflow-hidden border-t-4 border-t-accent transition-shadow hover:shadow-md";
---

<BaseLayout
  title="项目管理 - SANI"
  description="展示研究计划从提交到项目启动的标准化流程，以及当前在研项目的横向卡片展示位。"
>
  <Hero
    title="项目管理"
    subtitle="围绕研究计划的提交、评估、分发、数据准备和项目启动，统一展示标准化协作流程。"
    compact={true}
    primaryCta={{ label: "项目申请流程", href: "#project-flow" }}
    secondaryCta={{ label: "浏览当前项目", href: "#current-projects" }}
  />

  <section id="project-flow" class="page-wrap py-20 md:py-32 scroll-mt-24">
    <SectionHeading eyebrow="Workflow" title="项目申请流程" center={true} />

    <div class="mt-8 flex justify-center md:mt-10">
      <button
        type="button"
        class="inline-flex h-[58px] items-center justify-center rounded-full bg-accent px-8 text-[15px] font-semibold text-white shadow-[0_16px_34px_rgba(31,107,102,0.22)] hover:bg-accent-hover hover:shadow-[0_18px_38px_rgba(31,107,102,0.26)] md:h-[64px] md:px-10 md:text-[16px]"
      >
        下载研究计划
      </button>
    </div>

    <div class="relative mx-auto mt-10 max-w-6xl md:mt-12" data-flow-timeline>
      <div class="flow-axis" aria-hidden="true"></div>

      <div class="space-y-6 md:space-y-10">
        {flowSteps.map((step, index) => (
          <div data-reveal style={`--reveal-delay:${index * 120}ms;`}>
            <div class="relative pl-14 md:hidden">
              <div class="flow-node flow-node--compact absolute left-0 top-4" data-flow-node>
                <span class="flow-node-ring"></span>
                <span class="flow-node-core">
                  <ProcessIcon name={step.icon} class="h-4 w-4" />
                </span>
              </div>

              <article class={flowCardClass}>
                <h3 class="text-h3 text-[24px] leading-[1.2] md:text-[28px]">
                  {step.title}
                </h3>
                <p class="mt-4 text-[15px] leading-[1.85] text-text-secondary md:text-[16px]">
                  {step.description}
                </p>
              </article>
            </div>

            <div class="hidden md:grid md:grid-cols-[minmax(0,1fr)_96px_minmax(0,1fr)] md:items-center md:gap-6">
              {step.direction === "left" ? (
                <>
                  <article class={`${flowCardClass} md:justify-self-end`}>
                    <h3 class="text-h3 text-[24px] leading-[1.18]">
                      {step.title}
                    </h3>
                    <p class="mt-4 text-[16px] leading-[1.85] text-text-secondary">
                      {step.description}
                    </p>
                  </article>

                  <div class="flow-node hidden md:flex" aria-hidden="true" data-flow-node>
                    <span class="flow-node-ring"></span>
                    <span class="flow-node-core">
                      <ProcessIcon name={step.icon} class="h-5 w-5" />
                    </span>
                  </div>

                  <div aria-hidden="true"></div>
                </>
              ) : (
                <>
                  <div aria-hidden="true"></div>

                  <div class="flow-node hidden md:flex" aria-hidden="true" data-flow-node>
                    <span class="flow-node-ring"></span>
                    <span class="flow-node-core">
                      <ProcessIcon name={step.icon} class="h-5 w-5" />
                    </span>
                  </div>

                  <article class={`${flowCardClass} md:justify-self-start`}>
                    <h3 class="text-h3 text-[24px] leading-[1.18]">
                      {step.title}
                    </h3>
                    <p class="mt-4 text-[16px] leading-[1.85] text-text-secondary">
                      {step.description}
                    </p>
                  </article>
                </>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="current-projects" class="bg-surface-alt/40 py-24 md:py-32 scroll-mt-24">
    <div class="page-wrap">
      <SectionHeading eyebrow="Projects" title="当前在研项目" center={true} />

      <div class="project-strip mt-16 overflow-x-auto pb-4 md:mt-20">
        <div class="flex min-w-max gap-6 pr-2">
          <article class={placeholderCardClass}>
            <div class="relative grid gap-6 md:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] md:items-end">
              <div>
                <span class="inline-flex items-center rounded-full bg-accent-soft px-3 py-1 text-[12px] font-semibold text-accent">
                  Placeholder
                </span>
                <h3 class="mt-4 text-[28px] font-serif font-bold text-ink-deep md:text-[34px]">
                  在研项目横向卡片位
                </h3>
                <p class="mt-4 max-w-xl text-[16px] leading-[1.85] text-text-secondary md:text-[17px]">
                  后续在研项目将以横向卡片流展示，单卡固定宽度，适合桌面端浏览与移动端横滑。
                </p>
              </div>

              <div class="rounded-[28px] border border-dashed border-accent/25 bg-accent-soft/35 p-5">
                <div class="space-y-3">
                  <div class="h-3 w-28 rounded-full bg-accent/20"></div>
                  <div class="h-3 w-full rounded-full bg-accent/12"></div>
                  <div class="h-3 w-5/6 rounded-full bg-accent/10"></div>
                </div>

                <div class="mt-5 grid grid-cols-3 gap-3">
                  <div class="h-24 rounded-3xl bg-white/70"></div>
                  <div class="h-[72px] rounded-3xl bg-white/55"></div>
                  <div class="h-28 rounded-3xl bg-white/80"></div>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const revealNodes = document.querySelectorAll("[data-reveal]");
      const timeline = document.querySelector("[data-flow-timeline]");
      const timelineNodes = timeline ? Array.from(timeline.querySelectorAll("[data-flow-node]")) : [];

      const visibleNodes = () => timelineNodes.filter((node) => node.getClientRects().length > 0);

      const updateTimeline = () => {
        if (!timeline) return;

        const nodes = visibleNodes();
        if (nodes.length === 0) return;

        const firstNode = nodes[0];
        const lastNode = nodes[nodes.length - 1];
        const timelineRect = timeline.getBoundingClientRect();
        const firstRect = firstNode.getBoundingClientRect();
        const lastRect = lastNode.getBoundingClientRect();

        const centerX = firstRect.left + firstRect.width / 2 - timelineRect.left;
        const topOffset = firstRect.top + firstRect.height / 2 - timelineRect.top;
        const bottomOffset = timelineRect.bottom - (lastRect.top + lastRect.height / 2);

        timeline.style.setProperty("--timeline-line-x", `${centerX}px`);
        timeline.style.setProperty("--timeline-line-top", `${Math.max(0, topOffset)}px`);
        timeline.style.setProperty("--timeline-line-bottom", `${Math.max(0, bottomOffset)}px`);
      };

      const scheduleTimelineUpdate = () => {
        if (typeof window.requestAnimationFrame === "function") {
          window.requestAnimationFrame(updateTimeline);
        } else {
          updateTimeline();
        }
      };

      if (!("IntersectionObserver" in window)) {
        revealNodes.forEach((node) => node.classList.add("is-visible"));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.18,
            rootMargin: "0px 0px -8% 0px",
          },
        );

        revealNodes.forEach((node) => observer.observe(node));
      }

      scheduleTimelineUpdate();
      window.addEventListener("load", scheduleTimelineUpdate, { once: true });
      window.addEventListener("resize", scheduleTimelineUpdate);

      if ("ResizeObserver" in window && timeline) {
        const resizeObserver = new ResizeObserver(scheduleTimelineUpdate);
        resizeObserver.observe(timeline);
        timelineNodes.forEach((node) => resizeObserver.observe(node));
      }
    })();
  </script>

  <style>
    .flow-axis {
      position: absolute;
      left: var(--timeline-line-x, 50%);
      top: var(--timeline-line-top, 0px);
      bottom: var(--timeline-line-bottom, 0px);
      width: 2px;
      transform: translateX(-50%);
      pointer-events: none;
      border-radius: 9999px;
      background: rgba(31, 107, 102, 0.36);
      z-index: 0;
    }

    .flow-node {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 74px;
      height: 74px;
      z-index: 1;
    }

    .flow-node--compact {
      width: 44px;
      height: 44px;
    }

    .flow-node-ring {
      position: absolute;
      inset: 0;
      border-radius: 9999px;
      border: 1px solid rgba(215, 223, 219, 0.95);
      background: rgba(252, 253, 252, 0.82);
    }

    .flow-node-core {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      border-radius: 9999px;
      background: var(--color-accent);
      color: white;
    }

    .flow-node--compact .flow-node-core {
      width: 30px;
      height: 30px;
    }

    .flow-node-core svg {
      width: 22px;
      height: 22px;
    }

    .flow-node--compact .flow-node-core svg {
      width: 14px;
      height: 14px;
    }

    .project-strip {
      scroll-snap-type: x proximity;
      scrollbar-width: thin;
      scrollbar-color: rgba(31, 107, 102, 0.35) transparent;
    }

    .project-strip::-webkit-scrollbar {
      height: 10px;
    }

    .project-strip::-webkit-scrollbar-track {
      background: transparent;
    }

    .project-strip::-webkit-scrollbar-thumb {
      border-radius: 9999px;
      background: linear-gradient(90deg, rgba(31, 107, 102, 0.18), rgba(31, 107, 102, 0.42));
    }

    [data-reveal] {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 700ms cubic-bezier(0.2, 0.75, 0.2, 1),
        transform 700ms cubic-bezier(0.2, 0.75, 0.2, 1);
      transition-delay: var(--reveal-delay, 0ms);
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      [data-reveal] {
        opacity: 1;
        transform: none;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</BaseLayout>
