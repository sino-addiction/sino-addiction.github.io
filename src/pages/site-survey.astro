---
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteData } from "../data/site";

type ChoiceOption = {
  label: string;
  note: string;
  value: string;
};

const toSlug = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const addictionOptions = [
  "酒精",
  "尼古丁 / 烟草",
  "大麻",
  "阿片类",
  "可卡因",
  "兴奋剂 / 甲基苯丙胺",
  "行为成瘾（赌博 / 游戏）",
  "混合 / 多物质",
  "其他",
] as const;

const modalityOptions: ChoiceOption[] = [
  { label: "结构 MRI", note: "T1 / T2 / 体积" },
  { label: "任务 fMRI", note: "task scans" },
  { label: "静息态 fMRI", note: "resting-state" },
  { label: "DTI", note: "扩散成像" },
  { label: "EEG", note: "头皮脑电" },
  { label: "fNIRS", note: "近红外" },
].map((option) => ({
  ...option,
  value: toSlug(option.label),
}));

const dataOptions: ChoiceOption[] = [
  { label: "基因 / 遗传", note: "基因型、GWAS、PRS、SNP" },
  { label: "外周血 / 生化", note: "血液指标、炎症、激素" },
  { label: "代谢组", note: "metabolomics" },
  { label: "微生物组", note: "microbiome / gut flora" },
  { label: "其他数据", note: "以上都不适合时使用" },
].map((option) => ({
  ...option,
  value: toSlug(option.label),
}));

const surveySubmitUrl = import.meta.env.PUBLIC_SURVEY_ENDPOINT?.trim() ?? "";
---

<BaseLayout
  title="站点调查表 | SANI"
  description="用于收集站点基本信息、成瘾类别、文章信息、模态和数据概况。"
>
  <Hero
    title="站点调查表"
    subtitle="用于收集站点基本信息、成瘾类别、相关文章、模态和数据概况。请按发表文章对应的数据填写，便于我们后续按 study 整理和提取；同一套数据若发表了多篇文章，请在文章信息中一并列出，未发表数据请填写“未发表”。"
    compact={true}
  />

  <section class="page-wrap pb-24 md:pb-32">
    <div class="survey-panel">
      <div class="survey-panel-head">
        <h2 class="font-serif text-[28px] md:text-[34px] font-bold text-ink-deep leading-[1.18]">
          请按文章对应的数据填写
        </h2>
        <p class="survey-note">
          我们按文章整理 study；同一套数据若发表了多篇文章，请在“文章信息”中一并列出，未发表数据请填写“未发表”。
        </p>
      </div>

      <form
        class="survey-form grid gap-8"
        data-site-survey-form
        data-submit-url={surveySubmitUrl}
        data-contact-email={siteData.contact.email}
      >
        <fieldset class="survey-section">
          <legend class="survey-section-title">基本信息</legend>
          <div class="grid gap-4 md:grid-cols-2">
            <div class="survey-field md:col-span-2">
              <label class="survey-label" for="study_name">站点 / 研究名称 *</label>
              <input
                class="survey-control"
                id="study_name"
                name="study_name"
                type="text"
                autocomplete="organization"
                required
                placeholder="例如 Imagen / 本中心队列名称"
              />
            </div>

            <div class="survey-field">
              <label class="survey-label" for="pi_name">PI 姓名 *</label>
              <input
                class="survey-control"
                id="pi_name"
                name="pi_name"
                type="text"
                autocomplete="name"
                required
                placeholder="主要负责人姓名"
              />
            </div>

            <div class="survey-field">
              <label class="survey-label" for="institution">机构 *</label>
              <input
                class="survey-control"
                id="institution"
                name="institution"
                type="text"
                autocomplete="organization"
                required
                placeholder="单位 / 医院 / 学校"
              />
            </div>

            <div class="survey-field">
              <label class="survey-label" for="email">邮箱 *</label>
              <input
                class="survey-control"
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                required
                placeholder="name@institution.edu"
              />
            </div>

            <div class="survey-field">
              <label class="survey-label" for="wechat_number">微信号（推荐）</label>
              <input
                class="survey-control"
                id="wechat_number"
                name="wechat_number"
                type="text"
                autocomplete="off"
                placeholder="便于后续沟通，例如 wechat_id"
              />
            </div>

            <div class="survey-field">
              <label class="survey-label" for="additional_contact">补充联系人（可选）</label>
              <input
                class="survey-control"
                id="additional_contact"
                name="additional_contact"
                type="text"
                autocomplete="name"
                placeholder="如 postdoc / data manager"
              />
            </div>
          </div>
        </fieldset>

        <fieldset class="survey-section">
          <legend class="survey-section-title">成瘾类别</legend>
          <div class="grid gap-4 md:grid-cols-2">
            <div class="survey-field md:col-span-2">
              <label class="survey-label" for="addiction_category">主要成瘾类别 *</label>
              <select class="survey-control" id="addiction_category" name="addiction_category" required>
                <option value="">请选择一个类别</option>
                {addictionOptions.map((option) => <option value={option}>{option}</option>)}
              </select>
            </div>

            <div class="survey-field md:col-span-2">
              <label class="survey-label" for="addiction_detail">补充类别说明（可选）</label>
              <input
                class="survey-control"
                id="addiction_detail"
                name="addiction_detail"
                type="text"
                placeholder="如 mixed alcohol + cannabis / 赌博 + 游戏"
              />
            </div>
          </div>
        </fieldset>

        <fieldset class="survey-section">
          <legend class="survey-section-title">文章信息</legend>
          <p class="survey-note">
            请填写能唯一定位该数据集的文献信息，建议包含题目、作者、期刊、年份、DOI / PMID / URL。我们按文章对应的数据整理 study：
            例如一篇文章包含 50 case / 50 control，就按这一套数据记录；如果同一套数据发表了多篇文章，请在此处一并列出；未发表数据请填写“未发表”。
          </p>
          <div class="survey-field">
            <label class="survey-label" for="article_reference">文章信息（必填）</label>
            <textarea
              class="survey-control"
              id="article_reference"
              name="article_reference"
              rows="4"
              required
              placeholder="题目、作者、期刊、年份、DOI / PMID / URL；如有多篇文章请一并列出；未发表请填写“未发表”。"
            ></textarea>
          </div>
        </fieldset>

        <fieldset class="survey-section">
          <legend class="survey-section-title">模态与数据</legend>
          <p class="survey-note">
            勾选后请填写对应的 case / control 数量；如果暂时没有精确数值，可以先留空，后续再补。
          </p>

          <div class="grid gap-6 lg:grid-cols-2">
            <div>
              <p class="survey-label mb-3">可提供模态</p>
              <div class="survey-choice-grid">
                {modalityOptions.map((option) => {
                  const checkboxId = `modality-${option.value}`;
                  const caseName = `modality_case_${option.value}`;
                  const controlName = `modality_control_${option.value}`;
                  const caseId = `${checkboxId}-case`;
                  const controlId = `${checkboxId}-control`;

                  return (
                    <div
                      class="survey-choice-card"
                      data-survey-choice
                      data-survey-choice-group="modalities"
                      data-item-label={option.label}
                      data-case-name={caseName}
                      data-control-name={controlName}
                    >
                      <label class="survey-choice-main" for={checkboxId}>
                        <input
                          class="survey-choice-toggle"
                          type="checkbox"
                          id={checkboxId}
                          name="modalities"
                          value={option.label}
                          data-survey-toggle
                        />
                        <span>
                          <strong>{option.label}</strong>
                          <small>{option.note}</small>
                        </span>
                      </label>

                      <div class="survey-choice-counts" data-survey-counts hidden>
                        <div class="survey-count-field">
                          <label class="survey-count-label" for={caseId}>Case 数</label>
                          <input
                            class="survey-control survey-count-control"
                            id={caseId}
                            name={caseName}
                            type="number"
                            min="0"
                            step="1"
                            inputmode="numeric"
                            placeholder="0"
                          />
                        </div>

                        <div class="survey-count-field">
                          <label class="survey-count-label" for={controlId}>Control 数</label>
                          <input
                            class="survey-control survey-count-control"
                            id={controlId}
                            name={controlName}
                            type="number"
                            min="0"
                            step="1"
                            inputmode="numeric"
                            placeholder="0"
                          />
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>

            <div>
              <p class="survey-label mb-3">其它数据</p>
              <p class="survey-note">
                如果有除影像外的其它数据，请勾选最接近的一类；不确定时可以选“其他数据”，并在备注中补充说明。
              </p>
              <div class="survey-choice-grid">
                {dataOptions.map((option) => {
                  const checkboxId = `data-${option.value}`;
                  const caseName = `data_case_${option.value}`;
                  const controlName = `data_control_${option.value}`;
                  const caseId = `${checkboxId}-case`;
                  const controlId = `${checkboxId}-control`;

                  return (
                    <div
                      class="survey-choice-card"
                      data-survey-choice
                      data-survey-choice-group="data_types"
                      data-item-label={option.label}
                      data-case-name={caseName}
                      data-control-name={controlName}
                    >
                      <label class="survey-choice-main" for={checkboxId}>
                        <input
                          class="survey-choice-toggle"
                          type="checkbox"
                          id={checkboxId}
                          name="data_types"
                          value={option.label}
                          data-survey-toggle
                        />
                        <span>
                          <strong>{option.label}</strong>
                          <small>{option.note}</small>
                        </span>
                      </label>

                      <div class="survey-choice-counts" data-survey-counts hidden>
                        <div class="survey-count-field">
                          <label class="survey-count-label" for={caseId}>Case 数</label>
                          <input
                            class="survey-control survey-count-control"
                            id={caseId}
                            name={caseName}
                            type="number"
                            min="0"
                            step="1"
                            inputmode="numeric"
                            placeholder="0"
                          />
                        </div>

                        <div class="survey-count-field">
                          <label class="survey-count-label" for={controlId}>Control 数</label>
                          <input
                            class="survey-control survey-count-control"
                            id={controlId}
                            name={controlName}
                            type="number"
                            min="0"
                            step="1"
                            inputmode="numeric"
                            placeholder="0"
                          />
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </fieldset>

        <fieldset class="survey-section">
          <legend class="survey-section-title">备注</legend>
          <div class="survey-field">
            <label class="survey-label" for="notes">补充说明（可选）</label>
            <textarea
              class="survey-control"
              id="notes"
              name="notes"
              rows="4"
              placeholder="如样本量、年龄范围、是否仍在收集、共享限制、脱敏情况等。"
            ></textarea>
          </div>
        </fieldset>

        <div class="survey-submit-row">
          <p class="survey-help">
            提交后信息将直接发送至 <span class="font-medium">{siteData.contact.email}</span>。
            若发送异常，请直接发送邮件至 <span class="font-medium">{siteData.contact.email}</span>，我们会尽快回复。
          </p>

          <button type="submit" class="btn-primary survey-submit-button w-full sm:w-auto px-8">
            提交并发送
          </button>
        </div>

        <p class="survey-status" data-survey-status aria-live="polite"></p>
      </form>
    </div>
  </section>

  <script is:inline>
    (() => {
      const form = document.querySelector("[data-site-survey-form]");
      if (!(form instanceof HTMLFormElement)) return;

      const submitUrl = form.dataset.submitUrl?.trim() ?? "";
      const contactEmail = form.dataset.contactEmail || "";
      const submitButton = form.querySelector(".survey-submit-button");
      const statusEl = form.querySelector("[data-survey-status]");
      const choiceCards = Array.from(form.querySelectorAll("[data-survey-choice]"));

      const getValue = (formData, name) => {
        const value = formData.get(name);
        return typeof value === "string" ? value.trim() : "";
      };

      const setStatus = (state, message) => {
        if (statusEl instanceof HTMLElement) {
          statusEl.dataset.state = state;
          statusEl.textContent = message;
        }
      };

      const buildSelections = (groupName, formData) => {
        const selections = [];

        for (const card of choiceCards) {
          if (!(card instanceof HTMLElement)) continue;
          if (card.dataset.surveyChoiceGroup !== groupName) continue;

          const toggle = card.querySelector("[data-survey-toggle]");
          if (!(toggle instanceof HTMLInputElement) || !toggle.checked) continue;

          const label = card.dataset.itemLabel || "";
          if (!label) continue;

          selections.push({
            label,
            case_count: getValue(formData, card.dataset.caseName || ""),
            control_count: getValue(formData, card.dataset.controlName || ""),
          });
        }

        return selections;
      };

          const syncChoiceCard = (card) => {
        if (!(card instanceof HTMLElement)) return () => {};

        const toggle = card.querySelector("[data-survey-toggle]");
        const counts = card.querySelector("[data-survey-counts]");
        const countInputs = counts instanceof HTMLElement ? Array.from(counts.querySelectorAll("input")) : [];

          const update = () => {
            const isSelected = toggle instanceof HTMLInputElement ? toggle.checked : false;
            card.dataset.state = isSelected ? "selected" : "idle";

          if (counts instanceof HTMLElement) {
            counts.hidden = !isSelected;
          }

            for (const input of countInputs) {
              if (!(input instanceof HTMLInputElement)) continue;
              input.disabled = !isSelected;
              input.required = false;
              if (!isSelected) {
                input.value = "";
              }
            }
        };

        if (toggle instanceof HTMLInputElement) {
          toggle.addEventListener("change", update);
        }

        update();
        return update;
      };

      const choiceControllers = choiceCards.map((card) => syncChoiceCard(card));
      const syncAllChoices = () => {
        for (const update of choiceControllers) {
          update();
        }
      };

      const buildPayload = (formData) => ({
        study_name: getValue(formData, "study_name"),
        pi_name: getValue(formData, "pi_name"),
        institution: getValue(formData, "institution"),
        email: getValue(formData, "email"),
        wechat_number: getValue(formData, "wechat_number"),
        additional_contact: getValue(formData, "additional_contact"),
        addiction_category: getValue(formData, "addiction_category"),
        addiction_detail: getValue(formData, "addiction_detail"),
        article_reference: getValue(formData, "article_reference"),
        modalities: buildSelections("modalities", formData),
        data_types: buildSelections("data_types", formData),
        notes: getValue(formData, "notes"),
        submitted_at: new Date().toISOString(),
        page_path: window.location.pathname,
      });

      const setButtonState = (label, disabled) => {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.textContent = label;
          submitButton.disabled = disabled;
        }
      };

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        event.stopImmediatePropagation();

        if (!form.reportValidity()) return;

        if (!submitUrl) {
          setStatus("error", `提交服务暂不可用，请直接发送邮件至 ${contactEmail}，我们会尽快回复。`);
          return;
        }

        const formData = new FormData(form);
        const payload = buildPayload(formData);
        const originalLabel =
          submitButton instanceof HTMLButtonElement && submitButton.textContent
            ? submitButton.textContent.trim()
            : "提交并发送";

        try {
          setButtonState("发送中...", true);
          setStatus("info", "信息正在发送，请稍候。");

          const response = await fetch(submitUrl, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            throw new Error(await response.text());
          }

          form.reset();
          syncAllChoices();
          setStatus("success", "您的信息已发送，我们将尽快与您取得联系。");
          window.setTimeout(() => setButtonState(originalLabel, false), 2200);
        } catch (error) {
          console.error(error);
          setStatus("error", `信息发送失败，请稍后重试，或直接发送邮件至 ${contactEmail}，我们会尽快回复。`);
          window.setTimeout(() => setButtonState(originalLabel, false), 2200);
        }
      });
    })();
  </script>

  <style>
    .survey-panel {
      position: relative;
      border-radius: 32px;
      border: 1px solid rgba(215, 223, 219, 0.9);
      background: rgba(255, 255, 255, 0.98);
      box-shadow: none;
    }

    .survey-panel-head {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding: 1.5rem 1.25rem;
      border-bottom: 1px solid rgba(215, 223, 219, 0.8);
    }

    .survey-note {
      color: var(--color-text-secondary);
      font-size: 0.92rem;
      line-height: 1.75;
      max-width: 62rem;
    }

    .survey-form {
      position: relative;
      padding: 1.25rem;
    }

    .survey-section {
      display: grid;
      gap: 1rem;
      border: 0;
      border-top: 1px solid rgba(215, 223, 219, 0.82);
      padding: 1.75rem 0 0;
    }

    .survey-section:first-of-type {
      border-top: 0;
      padding-top: 0;
    }

    .survey-section-title {
      display: inline-flex;
      align-items: center;
      min-height: 24px;
      padding: 0 0.65rem;
      margin-left: 0;
      border-radius: 9999px;
      background: rgba(31, 107, 102, 0.08);
      color: var(--color-accent);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .survey-field {
      display: grid;
      gap: 0.55rem;
    }

    .survey-label {
      color: var(--color-ink-deep);
      font-size: 0.9rem;
      font-weight: 700;
    }

    .survey-control {
      width: 100%;
      min-height: 3rem;
      border-radius: 18px;
      border: 1px solid rgba(215, 223, 219, 0.95);
      background: rgba(255, 255, 255, 0.96);
      padding: 0.85rem 1rem;
      font: inherit;
      font-size: 0.95rem;
      color: var(--color-text-primary);
    }

    .survey-control::placeholder {
      color: var(--color-text-muted);
    }

    .survey-control:focus {
      outline: none;
      border-color: rgba(31, 107, 102, 0.42);
    }

    textarea.survey-control {
      min-height: 120px;
      resize: vertical;
    }

    select.survey-control {
      appearance: none;
      padding-right: 2.4rem;
      background-image:
        linear-gradient(45deg, transparent 50%, #738391 50%),
        linear-gradient(135deg, #738391 50%, transparent 50%);
      background-position:
        calc(100% - 18px) calc(1.25rem),
        calc(100% - 12px) calc(1.25rem);
      background-size: 6px 6px, 6px 6px;
      background-repeat: no-repeat;
    }

    .survey-choice-grid {
      display: grid;
      gap: 0.75rem;
    }

    .survey-choice-card {
      display: grid;
      gap: 0.85rem;
      border-radius: 18px;
      border: 1px solid rgba(215, 223, 219, 0.95);
      background: rgba(252, 253, 252, 0.98);
      padding: 0.9rem 1rem;
    }

    .survey-choice-card[data-state="selected"] {
      border-color: rgba(31, 107, 102, 0.25);
      background: rgba(247, 250, 248, 0.98);
    }

    .survey-choice-main {
      display: flex;
      gap: 0.8rem;
      align-items: flex-start;
      cursor: pointer;
    }

    .survey-choice-toggle {
      margin-top: 0.18rem;
      flex-shrink: 0;
      width: 1rem;
      height: 1rem;
      accent-color: var(--color-accent);
    }

    .survey-choice-main span {
      display: grid;
      gap: 0.15rem;
    }

    .survey-choice-main strong {
      color: var(--color-ink-deep);
      font-size: 0.94rem;
      line-height: 1.35;
      font-weight: 700;
    }

    .survey-choice-main small {
      color: var(--color-text-secondary);
      font-size: 0.82rem;
      line-height: 1.5;
    }

    .survey-choice-counts {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .survey-count-field {
      display: grid;
      gap: 0.4rem;
    }

    .survey-count-label {
      color: var(--color-text-secondary);
      font-size: 0.82rem;
      font-weight: 700;
    }

    .survey-count-control {
      min-height: 2.75rem;
      padding: 0.7rem 0.9rem;
      border-radius: 16px;
    }

    .survey-help {
      color: var(--color-text-secondary);
      font-size: 0.9rem;
      line-height: 1.7;
    }

    .survey-status {
      min-height: 1.5rem;
      color: var(--color-text-secondary);
      font-size: 0.92rem;
      line-height: 1.7;
    }

    .survey-status[data-state="success"] {
      color: #1f6b66;
    }

    .survey-status[data-state="error"] {
      color: #a34444;
    }

    .survey-status[data-state="info"] {
      color: var(--color-text-secondary);
    }

    .survey-submit-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid rgba(215, 223, 219, 0.82);
      padding-top: 1.5rem;
    }

    .survey-submit-button {
      min-width: 180px;
    }

    @media (max-width: 767px) {
