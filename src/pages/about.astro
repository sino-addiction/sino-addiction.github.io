---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { requirePage } from "../lib/content";

const page = await requirePage("about");

const profileFields = [
  { label: "姓名", value: "待补充" },
  { label: "单位", value: "待补充" },
  { label: "研究方向", value: "待补充" },
  { label: "联系方式", value: "待补充" },
];
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Hero {...page.data.hero} compact={true} />

  <!-- Collaboration Network -->
  <section class="page-wrap section-shell pt-0">
    <SectionHeading
      eyebrow="Collaboration Network"
      title="参与机构与研究团队"
      description="目前仅展示右侧信息，左侧结构分类暂不展示。"
      center={true}
    />
    <div class="mt-12 mx-auto grid max-w-5xl gap-6 md:grid-cols-2">
      <article class="surface-card flex h-full flex-col border-t-4 border-t-accent p-8 md:p-10">
        <span class="eyebrow mb-5 ring-1 ring-inset ring-accent/10 max-w-min">Profile</span>
        <h3 class="card-title">我的信息</h3>
        <p class="mt-4 text-[15px] leading-relaxed text-text-secondary">
          这里保留真实信息位，不展示假名或示例资料。请在需要公开时补充实际内容。
        </p>
        <dl class="mt-6 grid gap-3 text-[15px] leading-relaxed">
          {profileFields.map((field) => (
            <div class="flex items-center justify-between gap-4 rounded-lg bg-surface-alt px-4 py-3">
              <dt class="font-medium text-text-muted">{field.label}</dt>
              <dd class="text-right font-semibold text-ink-deep">{field.value}</dd>
            </div>
          ))}
        </dl>
      </article>

      <article class="surface-card flex h-full flex-col border-t-4 border-t-status-planning p-8 md:p-10">
        <span class="eyebrow mb-5 ring-1 ring-inset ring-accent/10 max-w-min">Open Call</span>
        <h3 class="card-title">期待您的加入</h3>
        <p class="mt-4 text-[15px] leading-relaxed text-text-secondary">
          期待您的加入。
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
