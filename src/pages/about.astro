---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import NetworkMap from "../components/NetworkMap.astro";
import { siteData } from "../data/site";
import { requirePage } from "../lib/content";

const page = await requirePage("about");

const profileFields = [
  { label: "姓名", value: "zh1peng" },
  { label: "角色", value: "SANI 协调与网站维护" },
  { label: "研究方向", value: "成瘾神经影像、MRI/EEG 数据处理与可复现分析工具" },
  { label: "GitHub", value: "github.com/zh1peng", href: "https://github.com/zh1peng" },
  { label: "联系方式", value: "zhipeng30@foxmail.com", href: "mailto:zhipeng30@foxmail.com" },
];
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Hero {...page.data.hero} compact={true} />

  <!-- Stats + Network Map -->
  <section class="relative pt-6 pb-10 md:pt-8 md:pb-12 bg-surface-alt/35">
    <div class="page-wrap">
      <div class="w-full max-w-4xl mx-auto mb-8 md:mb-10 text-center">
        <SectionHeading title="多中心协作版图" center={true} />
      </div>

      <div class="grid gap-8 xl:gap-10 lg:grid-cols-[minmax(300px,360px)_minmax(0,1fr)] lg:items-center">
        <aside class="rounded-[32px] border border-border/60 bg-[#f4f7f3]/70 p-4 md:p-5 shadow-[0_14px_40px_rgba(16,33,50,0.04)] backdrop-blur-sm lg:self-center">
          <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
          {siteData.homepage.stats.map((stat) => (
            <article class="rounded-[24px] border border-white/70 bg-white/58 p-6 md:p-7 shadow-[0_10px_24px_rgba(16,33,50,0.04)] backdrop-blur-sm">
              <span class="text-[13px] font-[750] text-text-muted uppercase tracking-[0.18em] mb-3 flex items-center gap-3">
                <span class="relative w-3 h-3 flex items-center justify-center">
                  <span class="absolute inset-0 bg-accent/25 rounded-full animate-ping"></span>
                  <span class="relative w-2 h-2 bg-accent rounded-full"></span>
                </span>
                {stat.label}
              </span>
              <span class="block text-[44px] md:text-[52px] font-serif font-bold text-ink-deep leading-none tracking-tighter">
                {stat.value}
              </span>
              <p class="mt-3 text-[13px] md:text-[14px] text-text-muted/85 leading-relaxed">
                {stat.note}
              </p>
            </article>
          ))}
          </div>
        </aside>

        <div class="w-full max-w-[860px] justify-self-end">
          <NetworkMap variant="home" />
        </div>
      </div>
    </div>
  </section>

  <!-- Collaboration Network -->
  <section class="page-wrap section-shell pt-0">
    <SectionHeading
      eyebrow="Collaboration Network"
      title="参与机构与研究团队"
      center={true}
    />
    <div class="mt-12 mx-auto max-w-3xl">
      <article class="surface-card flex h-full flex-col border-t-4 border-t-accent p-8 md:p-10">
        <span class="eyebrow mb-5 ring-1 ring-inset ring-accent/10 max-w-min">Profile</span>
        <h3 class="card-title">我的信息</h3>
        <p class="mt-4 text-[15px] leading-relaxed text-text-secondary">
          当前仅展示已确认的发起与维护信息。参与机构和研究团队名单将在获得确认后持续更新。
        </p>
        <dl class="mt-6 grid gap-3 text-[15px] leading-relaxed">
          {profileFields.map((field) => (
            <div class="flex flex-col gap-1 rounded-lg bg-surface-alt px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
              <dt class="shrink-0 font-medium text-text-muted">{field.label}</dt>
              <dd class="min-w-0 break-words text-left font-semibold text-ink-deep sm:text-right">
                {field.href ? (
                  <a class="text-accent underline-offset-4 hover:underline" href={field.href}>
                    {field.value}
                  </a>
                ) : (
                  field.value
                )}
              </dd>
            </div>
          ))}
        </dl>
      </article>
    </div>
  </section>
</BaseLayout>
