---
import type { CollectionEntry } from "astro:content";

type CarouselItem = {
  type: "项目" | "新闻";
  title: string;
  description: string;
  url: string;
  meta: string;
};

type Props = {
  items: CarouselItem[];
};

const { items } = Astro.props;
---
<div class="relative w-full max-w-5xl mx-auto surface-card p-8 md:p-12 overflow-hidden border-t-4 border-accent">
  <div class="carousel-container relative w-full overflow-hidden" data-carousel-length={items.length}>
    <div class="carousel-track flex transition-transform duration-500 ease-in-out" style="transform: translateX(0%);" data-carousel-track>
      {items.map((item) => (
        <div class="w-full shrink-0 px-2 lg:px-4 flex flex-col">
          <span class="inline-flex items-center text-[13px] font-semibold text-accent uppercase tracking-wider mb-4 border-l-2 border-accent pl-3">
            {item.type} · {item.meta}
          </span>
          <h3 class="text-[24px] md:text-[30px] font-bold text-ink-deep leading-snug mb-4 text-balance">
            <a href={item.url} class="hover:text-accent transition-colors">{item.title}</a>
          </h3>
          <p class="text-[16px] md:text-[18px] leading-[1.7] text-text-secondary mb-8 line-clamp-3">
            {item.description}
          </p>
          <div class="mt-auto">
            <a href={item.url} class="btn-link text-[15px] font-semibold">阅读详情 <span class="ml-1 opacity-70">→</span></a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="mt-10 flex items-center justify-between border-t border-border/80 pt-6 px-2 lg:px-4">
    <div class="flex gap-2 carousel-dots">
      {items.map((_, i) => (
        <button class:list={["w-2 h-2 rounded-full transition-colors cursor-pointer", i === 0 ? "bg-accent" : "bg-border"]} data-index={i} aria-label={`Go to slide ${i + 1}`} />
      ))}
    </div>
    
    <div class="flex gap-3">
      <button class="carousel-prev h-10 w-10 flex items-center justify-center rounded-full border border-border bg-surface text-ink-deep hover:border-accent hover:text-accent transition-colors shadow-sm" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button class="carousel-next h-10 w-10 flex items-center justify-center rounded-full border border-border bg-surface text-ink-deep hover:border-accent hover:text-accent transition-colors shadow-sm" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const track = document.querySelector('[data-carousel-track]');
    const prevBtn = document.querySelector('.carousel-prev');
    const nextBtn = document.querySelector('.carousel-next');
    const dots = document.querySelectorAll('.carousel-dots button');
    
    if (!track) return;
    
    let currentIndex = 0;
    const length = parseInt(track.parentElement.getAttribute('data-carousel-length') || '1', 10);
    
    function update() {
      track.style.transform = `translateX(-${currentIndex * 100}%)`;
      dots.forEach((dot, idx) => {
        if (idx === currentIndex) {
          dot.classList.remove('bg-border');
          dot.classList.add('bg-accent');
        } else {
          dot.classList.add('bg-border');
          dot.classList.remove('bg-accent');
        }
      });
    }
    
    prevBtn?.addEventListener('click', () => {
      currentIndex = (currentIndex > 0) ? currentIndex - 1 : length - 1;
      update();
    });
    
    nextBtn?.addEventListener('click', () => {
      currentIndex = (currentIndex < length - 1) ? currentIndex + 1 : 0;
      update();
    });
    
    dots.forEach((dot, idx) => {
      dot.addEventListener('click', () => {
        currentIndex = idx;
        update();
      });
    });
  })();
</script>
