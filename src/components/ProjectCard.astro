---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"projects">;
};

const { entry } = Astro.props;

// Mock phase mapped from progress for now
const getPhase = (p: number) => {
  if (p < 20) return "筹备阶段";
  if (p < 50) return "数据采集";
  if (p < 80) return "分析建模";
  if (p < 100) return "成果撰写";
  return "已结题";
};

const phase = getPhase(entry.data.progress);
---

<article class="surface-card flex h-full flex-col p-7 md:p-8 min-w-[380px] w-full">
  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border pb-4">
    <div class="flex items-center gap-3">
      <span class="text-sm font-semibold text-ink-deep">负责人 | {entry.data.lead}</span>
    </div>
    <span class="status-badge status-integrating">{phase}</span>
  </div>

  <div class="mt-5 flex-1">
    <p class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-2">
      {entry.data.dateStart} — {entry.data.dateEnd}
    </p>
    <h3 class="card-title line-clamp-2 text-ink-deep leading-snug">
      {entry.data.title}
    </h3>
    <p class="mt-3 text-sm leading-relaxed text-text-secondary line-clamp-4">
      {entry.body}
    </p>
  </div>

  {entry.data.downloadFile && (
    <div class="mt-6 pt-5 border-t border-border/50">
      <a href={entry.data.downloadFile} class="btn-link text-[13px] font-semibold">
        下载分析计划
        <span aria-hidden="true" class="ml-1">↓</span>
      </a>
    </div>
  )}
</article>
