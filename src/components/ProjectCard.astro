---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"projects">;
};

const { entry } = Astro.props;
---

<article class="surface-card reveal flex h-full flex-col p-7">
  <div class="flex items-center justify-between gap-4">
    <p class="eyebrow">{entry.data.lead}</p>
    <span class="rounded-full bg-mist-50 px-3 py-1 text-xs font-semibold text-ink-700">{entry.data.progress}%</span>
  </div>
  <h3 class="mt-6 font-serif text-2xl font-semibold tracking-tight text-ink-950">{entry.data.title}</h3>
  <p class="mt-3 text-sm font-medium uppercase tracking-[0.18em] text-ink-700">
    {entry.data.dateStart} - {entry.data.dateEnd}
  </p>
  <p class="mt-5 flex-1 text-base leading-7 text-ink-700">{entry.body}</p>

  <div class="mt-6">
    <div class="progress-track h-2 overflow-hidden rounded-full">
      <div class="progress-fill h-full rounded-full" style={`width: ${entry.data.progress}%`}></div>
    </div>
  </div>

  {entry.data.downloadFile && (
    <div class="mt-6">
      <a
        href={entry.data.downloadFile}
        class="inline-flex items-center gap-2 rounded-full border border-ink-900/10 px-4 py-2 text-sm font-semibold text-ink-900 hover:border-sage-500/30 hover:bg-sage-500/8 hover:text-sage-500"
      >
        下载分析计划
        <span aria-hidden="true">↓</span>
      </a>
    </div>
  )}
</article>
