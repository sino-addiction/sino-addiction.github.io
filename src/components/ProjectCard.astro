---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"projects">;
};

const { entry } = Astro.props;
---

<article class="surface-card reveal flex h-full flex-col p-7">
  <div class="flex items-center justify-between gap-4">
    <span class="status-badge status-integrating">{entry.data.lead}</span>
    <span class="status-badge status-available">{entry.data.progress}%</span>
  </div>
  <h3 class="zh-heading mt-6 font-serif text-2xl leading-8 font-bold tracking-tight text-primary-900">{entry.data.title}</h3>
  <p class="mt-3 text-sm font-medium uppercase tracking-[0.08em] text-muted-500">
    {entry.data.dateStart} - {entry.data.dateEnd}
  </p>
  <p class="mt-5 flex-1 text-base leading-7 text-secondary-600">{entry.body}</p>

  <div class="mt-6">
    <div class="progress-track h-2 overflow-hidden rounded-full">
      <div class="progress-fill h-full rounded-full" style={`width: ${entry.data.progress}%`}></div>
    </div>
  </div>

  {entry.data.downloadFile && (
    <div class="mt-6">
      <a href={entry.data.downloadFile} class="btn-link">
        下载分析计划
        <span aria-hidden="true">↓</span>
      </a>
    </div>
  )}
</article>
