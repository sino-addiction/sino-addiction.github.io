---
import {
  chinaOutlinePath,
  hainanPath,
  networkSites,
  southSeaPaths,
  taiwanPath,
} from "../data/networkMap";
---

<div class="network-map relative isolate w-full">
  <div class="pointer-events-none absolute inset-x-[10%] top-[12%] h-[58%] rounded-[50%] bg-[radial-gradient(circle_at_center,rgba(31,138,132,0.08),transparent_72%)] blur-3xl"></div>
  <div class="pointer-events-none absolute inset-x-[18%] bottom-[10%] h-[28%] rounded-[50%] bg-[radial-gradient(circle_at_center,rgba(16,33,50,0.06),transparent_78%)] blur-[120px]"></div>

  <div class="hidden md:block">
    <div class="relative aspect-[1.25/1] w-full overflow-visible">
      <svg
        viewBox="0 0 1000 800"
        class="h-full w-full overflow-visible"
        role="img"
        aria-labelledby="network-map-title network-map-desc"
      >
        <title id="network-map-title">SANI 多中心协作版图</title>
        <desc id="network-map-desc">
          中国协作中心分布示意，展示北京、上海、广州、武汉、西安与成都六个核心协作站点及其样本规模。
        </desc>

        <defs>
          <linearGradient id="network-map-fill" x1="0%" x2="100%" y1="8%" y2="90%">
            <stop offset="0%" stop-color="#F8FBF9"></stop>
            <stop offset="62%" stop-color="#EFF5F2"></stop>
            <stop offset="100%" stop-color="#E7EFEB"></stop>
          </linearGradient>
          <linearGradient id="network-map-stroke" x1="18%" x2="88%" y1="0%" y2="100%">
            <stop offset="0%" stop-color="#1F8A84" stop-opacity="0.34"></stop>
            <stop offset="100%" stop-color="#102132" stop-opacity="0.42"></stop>
          </linearGradient>
          <filter id="network-map-shadow" x="-8%" y="-8%" width="116%" height="116%">
            <feDropShadow dx="0" dy="18" stdDeviation="20" flood-color="#102132" flood-opacity="0.05"></feDropShadow>
          </filter>
        </defs>

        <path
          d={chinaOutlinePath}
          fill="url(#network-map-fill)"
          stroke="url(#network-map-stroke)"
          stroke-width="2"
          vector-effect="non-scaling-stroke"
          filter="url(#network-map-shadow)"
        ></path>
        <path
          d={chinaOutlinePath}
          fill="none"
          stroke="#1F8A84"
          stroke-opacity="0.14"
          stroke-width="10"
          vector-effect="non-scaling-stroke"
        ></path>
        <path
          d={hainanPath}
          fill="#F6FAF8"
          stroke="#6C828E"
          stroke-opacity="0.8"
          stroke-width="1.6"
          vector-effect="non-scaling-stroke"
        ></path>
        <path
          d={taiwanPath}
          fill="#F6FAF8"
          stroke="#6C828E"
          stroke-opacity="0.85"
          stroke-width="1.6"
          vector-effect="non-scaling-stroke"
        ></path>
        {southSeaPaths.map((path) => (
          <path
            d={path}
            fill="none"
            stroke="#708491"
            stroke-opacity="0.6"
            stroke-width="1.6"
            stroke-dasharray="5 7"
            stroke-linecap="round"
            vector-effect="non-scaling-stroke"
          ></path>
        ))}

        {networkSites.map((site) => (
          <g
            class="map-site"
            tabindex="0"
            role="group"
            aria-label={`${site.institution}，${site.city}，贡献样本 ${site.sampleCount} 例`}
          >
            <path
              class="map-leader"
              d={site.leaderPath}
              fill="none"
              stroke="#1F8A84"
              stroke-opacity="0.6"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              vector-effect="non-scaling-stroke"
            ></path>

            <circle class="map-node-halo" cx={site.x} cy={site.y} r="16"></circle>
            <circle class="map-node-ring" cx={site.x} cy={site.y} r="8.5"></circle>
            <circle class="map-node-core" cx={site.x} cy={site.y} r="4.5"></circle>

            <text
              class="map-label"
              x={site.labelX}
              y={site.labelY}
              text-anchor={site.labelAnchor}
            >
              {site.city}
            </text>

            <foreignObject
              x={site.cardX}
              y={site.cardY}
              width="220"
              height="112"
              class:list={[
                "map-callout",
                site.cardSide === "left" ? "map-callout-left" : "map-callout-right",
              ]}
            >
              <div
                class="flex h-full flex-col rounded-[22px] border border-border/90 bg-white/98 px-5 py-4 shadow-[0_18px_40px_rgba(16,33,50,0.08)]"
              >
                <div class="mb-3 flex items-center justify-between gap-4">
                  <span class="inline-flex h-6 items-center rounded-full bg-accent/8 px-3 text-[11px] font-semibold tracking-[0.04em] text-accent">
                    {site.label}
                  </span>
                  <span class="text-[13px] font-semibold text-text-muted">
                    {site.city}
                  </span>
                </div>
                <h3 class="text-[15px] leading-[1.45] font-semibold text-ink-deep">
                  {site.institution}
                </h3>
                <div class="mt-auto flex items-end justify-between border-t border-border/70 pt-3">
                  <span class="text-[12px] leading-none text-text-muted">
                    贡献样本
                  </span>
                  <span class="text-[18px] leading-none font-bold text-accent">
                    {site.sampleCount}
                  </span>
                </div>
              </div>
            </foreignObject>
          </g>
        ))}
      </svg>
    </div>
  </div>

  <div class="md:hidden">
    <div class="rounded-[26px] border border-border/80 bg-surface/70 px-4 py-5 shadow-sm">
      <svg viewBox="0 0 1000 800" class="h-auto w-full" aria-hidden="true">
        <path
          d={chinaOutlinePath}
          fill="#F8FBF9"
          stroke="#6C828E"
          stroke-opacity="0.75"
          stroke-width="2.2"
          vector-effect="non-scaling-stroke"
        ></path>
        <path
          d={hainanPath}
          fill="#F8FBF9"
          stroke="#6C828E"
          stroke-opacity="0.75"
          stroke-width="1.6"
          vector-effect="non-scaling-stroke"
        ></path>
        <path
          d={taiwanPath}
          fill="#F8FBF9"
          stroke="#6C828E"
          stroke-opacity="0.75"
          stroke-width="1.6"
          vector-effect="non-scaling-stroke"
        ></path>
        {southSeaPaths.map((path) => (
          <path
            d={path}
            fill="none"
            stroke="#708491"
            stroke-opacity="0.55"
            stroke-width="1.6"
            stroke-dasharray="5 7"
            stroke-linecap="round"
            vector-effect="non-scaling-stroke"
          ></path>
        ))}
        {networkSites.map((site) => (
          <g>
            <circle cx={site.x} cy={site.y} r="10" fill="#1F8A84" fill-opacity="0.12"></circle>
            <circle cx={site.x} cy={site.y} r="5.2" fill="#1F8A84"></circle>
            <text
              x={site.labelX}
              y={site.labelY}
              text-anchor={site.labelAnchor}
              fill="#486173"
              font-size="18"
              font-weight="600"
            >
              {site.city}
            </text>
          </g>
        ))}
      </svg>
    </div>

    <div class="mt-6 grid gap-4">
      {networkSites.map((site) => (
        <article class="surface-card px-5 py-5">
          <div class="mb-3 flex items-center justify-between gap-3">
            <span class="inline-flex h-6 items-center rounded-full bg-accent/8 px-3 text-[11px] font-semibold tracking-[0.04em] text-accent">
              {site.label}
            </span>
            <span class="text-[14px] font-semibold text-text-muted">{site.city}</span>
          </div>
          <h3 class="text-[17px] leading-[1.45] font-semibold text-ink-deep">
            {site.institution}
          </h3>
          <p class="mt-4 text-[14px] leading-relaxed text-text-secondary">
            当前纳入 <span class="font-semibold text-accent">{site.sampleCount}</span> 例协作样本。
          </p>
        </article>
      ))}
    </div>
  </div>
</div>

<style>
  .network-map svg {
    overflow: visible;
  }

  .map-site {
    cursor: default;
    outline: none;
  }

  .map-leader,
  .map-callout {
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 220ms ease,
      transform 240ms ease;
  }

  .map-callout-left {
    transform: translate3d(-10px, 6px, 0);
  }

  .map-callout-right {
    transform: translate3d(10px, 6px, 0);
  }

  .map-site:hover .map-leader,
  .map-site:hover .map-callout,
  .map-site:focus .map-leader,
  .map-site:focus .map-callout,
  .map-site:focus-within .map-leader,
  .map-site:focus-within .map-callout {
    opacity: 1;
    pointer-events: auto;
    transform: translate3d(0, 0, 0);
  }

  .map-node-halo,
  .map-node-ring,
  .map-node-core {
    transform-box: fill-box;
    transform-origin: center;
    transition:
      transform 220ms ease,
      fill 220ms ease,
      stroke 220ms ease,
      opacity 220ms ease;
  }

  .map-node-halo {
    fill: rgba(31, 138, 132, 0.12);
  }

  .map-node-ring {
    fill: #ffffff;
    stroke: rgba(31, 138, 132, 0.92);
    stroke-width: 2.4;
    vector-effect: non-scaling-stroke;
  }

  .map-node-core {
    fill: #1f8a84;
  }

  .map-label {
    fill: #486173;
    font-size: 14px;
    font-weight: 650;
    letter-spacing: 0.02em;
    transition: fill 220ms ease;
  }

  .map-site:hover .map-node-halo,
  .map-site:focus .map-node-halo,
  .map-site:focus-within .map-node-halo {
    transform: scale(1.75);
    opacity: 0.9;
  }

  .map-site:hover .map-node-ring,
  .map-site:focus .map-node-ring,
  .map-site:focus-within .map-node-ring {
    transform: scale(1.18);
    stroke: rgba(16, 33, 50, 0.82);
  }

  .map-site:hover .map-node-core,
  .map-site:focus .map-node-core,
  .map-site:focus-within .map-node-core {
    transform: scale(1.4);
    fill: #102132;
  }

  .map-site:hover .map-label,
  .map-site:focus .map-label,
  .map-site:focus-within .map-label {
    fill: #102132;
  }

  @media (prefers-reduced-motion: reduce) {
    .map-leader,
    .map-callout,
    .map-node-halo,
    .map-node-ring,
    .map-node-core,
    .map-label {
      transition: none;
    }
  }
</style>
