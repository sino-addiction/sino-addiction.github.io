---
import { siteData } from "../data/site";

const labelOffsets = [
  { dx: 24, dy: 18 },
  { dx: 22, dy: 16 },
  { dx: 0, dy: 24 },
  { dx: 0, dy: 20 },
  { dx: 18, dy: 18 },
  { dx: 18, dy: 16 },
];

const initialIndex = Math.max(siteData.networkMap.findIndex((point) => point.city === "北京"), 0);
const initialPoint = siteData.networkMap[initialIndex] ?? siteData.networkMap[0];
---

<div class="w-full" data-network-map-root>
  <div class="w-full h-full relative flex items-center justify-center overflow-visible select-none">
    <div class="relative w-full max-w-5xl mx-auto">
      <!-- Real China Map SVG (generated from DataV GeoJSON with province boundaries + nine-dash line + islands) -->
      <img src="/assets/china-map.svg" alt="中国地图" class="w-full h-auto opacity-70" draggable="false" />

      <!-- City nodes overlay - positioned using accurate geographic coordinates -->
      {siteData.networkMap.map((point, index) => {
        const labelOffset = labelOffsets[index] ?? { dx: 0, dy: 18 };

        return (
          <div
            class="absolute z-10 -translate-x-1/2 -translate-y-1/2"
            style={`left: ${point.x}%; top: ${point.y * 700 / 950}%;`}
          >
            <button
              type="button"
              class="relative group cursor-pointer rounded-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40"
              data-network-map-marker
              data-network-map-city={point.city}
              data-network-map-institution={point.institution}
              data-network-map-count={point.count}
              data-network-map-index={index}
              aria-pressed={index === initialIndex ? "true" : "false"}
              aria-label={`${point.city}，${point.institution}，${point.count}`}
            >
              <span class="absolute -inset-4 rounded-full md:hidden" aria-hidden="true"></span>
              <!-- Pulse ring -->
              <div class="network-map-ring absolute inset-0 m-auto w-5 h-5 bg-accent/20 rounded-full animate-ping pointer-events-none"></div>
              <!-- Dot -->
              <div class="relative w-4 h-4 flex items-center justify-center cursor-pointer z-20 peer">
                <div class="network-map-dot w-3 h-3 bg-accent rounded-full border-2 border-white shadow-md group-hover:scale-[2] group-hover:bg-ink-deep transition-all duration-300"></div>
              </div>

              <!-- City label -->
              <div
                class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 whitespace-nowrap text-[14px] sm:text-[16px] md:text-[22px] font-[800] leading-none text-ink-deep/60 pointer-events-none group-hover:opacity-0 transition-opacity drop-shadow-[0_1px_0_rgba(255,255,255,0.95)]"
                style={`margin-left: ${labelOffset.dx}px; margin-top: ${labelOffset.dy}px;`}
              >
                {point.city}
              </div>

              <!-- Hover tooltip card -->
              <div
                class:list={[
                  "hidden md:flex absolute opacity-0 pointer-events-none group-hover:opacity-100 peer-hover:opacity-100 transition-all duration-400 z-50",
                  point.dir === "left" && "right-full mr-3 top-1/2 -translate-y-1/2 flex-row-reverse",
                  point.dir === "right" && "left-full ml-3 top-1/2 -translate-y-1/2 flex-row",
                  point.dir === "top" && "bottom-full mb-3 left-1/2 -translate-x-1/2 flex-col-reverse",
                  point.dir === "bottom" && "top-full mt-3 left-1/2 -translate-x-1/2 flex-col",
                ]}
              >
                <!-- Leader line -->
                <div
                  class:list={[
                    "bg-accent/50 shrink-0",
                    (point.dir === "left" || point.dir === "right") && "w-10 h-[1.5px] my-auto",
                    (point.dir === "top" || point.dir === "bottom") && "h-10 w-[1.5px] mx-auto",
                  ]}
                ></div>

                <!-- Card (no label field, just city + institution + count) -->
                <div class="bg-white/95 backdrop-blur-lg border border-border shadow-[0_12px_48px_rgba(16,33,50,0.16)] p-4 rounded-xl w-[250px] flex flex-col shrink-0 z-10 scale-95 group-hover:scale-100 transition-all duration-300">
                  <span class="text-[11px] font-bold text-accent px-1.5 py-0.5 bg-accent/8 rounded tracking-widest w-fit mb-2">{point.city}</span>
                  <h4 class="text-[15px] font-[800] text-ink-deep leading-snug mb-3">{point.institution}</h4>
                  <div class="flex items-center justify-between pt-3 border-t border-border/40">
                    <span class="text-[12px] font-medium text-text-secondary">贡献样本</span>
                    <span class="text-[13px] font-bold text-accent">{point.count}</span>
                  </div>
                </div>
              </div>

              <!-- Connection lines to center (Beijing) -->
              {point.city !== "北京" && (
                <svg
                  class="hidden md:block absolute top-1/2 left-1/2 pointer-events-none z-0 opacity-[0.12] group-hover:opacity-30 transition-opacity duration-500"
                  style={`width: 1px; height: 1px; overflow: visible;`}
                >
                  <line
                    x1="0"
                    y1="0"
                    x2={`${(68.9 - point.x) * 10}`}
                    y2={`${(38.7 * 700 / 950 - point.y * 700 / 950) * 9.5}`}
                    stroke="var(--color-accent)"
                    stroke-width="1"
                    stroke-dasharray="4 3"
                  />
                </svg>
              )}
            </button>
          </div>
        );
      })}
    </div>
  </div>

  <div class="mt-6 space-y-3 md:hidden" data-network-map-mobile>
    <div class="rounded-3xl border border-border/70 bg-white/90 p-4 shadow-[0_10px_30px_rgba(16,33,50,0.08)] backdrop-blur-sm" aria-live="polite">
      <div class="flex items-start justify-between gap-3">
        <p class="text-[12px] font-semibold text-text-muted">点击地图上的圆点查看站点信息</p>
        <span class="shrink-0 text-[13px] font-bold text-accent" data-network-map-active-count>{initialPoint.count}</span>
      </div>
      <div class="mt-3">
        <span class="inline-flex rounded-full bg-accent/8 px-2 py-0.5 text-[11px] font-bold tracking-[0.08em] text-accent" data-network-map-active-city>
          {initialPoint.city}
        </span>
        <h4 class="mt-2 text-[16px] font-[800] leading-snug text-ink-deep" data-network-map-active-institution>
          {initialPoint.institution}
        </h4>
      </div>
    </div>
  </div>

  <script>
    const roots = document.querySelectorAll("[data-network-map-root]");

    roots.forEach((root) => {
      const markers = Array.from(root.querySelectorAll<HTMLElement>("[data-network-map-marker]"));
      const activeCity = root.querySelector<HTMLElement>("[data-network-map-active-city]");
      const activeInstitution = root.querySelector<HTMLElement>("[data-network-map-active-institution]");
      const activeCount = root.querySelector<HTMLElement>("[data-network-map-active-count]");

      const setActive = (marker: HTMLElement) => {
        const city = marker.dataset.networkMapCity ?? "";
        const institution = marker.dataset.networkMapInstitution ?? "";
        const count = marker.dataset.networkMapCount ?? "";

        markers.forEach((item) => {
          item.setAttribute("aria-pressed", item === marker ? "true" : "false");
        });

        if (activeCity) activeCity.textContent = city;
        if (activeInstitution) activeInstitution.textContent = institution;
        if (activeCount) activeCount.textContent = count;
      };

      markers.forEach((marker) => {
        marker.addEventListener("click", () => setActive(marker));
      });

      const initialMarker = markers.find((marker) => marker.getAttribute("aria-pressed") === "true") ?? markers[0];
      if (initialMarker) {
        setActive(initialMarker);
      }
    });
  </script>

  <style>
    [data-network-map-marker][aria-pressed="true"] .network-map-dot {
      transform: scale(1.85);
      filter: drop-shadow(0 0 8px rgba(29, 113, 108, 0.35));
    }

    [data-network-map-marker][aria-pressed="true"] .network-map-ring {
      opacity: 0.9;
    }

    @media (max-width: 767px) {
      [data-network-map-marker] {
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
      }
    }
  </style>
</div>
