---
import { siteData } from "../data/site";
---

<div class="w-full h-full relative p-4 flex items-center justify-center overflow-visible">
  <div class="relative w-full aspect-[1.1/1] max-w-4xl mx-auto flex items-center justify-center">
    
    <!-- 
      Politically and Geographically Accurate China Map Silhouette 
      Including: Nine-dash line regions, Taiwan, Hainan, and standardized borders.
    -->
    <svg viewBox="0 0 850 680" class="w-full h-full text-border drop-shadow-sm opacity-40 shrink-0" fill="currentColor">
      <!-- Main Continent + Hainan + Taiwan -->
      <path d="M685.5 102.5c4.7-5.5 11.2-12.2 16.5-12.8 5.4-.5 10.6 5 13.9 9.3 3.3 4.2 8.6 13.3 11.7 18 3.1 4.7 13.2 10.7 17.1 14.9 3.9 4.2 12 14.1 14.4 20.3 2.4 6.2 6.6 20.7 4.2 27.2-2.3 6.6-7.1 15.6-11.4 19.3-4.3 3.8-12.5 10.5-12 18 .5 7.5-.1 17-.6 25.4-.5 8.4-4.8 19-3.7 26.6 1.1 7.6 10.5 14.4 10.5 22.3 0 7.8-8.9 15.9-12.9 22.7-4 6.8-5.3 17.3-8.8 24.3-3.6 7-11.4 15-16.1 21.6-4.7 6.6-9.1 15-14.7 20-5.6 5-13.6 10.1-19.3 15-5.7 4.9-11 11.8-17 15.5-6 3.7-18.7 8.3-25 10.4-6.3 2.1-15 4.5-21.7 8.6-6.7 4.1-14.4 11.2-21.3 13.3-6.9 2.1-16.1 1.6-23.7 3.5-7.6 1.9-15.6 8.7-22.6 10.1-7 1.4-19 1-26 1-7 0-16.5 4.3-24.3 4.8-7.8.5-18.6-4.5-26.6-5.4-8-.9-18.6 3.5-26.6 4.3-8 .8-16.4-.6-24.4-.1-8 .5-16.5 2.1-24.3 1-7.8-1.1-18.2-11.6-25-15-6.8-3.4-14-11.7-19.1-17.7-5.1-6-8.7-16-11.7-22.3-3-6.3-4.6-13.8-5.9-20.7-1.3-6.9-4.8-15-4.8-22.3 0-7.3 5.4-16 6-23.7.6-7.7-1.4-17.4-1.9-25.1-.5-7.7 5.1-14.2 7-21.7 1.9-7.5 1.5-18.3 4.1-25.7 2.6-7.4 11-12.7 15.3-19.6 4.3-6.9 7-16 11.1-22 4.1-6 11.4-10.4 17.5-14.5 6.1-4.1 15.1-7.5 22.3-9.5 7.2-2 15.3-.4 23-.4 7.7 0 16.7-5.1 24.3-5.9 7.6-.8 18.5 2.6 26.6 2.6 8.1 0 17-6 24.4-7.5 7.4-1.5 15.4.1 23.1-.4 7.7-.5 15.9-5.1 23.7-5.9 7.8-.8 16-.1 24.1-.7 8.1-.6 20.3-6.9 28.3-6.9 8.1 0 19 3.2 26.6 3.2 7.6.1 16.4-5.3 22-8.5 5.6-3.2 11-10 13.9-14.5 2.9-4.5 1.4-14 4.5-18 3.1-4 12-4.5 16.5-10.2z" />
      <path d="M520 545c-2.4 2.8-.7 10.4 2.8 14 3.5 3.6 15.4 13 23.2 13 7.8 0 16.4-5.4 16.4-12.8 0-7.4-12-14.1-20-14.1-8 0-20-.1-22.4-.1z" /> <!-- Hainan -->
      <path d="M660 480c2.4 0 5.1 4.5 5.1 11 0 6.5-2.7 14.1-7.2 18-4.5 3.9-11 5.3-15.5 3.1-4.5-2.2-5.7-9.3-5.7-16 0-6.7 1.2-16.1 5.7-16.1 4.5 0 15.2 0 17.6 0z" /> <!-- Taiwan -->
      
      <!-- Nine-Dash Line Representation -->
      <g opacity="0.6">
        <path d="M580 580 c10 5 15 20 12 35" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 3"/>
        <path d="M620 620 c5 15 0 35 -10 45" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 3"/>
        <path d="M540 600 c-5 15 -15 25 -25 30" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 3"/>
      </g>
    </svg>

    <!-- Overlay Nodes & Hover Tooltips with exact relative coordinates -->
    {siteData.networkMap.map((point) => (
      <div 
        class="absolute z-10 flex items-center justify-center -translate-x-1/2 -translate-y-1/2 transition-all duration-300"
        style={`left: ${point.x}%; top: ${point.y}%;`}
      >
        <!-- The Node Dot -->
        <div class="relative w-8 h-8 group">
          <div class="absolute inset-0 m-auto w-3 h-3 bg-accent rounded-full border-2 border-surface shadow-sm cursor-pointer group-hover:scale-[1.8] group-hover:bg-ink-deep transition-all duration-300 z-20 peer"></div>
          
          <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 whitespace-nowrap text-[12px] font-bold text-ink-deep pointer-events-none opacity-40 group-hover:opacity-0 transition-opacity">
            {point.city}
          </div>

          <!-- The Extruded Information Card -->
          <div class:list={[
            "absolute opacity-0 pointer-events-none group-hover:opacity-100 peer-hover:opacity-100 transition-all duration-500 flex z-50",
            point.dir === "left" && "right-full mr-0 top-1/2 -translate-y-1/2 flex-row-reverse",
            point.dir === "right" && "left-full ml-0 top-1/2 -translate-y-1/2 flex-row",
            point.dir === "top" && "bottom-full mb-0 left-1/2 -translate-x-1/2 flex-col-reverse",
            point.dir === "bottom" && "top-full mt-0 left-1/2 -translate-x-1/2 flex-col",
          ]}>
            
            <!-- Long Leader Line -->
            <div class:list={[
              "bg-accent/40 shrink-0 z-0 transition-all duration-500",
              (point.dir === "left" || point.dir === "right") && "w-16 h-[1px] my-auto",
              (point.dir === "top" || point.dir === "bottom") && "h-16 w-[1px] mx-auto"
            ]}></div>

            <!-- Enhanced Content Card -->
            <div class="bg-surface/95 backdrop-blur-md border border-border shadow-[0_12px_48px_rgba(16,33,50,0.15)] p-5 rounded-2xl w-[260px] flex flex-col shrink-0 z-10 scale-95 group-hover:scale-100 transition-all duration-300">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-[12px] font-bold text-accent px-2 py-0.5 bg-accent/5 rounded tracking-widest">{point.city}</span>
                <span class="text-[11px] font-[650] text-text-muted/60 uppercase flex-1 text-right">{point.label}</span>
              </div>
              <h4 class="text-[16px] font-[750] text-ink-deep leading-tight mb-4">{point.institution}</h4>
              <div class="mt-auto flex items-center justify-between pt-4 border-t border-border/40">
                <span class="text-[13px] font-medium text-text-secondary">贡献样本规模</span>
                <span class="text-[14px] font-bold text-ink-deep">{point.count}</span>
              </div>
            </div>
            
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
