---
import { siteData } from "../data/site";
---

<div class="w-full h-full relative flex items-center justify-center overflow-visible select-none">
  <div class="relative w-full max-w-5xl mx-auto">
    
    <!-- Real China Map SVG (generated from DataV GeoJSON with province boundaries) -->
    <img src="/assets/china-map.svg" alt="中国地图" class="w-full h-auto opacity-70" draggable="false" />

    <!-- City nodes overlay - positioned using accurate geographic coordinates -->
    {siteData.networkMap.map((point) => (
      <div 
        class="absolute z-10 -translate-x-1/2 -translate-y-1/2"
        style={`left: ${point.x}%; top: ${point.y}%;`}
      >
        <div class="relative group">
          <!-- Pulse ring -->
          <div class="absolute inset-0 m-auto w-5 h-5 bg-accent/20 rounded-full animate-ping pointer-events-none"></div>
          <!-- Dot -->
          <div class="relative w-4 h-4 flex items-center justify-center cursor-pointer z-20 peer">
            <div class="w-3 h-3 bg-accent rounded-full border-2 border-white shadow-md group-hover:scale-[2] group-hover:bg-ink-deep transition-all duration-300"></div>
          </div>
          
          <!-- City label (always visible, subtle) -->
          <div class="absolute left-1/2 -translate-x-1/2 top-full mt-1 whitespace-nowrap text-[11px] font-bold text-ink-deep/50 pointer-events-none group-hover:opacity-0 transition-opacity">
            {point.city}
          </div>

          <!-- Hover tooltip card -->
          <div class:list={[
            "absolute opacity-0 pointer-events-none group-hover:opacity-100 peer-hover:opacity-100 transition-all duration-400 flex z-50",
            point.dir === "left" && "right-full mr-3 top-1/2 -translate-y-1/2 flex-row-reverse",
            point.dir === "right" && "left-full ml-3 top-1/2 -translate-y-1/2 flex-row",
            point.dir === "top" && "bottom-full mb-3 left-1/2 -translate-x-1/2 flex-col-reverse",
            point.dir === "bottom" && "top-full mt-3 left-1/2 -translate-x-1/2 flex-col",
          ]}>
            
            <!-- Leader line -->
            <div class:list={[
              "bg-accent/50 shrink-0",
              (point.dir === "left" || point.dir === "right") && "w-10 h-[1.5px] my-auto",
              (point.dir === "top" || point.dir === "bottom") && "h-10 w-[1.5px] mx-auto"
            ]}></div>

            <!-- Card -->
            <div class="bg-white/95 backdrop-blur-lg border border-border shadow-[0_12px_48px_rgba(16,33,50,0.16)] p-4 rounded-xl w-[250px] flex flex-col shrink-0 z-10 scale-95 group-hover:scale-100 transition-all duration-300">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-[11px] font-bold text-accent px-1.5 py-0.5 bg-accent/8 rounded tracking-widest">{point.city}</span>
                <span class="text-[10px] font-[700] text-text-muted/50 uppercase flex-1 text-right tracking-wider">{point.label}</span>
              </div>
              <h4 class="text-[15px] font-[800] text-ink-deep leading-snug mb-3">{point.institution}</h4>
              <div class="flex items-center justify-between pt-3 border-t border-border/40">
                <span class="text-[12px] font-medium text-text-secondary">贡献样本</span>
                <span class="text-[13px] font-bold text-accent">{point.count}</span>
              </div>
            </div>
          </div>

          <!-- Connection lines to center (Beijing) -->
          {point.city !== "北京" && (
            <svg class="absolute top-1/2 left-1/2 pointer-events-none z-0 opacity-[0.12] group-hover:opacity-30 transition-opacity duration-500" 
                 style={`width: 1px; height: 1px; overflow: visible;`}>
              <line x1="0" y1="0" 
                    x2={`${(68.9 - point.x) * 10}`} 
                    y2={`${(38.7 - point.y) * 7}`}
                    stroke="var(--color-accent)" stroke-width="1" stroke-dasharray="4 3" />
            </svg>
          )}
        </div>
      </div>
    ))}
  </div>
</div>
