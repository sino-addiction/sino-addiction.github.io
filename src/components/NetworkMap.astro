---
import { siteData } from "../data/site";
---

<div class="w-full h-full relative p-4 flex items-center justify-center">
  <div class="relative w-full aspect-[5/3] max-w-3xl mx-auto">
    <!-- Abstract contour/grid representation of map -->
    <svg viewBox="0 0 800 480" class="w-full h-full drop-shadow-sm" xmlns="http://www.w3.org/2000/svg" aria-label="中国成瘾神经影像网络分布图" role="img">
      <!-- Background subtle grid -->
      <pattern id="dotGrid" width="20" height="20" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1.5" fill="var(--color-border)" opacity="0.4" />
      </pattern>
      <rect width="100%" height="100%" fill="url(#dotGrid)" />

      <!-- Schematic Connection Lines -->
      <g stroke="var(--color-border)" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.6">
        <path d="M 520 180 Q 450 200 400 300" fill="none" />
        <path d="M 520 180 Q 550 260 560 350" fill="none" />
        <path d="M 520 180 Q 350 250 220 280" fill="none" />
        <path d="M 520 180 Q 550 200 600 240" fill="none" />
        <path d="M 520 180 Q 480 220 450 250" fill="none" />
      </g>
    </svg>

    <!-- Overlay Nodes -->
    {siteData.networkMap.map((point) => (
      <!-- We scale original 520x360 coordinates into CSS absolute % roughly -->
      <div 
        class="group absolute flex flex-col items-center justify-center -translate-x-1/2 -translate-y-1/2 z-10 cursor-pointer"
        style={`left: ${point.x / 520 * 100}%; top: ${point.y / 360 * 100}%;`}
      >
        <div class="relative flex items-center justify-center">
          <div class="absolute w-8 h-8 rounded-full bg-accent opacity-10 group-hover:opacity-20 group-hover:scale-125 transition-all duration-300"></div>
          <div class="w-3 h-3 rounded-full bg-accent border-[2px] border-surface"></div>
        </div>
        <div class="mt-2 text-[13px] font-bold text-ink-deep bg-surface/80 backdrop-blur-sm px-2 py-0.5 rounded-sm drop-shadow-sm transition-opacity group-hover:opacity-0 whitespace-nowrap">
          {point.city}
        </div>

        <!-- Tooltip -->
        <div class="absolute bottom-full mb-3 pointer-events-none opacity-0 group-hover:opacity-100 transition-all duration-200 translate-y-2 group-hover:translate-y-0 z-50 flex flex-col items-center">
          <div class="bg-ink-deep text-white px-4 py-3 rounded-lg shadow-lg whitespace-nowrap min-w-[140px]">
            <p class="text-[13px] font-bold tracking-wider text-white/50 mb-1 uppercase text-center">{point.city}</p>
            <p class="text-[15px] font-semibold text-white text-center">{point.institution}</p>
            <hr class="border-white/10 my-2" />
            <p class="text-[14px] font-medium text-accent-soft text-center">{point.count}</p>
          </div>
          <div class="w-3 h-3 bg-ink-deep rotate-45 -mt-2"></div>
        </div>
      </div>
    ))}
  </div>
</div>
