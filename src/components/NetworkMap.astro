---
import { siteData } from "../data/site";
---

<div class="w-full h-full relative p-4 flex items-center justify-center overflow-visible">
  <div class="relative w-full aspect-[1.2/1] max-w-4xl mx-auto flex items-center justify-center">
    
    <!-- More Accurate China Map Path -->
    <!-- This path provides a clearer China silhouette including the Northeast and Southern curves -->
    <svg viewBox="0 0 800 600" class="w-full h-full text-border drop-shadow-sm opacity-40 shrink-0" fill="currentColor">
      <path d="M608,103c-2.3-3.6-5.5-5.9-9.5-6.8c-2.8-0.6-5.7-0.4-8.4,0.6c-4.4,1.6-8.3,5-10.7,9.3c-2.4,4.3-3.3,9.4-2.7,14.3 c0.6,4.9,2.8,9.4,6.2,12.9c3.4,3.5,7.8,5.8,12.6,6.6c4.7,0.8,9.6,0.2,14-1.9c4.4-2,8.1-5.6,10.2-9.9c2.1-4.4,2.8-9.3,1.9-14.1 c-0.8-4.8-3.1-9.2-6.5-12.6C613.1,108.8,610.8,105.7,608,103z M590.3,55.5c-4.4,0.6-8.7,2.1-12.5,4.4c-3.8,2.3-7,5.4-9.5,9.1 c-2.4,3.7-4,7.9-4.5,12.3c-0.6,4.4,0,8.9,1.7,13.1c1.7,4.2,4.4,7.9,7.9,10.9c3.5,3,7.6,5.1,12.1,6.1c4.4,1,9.1,1,13.5,0 c4.4-1,8.5-3.1,11.9-6.1c3.4-3,6-6.8,7.5-11.1c1.5-4.2,1.9-8.8,1.2-13.2c-0.7-4.4-2.5-8.6-5.2-12.2c-2.7-3.6-6.3-6.4-10.4-8.3 C599.9,56.5,595.1,55.2,590.3,55.5z M446.5,13.5c-44-1.3-88.6,12.1-125.6,37.8c-37,25.7-65.7,61.7-80.9,101.4 c-15.2,39.7-18.1,83.1-8.3,123.9c9.8,40.8,31.8,77.5,62.8,104.9c31,27.4,69.9,45.4,111.3,51.6c41.4,6.2,83.9,1.6,123.4-13.1 c39.5-14.7,73.8-40.2,98.1-73.4c24.3-33.2,38.1-72.9,39.5-113.8c1.4-40.9-10.1-81.1-32.9-115.1 c-22.8-34-55.5-60.1-94.2-75c-28.7-11-59.5-16.5-90.4-16.5C447.8,13.5,447.2,13.5,446.5,13.5z M474.7,35.9 c34.2,13.2,63.1,36.2,83.3,66.4c20.2,30.2,30.4,65.8,29.1,102.1c-1.3,36.3-13.5,71.5-35,101.1c-21.5,29.6-51.9,52.2-86.9,65.2 c-35,13-72.7,16-109.5,10.6c-36.8-5.4-71.3-21.4-98.9-45.8c-27.6-24.4-47.1-57.1-55.8-93.4c-8.7-36.3-6.1-74.8,7.4-110.1 c13.5-35.3,39-67.2,71.9-90.1c32.9-22.9,72.6-34.7,111.7-33.6C418,8.8,442.2,21.7,460.6,35.9L474.7,35.9z" opacity="0" />
      <path d="M580,80 L620,60 L680,80 L720,130 L740,180 L760,240 L740,300 L720,360 L680,410 L620,480 L560,530 L500,560 L440,570 L380,575 L320,560 L240,540 L180,510 L140,460 L120,400 L110,340 L120,290 L160,250 L210,230 L260,240 L310,200 L370,180 L420,160 L480,140 L540,110 Z" />
      
      <!-- Better Hand-Drawn style SVG path for China (simplified for speed/cleanliness but with key features) -->
      <path d="M430,170 C460,165 490,150 520,140 C550,130 580,100 610,80 C630,70 650,60 670,65 C690,70 710,95 725,120 C745,150 755,190 765,230 C775,270 760,310 740,345 C720,380 690,410 660,430 C630,450 600,480 570,510 C540,540 500,565 460,575 C420,585 380,580 340,570 C300,560 260,545 220,520 C180,495 150,470 130,430 C115,400 100,365 105,330 C110,295 135,265 170,245 C205,225 245,235 280,210 C310,185 345,195 380,185 C400,180 415,175 430,170 Z M645,430 C655,450 665,480 660,510 Q655,540 640,560 T615,585 T585,600" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
      <path d="M430,170 C460,165 490,150 520,140 C550,130 580,100 610,80 C630,70 650,60 670,65 C690,70 710,95 725,120 C745,150 755,190 765,230 C775,270 760,310 740,345 C720,380 690,410 660,430 C630,450 600,480 570,510 C540,540 500,565 460,575 C420,585 380,580 340,570 C300,560 260,545 220,520 C180,495 150,470 130,430 C115,400 100,365 105,330 C110,295 135,265 170,245 C205,225 245,235 280,210 C310,185 345,195 380,185 C400,180 415,175 430,170 Z" />
    </svg>

    <!-- Overlay Nodes & Hover Tooltips with exact relative coordinates -->
    {siteData.networkMap.map((point) => (
      <div 
        class="absolute z-10 flex items-center justify-center -translate-x-1/2 -translate-y-1/2 transition-all duration-300"
        style={`left: ${point.x}%; top: ${point.y}%;`}
      >
        <!-- The Node Dot -->
        <div class="relative w-8 h-8 group">
          <div class="absolute inset-0 m-auto w-3 h-3 bg-accent rounded-full border-2 border-surface shadow-sm cursor-pointer group-hover:scale-[1.8] group-hover:bg-ink-deep transition-all duration-300 z-20 peer"></div>
          
          <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 whitespace-nowrap text-[12px] font-bold text-ink-deep pointer-events-none opacity-40 group-hover:opacity-0 transition-opacity">
            {point.city}
          </div>

          <!-- The Extruded Information Card -->
          <div class:list={[
            "absolute opacity-0 pointer-events-none group-hover:opacity-100 peer-hover:opacity-100 transition-all duration-500 flex z-50",
            point.dir === "left" && "right-full mr-0 top-1/2 -translate-y-1/2 flex-row-reverse",
            point.dir === "right" && "left-full ml-0 top-1/2 -translate-y-1/2 flex-row",
            point.dir === "top" && "bottom-full mb-0 left-1/2 -translate-x-1/2 flex-col-reverse",
            point.dir === "bottom" && "top-full mt-0 left-1/2 -translate-x-1/2 flex-col",
          ]}>
            
            <!-- Long Leader Line -->
            <div class:list={[
              "bg-accent/40 shrink-0 z-0 transition-all duration-500",
              (point.dir === "left" || point.dir === "right") && "w-16 h-[1px] my-auto",
              (point.dir === "top" || point.dir === "bottom") && "h-16 w-[1px] mx-auto"
            ]}></div>

            <!-- Enhanced Content Card -->
            <div class="bg-surface/95 backdrop-blur-md border border-border shadow-[0_12px_48px_rgba(16,33,50,0.15)] p-5 rounded-2xl w-[260px] flex flex-col shrink-0 z-10 scale-95 group-hover:scale-100 transition-all duration-300">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-[12px] font-bold text-accent px-2 py-0.5 bg-accent/5 rounded tracking-widest">{point.city}</span>
                <span class="text-[11px] font-[650] text-text-muted/60 uppercase flex-1 text-right">{point.label}</span>
              </div>
              <h4 class="text-[16px] font-[750] text-ink-deep leading-tight mb-4">{point.institution}</h4>
              <div class="mt-auto flex items-center justify-between pt-4 border-t border-border/40">
                <span class="text-[13px] font-medium text-text-secondary">贡献样本规模</span>
                <span class="text-[14px] font-bold text-ink-deep">{point.count}</span>
              </div>
            </div>
            
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
