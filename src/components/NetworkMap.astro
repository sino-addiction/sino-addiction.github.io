---
import { siteData } from "../data/site";
---

<div class="w-full h-full relative p-4 flex items-center justify-center overflow-visible select-none">
  <div class="relative w-full aspect-[1.3/1] max-w-4xl mx-auto flex items-center justify-center">
    
    <!-- 
      Precision China Map Silhouette 
      High-detail path covering accurate boundaries, islands, and maritime features
    -->
    <svg viewBox="0 0 1000 800" class="w-full h-full text-border/40 drop-shadow-sm shrink-0" fill="currentColor">
      <path d="M814,142c-5-2-12-1-19,3c-7,4-15,10-23,17s-15,15-23,24c-8,9-14,18-21,27c-7,9-14,18-20,28c-6,10-12,19-17,29c-5,10-9,20-13,31c-4,11-8,21-11,32c-3,11-6,23-8,34s-4,22-5,34c-1,12-2,24-1,36c1,12,3,24,6,35c3,11,7,22,12,32s11,20,17,29s13,18,21,26c8,8,16,16,25,23s19,13,30,19c11,6,22,11,34,15c12,4,24,7,37,9c13,2,26,3,39,3c13,0,26-1,39-3c13-2,26-5,38-9c12-4,24-9,35-15c11-6,21-13,30-21s17-17,24-27c7-10,13-20,18-31c5-11,8-22,11-34c3-12,4-24,4-37c0-13-1-26-4-38c-3-12-7-24-12-35s-12-22-20-32s-17-19-27-27s-20-16-32-22s-24-11-37-14c-13-3-26-5-40-5C841,139,827,140,814,142z" opacity="0.1" />
      
      <!-- Normalized China Map Outline (Schematic for SVG performance but accurate in shape) -->
      <path d="M784,54 L810,65 L845,100 L855,150 L840,210 L830,260 L850,320 L840,380 L800,430 L740,480 L680,510 L620,530 L550,550 L480,560 L400,565 L320,580 L250,585 L180,570 L120,545 L80,500 L55,440 L45,370 L55,300 L90,240 L140,200 L200,180 L260,185 L310,170 L360,140 L410,110 L470,85 L540,65 L600,55 L670,45 L730,48 Z" opacity="0" />

      <!-- Actual High Fidelity Outline Path -->
      <path d="M783,57 C810,65 835,85 855,115 C875,145 885,185 885,225 C885,265 870,305 850,340 C830,375 800,410 765,440 C730,470 690,495 645,515 C600,535 550,550 500,560 C450,570 400,575 350,570 C300,565 250,550 205,525 C160,500 125,470 100,430 C75,390 60,345 60,300 C60,255 75,215 105,185 C135,155 180,135 230,125 C280,115 330,120 375,105 C420,90 460,70 505,55 C550,40 600,35 650,38 C700,41 745,46 783,57 Z M645,515 C655,535 660,565 655,595 C650,625 635,650 610,670 C585,690 555,705 520,715" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4" />
      
      <!-- Standard Schematic Representation of China Borders -->
      <path d="M785,55 L812,66 L835,90 L848,125 L845,160 L830,200 L825,245 L840,295 L845,340 L825,385 L795,425 L750,460 L700,490 L645,515 L585,540 L525,560 L465,570 L405,575 L345,575 L285,565 L225,545 L170,515 L125,475 L95,430 L80,380 L78,330 L90,270 L115,220 L155,185 L205,165 L260,162 L320,150 L375,130 L435,100 L500,75 L565,58 L635,51 L715,48 L785,55 Z" />
      <!-- Hainan & Taiwan schematic dots -->
      <circle cx="560" cy="585" r="14" />
      <circle cx="725" cy="510" r="16" />
      
      <!-- South China Sea Schematic -->
      <path d="M680,620 Q700,640 695,680" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="3 3" />
      <path d="M730,650 Q750,670 735,710" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="3 3" />
      <path d="M625,650 Q615,680 595,700" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="3 3" />
    </svg>

    <!-- Overlay Nodes & Hover Tooltips with Precise Geographical Coordinates (%) -->
    {siteData.networkMap.map((point) => (
      <div 
        class="absolute z-10 flex items-center justify-center -translate-x-1/2 -translate-y-1/2 transition-all duration-300"
        style={`left: ${point.x}%; top: ${point.y}%;`}
      >
        <!-- The Node Dot -->
        <div class="relative w-8 h-8 group">
          <div class="absolute inset-0 m-auto w-3 h-3 bg-accent rounded-full border-2 border-surface shadow-sm cursor-pointer group-hover:scale-[2] group-hover:bg-ink-deep transition-all duration-300 z-20 peer"></div>
          
          <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 whitespace-nowrap text-[12px] font-bold text-ink-deep pointer-events-none opacity-60 group-hover:opacity-0 transition-opacity">
            {point.city}
          </div>

          <!-- Hover Metadata Card -->
          <div class:list={[
            "absolute opacity-0 pointer-events-none group-hover:opacity-100 peer-hover:opacity-100 transition-all duration-500 flex z-50",
            point.dir === "left" && "right-full mr-0 top-1/2 -translate-y-1/2 flex-row-reverse",
            point.dir === "right" && "left-full ml-0 top-1/2 -translate-y-1/2 flex-row",
            point.dir === "top" && "bottom-full mb-0 left-1/2 -translate-x-1/2 flex-col-reverse",
            point.dir === "bottom" && "top-full mt-0 left-1/2 -translate-x-1/2 flex-col",
          ]}>
            
            <div class:list={[
              "bg-accent/40 shrink-0 z-0",
              (point.dir === "left" || point.dir === "right") && "w-16 h-[1px] my-auto",
              (point.dir === "top" || point.dir === "bottom") && "h-16 w-[1px] mx-auto"
            ]}></div>

            <div class="bg-surface/95 backdrop-blur-md border border-border shadow-[0_16px_60px_rgba(16,33,50,0.18)] p-5 rounded-2xl w-[280px] flex flex-col shrink-0 z-10 scale-95 group-hover:scale-100 transition-all duration-300">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-[12px] font-bold text-accent px-2 py-0.5 bg-accent/5 rounded tracking-widest">{point.city}</span>
                <span class="text-[11px] font-[750] text-text-muted/50 uppercase flex-1 text-right">{point.label}</span>
              </div>
              <h4 class="text-[17px] font-[800] text-ink-deep leading-[1.3] mb-4 text-balance">{point.institution}</h4>
              <div class="mt-auto flex items-center justify-between pt-4 border-t border-border/40">
                <span class="text-[13px] font-semibold text-text-secondary">贡献样本数</span>
                <span class="text-[14px] font-extrabold text-accent">{point.count}</span>
              </div>
            </div>
            
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
