---
import { siteData } from "../data/site";
---

<div class="w-full h-full relative p-4 flex items-center justify-center">
  <div class="relative w-full aspect-[5/3.5] max-w-4xl mx-auto flex items-center justify-center">
    
    <!-- More recognizable simplified China silhouette -->
    <svg viewBox="0 0 850 650" class="w-full h-full text-border drop-shadow-sm opacity-40 shrink-0" fill="currentColor">
      <path d="M685 105 Q705 95 725 110 T745 135 T760 170 T775 220 Q785 260 760 290 Q770 330 755 365 Q740 390 715 415 Q700 435 680 445 Q670 470 650 495 Q630 510 600 525 Q570 550 540 575 Q515 600 480 595 Q450 605 420 595 Q380 600 340 585 Q310 575 290 545 Q260 550 220 535 Q190 520 170 500 Q140 475 125 435 Q120 405 100 380 Q90 350 110 320 Q130 285 170 260 Q190 245 220 250 Q255 255 290 220 Q315 195 340 210 Q370 225 395 200 Q420 180 445 185 Q470 190 495 180 Q520 170 545 185 Q570 195 595 175 Q620 155 645 145 Q665 135 675 140 Q685 125 685 105 Z" />
    </svg>

    <!-- Overlay Nodes & Hover Tooltips -->
    {siteData.networkMap.map((point) => (
      <div 
        class="absolute z-10 flex items-center justify-center -translate-x-1/2 -translate-y-1/2"
        style={`left: ${point.x}%; top: ${point.y}%;`}
      >
        <!-- The Node Dot -->
        <div class="relative w-6 h-6 group">
          <div class="absolute inset-0 m-auto w-3 h-3 bg-accent rounded-full border-2 border-surface shadow-sm cursor-pointer group-hover:scale-[1.6] group-hover:bg-ink-deep transition-all duration-300 z-20 peer"></div>

          <!-- Vertical/Horizontal Leader Line + Tooltip -->
          <div class:list={[
            "absolute opacity-0 pointer-events-none peer-hover:opacity-100 group-hover:opacity-100 transition-all duration-500 flex z-30",
            point.dir === "left" && "right-full mr-0 top-1/2 -translate-y-1/2 flex-row-reverse",
            point.dir === "right" && "left-full ml-0 top-1/2 -translate-y-1/2 flex-row",
            point.dir === "top" && "bottom-full mb-0 left-1/2 -translate-x-1/2 flex-col-reverse",
            point.dir === "bottom" && "top-full mt-0 left-1/2 -translate-x-1/2 flex-col",
          ]}>
            
            <!-- Thin Leader Line -->
            <div class:list={[
              "bg-accent/40 shrink-0 z-0 transition-all duration-500",
              (point.dir === "left" || point.dir === "right") && "w-12 h-[1px] my-auto",
              (point.dir === "top" || point.dir === "bottom") && "h-12 w-[1px] mx-auto"
            ]}></div>

            <!-- Content Card (Fixed Outward) -->
            <div class="bg-surface/95 backdrop-blur-md border border-border/80 shadow-[0_8px_32px_rgba(16,33,50,0.12)] p-4 rounded-xl w-[240px] flex flex-col shrink-0 z-10 scale-95 group-hover:scale-100 transition-transform duration-300">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-[11px] font-bold text-accent uppercase tracking-[0.1em]">{point.city}</span>
                <div class="h-[1px] bg-border/50 flex-1"></div>
                <span class="text-[10px] font-bold text-text-muted/60 uppercase">{point.label}</span>
              </div>
              <span class="text-[15px] font-[700] text-ink-deep leading-snug mb-3">{point.institution}</span>
              <div class="mt-auto pt-3 border-t border-border/40 flex items-center justify-between">
                <span class="text-[12px] font-medium text-text-secondary">贡献样本数</span>
                <span class="text-[13px] font-bold text-accent">{point.count}</span>
              </div>
            </div>
            
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
