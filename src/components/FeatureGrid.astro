---
type Feature = {
  label?: string;
  title: string;
  description: string;
};

type Props = {
  items: Feature[];
  numbered?: boolean;
};

const { items, numbered = false } = Astro.props;
---

<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
  {items.map((item, index) => (
    <article class:list={["surface-card reveal p-6", index % 3 === 1 ? "delay-1" : index % 3 === 2 ? "delay-2" : ""]}>
      <div class="flex items-start gap-4">
        <span class:list={[
          "flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl text-sm font-semibold",
          numbered ? "bg-ink-950 text-white" : "bg-sage-500/12 text-sage-500",
        ]}>
          {numbered ? String(index + 1).padStart(2, "0") : item.label ? item.label.slice(0, 2) : "•"}
        </span>
        <div>
          {item.label && !numbered && <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sage-500">{item.label}</p>}
          <h3 class="mt-1 font-serif text-2xl font-semibold tracking-tight text-ink-950">{item.title}</h3>
          <p class="mt-3 text-base leading-7 text-ink-700">{item.description}</p>
        </div>
      </div>
    </article>
  ))}
</div>
