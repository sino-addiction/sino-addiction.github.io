---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"publications">;
};

const { entry } = Astro.props;
---

<article class="surface-card reveal p-6 md:p-7">
  <div class="flex flex-wrap gap-2">
    {entry.data.tags.map((tag) => (
      <span class="status-badge status-available">{tag}</span>
    ))}
  </div>
  <h3 class="zh-heading mt-5 font-serif text-2xl leading-8 font-bold tracking-tight text-primary-900">{entry.data.title}</h3>
  <p class="mt-3 text-base leading-7 text-secondary-600">{entry.data.authors}</p>
  <p class="mt-3 text-sm font-medium uppercase tracking-[0.08em] text-muted-500">
    {entry.data.journal} · {entry.data.year}
  </p>
  {entry.body && <p class="mt-5 text-base leading-7 text-secondary-600">{entry.body}</p>}
  <div class="mt-6 flex flex-wrap items-center gap-4">
    {entry.data.doi && <span class="text-sm font-medium text-secondary-600">DOI: {entry.data.doi}</span>}
    {entry.data.externalUrl && (
      <a href={entry.data.externalUrl} class="btn-link" target="_blank" rel="noreferrer">
        查看详情
        <span aria-hidden="true">↗</span>
      </a>
    )}
  </div>
</article>
