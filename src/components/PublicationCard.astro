---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"publications">;
};

const { entry } = Astro.props;
---

<article class="surface-card reveal p-6 md:p-7">
  <div class="flex flex-wrap gap-2">
    {entry.data.tags.map((tag) => (
      <span class="rounded-full border border-sage-500/18 bg-sage-500/8 px-3 py-1 text-xs font-semibold text-sage-500">{tag}</span>
    ))}
  </div>
  <h3 class="mt-5 font-serif text-2xl font-semibold tracking-tight text-ink-950">{entry.data.title}</h3>
  <p class="mt-3 text-base leading-7 text-ink-700">{entry.data.authors}</p>
  <p class="mt-3 text-sm font-medium uppercase tracking-[0.16em] text-ink-700">
    {entry.data.journal} · {entry.data.year}
  </p>
  {entry.body && <p class="mt-5 text-base leading-7 text-ink-700">{entry.body}</p>}
  <div class="mt-6 flex flex-wrap items-center gap-4">
    {entry.data.doi && <span class="text-sm font-medium text-ink-800">DOI: {entry.data.doi}</span>}
    {entry.data.externalUrl && (
      <a
        href={entry.data.externalUrl}
        class="inline-flex items-center gap-2 rounded-full border border-ink-900/10 px-4 py-2 text-sm font-semibold text-ink-900 hover:border-sage-500/30 hover:bg-sage-500/8 hover:text-sage-500"
        target="_blank"
        rel="noreferrer"
      >
        查看详情
        <span aria-hidden="true">↗</span>
      </a>
    )}
  </div>
</article>
