---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"news">;
};

const { entry } = Astro.props;
const formattedDate = entry.data.date.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="surface-card group flex h-full flex-col p-7 hover:shadow-md transition-shadow">
  <p class="text-[12px] font-bold text-text-muted uppercase tracking-wider mb-4 border-l-2 border-accent pl-2">{formattedDate}</p>
  <h3 class="card-title line-clamp-2 hover:text-accent transition-colors leading-[1.4]">
    <a href={`/news/${entry.data.slug}/`} class="outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-sm">
      {entry.data.title}
    </a>
  </h3>
  <p class="mt-4 flex-1 text-[15px] leading-relaxed text-text-secondary line-clamp-3">
    {entry.data.summary}
  </p>
  <div class="mt-6 pt-5 border-t border-border/60">
    <a href={`/news/${entry.data.slug}/`} class="btn-link text-[13px] font-semibold hover:text-accent transition-colors inline-block">
      阅读更多
      <span aria-hidden="true" class="ml-1 opacity-70">→</span>
    </a>
  </div>
</article>
