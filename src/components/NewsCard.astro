---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"news">;
};

const { entry } = Astro.props;
const formattedDate = entry.data.date.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="surface-card reveal group flex h-full flex-col overflow-hidden p-6">
  <p class="text-sm font-medium text-muted-500">{formattedDate}</p>
  <h3 class="zh-heading mt-4 font-serif text-2xl leading-8 font-bold tracking-tight text-primary-900">
    <a href={`/news/${entry.data.slug}/`} class="hover:text-accent-700">{entry.data.title}</a>
  </h3>
  <p class="mt-4 flex-1 text-base leading-7 text-secondary-600">{entry.data.summary}</p>
  <div class="mt-6">
    <a href={`/news/${entry.data.slug}/`} class="btn-link">
      阅读更多
      <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
