---
type Metric = {
  label: string;
  value: string;
};

type Props = {
  items: Metric[];
};

const { items } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
  {items.map((item, index) => (
    <article class:list={["surface-card reveal p-5", index % 5 === 1 ? "delay-1" : index % 5 === 2 ? "delay-2" : index % 5 === 3 ? "delay-3" : ""]}>
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ink-700">指标</p>
      <p class="mt-4 font-serif text-3xl font-semibold text-ink-950">{item.value}</p>
      <p class="mt-3 text-base leading-7 text-ink-800">{item.label}</p>
    </article>
  ))}
</div>
