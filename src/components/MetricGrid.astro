---
type Metric = {
  name: string;
  status: string;
  note: string;
};

type Props = {
  items: Metric[];
};

const { items } = Astro.props;

const getStatusClass = (status: string) => {
  if (status === "available") return "status-available";
  if (status === "integrating") return "status-integrating";
  return "status-planned";
};
---

<div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
  {items.map((item, index) => (
    <article class:list={["surface-card reveal h-full p-6", index % 3 === 1 ? "delay-1" : index % 3 === 2 ? "delay-2" : ""]}>
      <div class="flex items-start justify-between gap-3">
        <h3 class="zh-heading font-serif text-2xl leading-8 font-bold text-primary-900">{item.name}</h3>
        <span class:list={["status-badge", getStatusClass(item.status)]}>
          {item.status === "available" ? "可用" : item.status === "integrating" ? "整合中" : "规划中"}
        </span>
      </div>
      <p class="mt-4 text-sm leading-6 text-secondary-600">{item.note}</p>
    </article>
  ))}
</div>
