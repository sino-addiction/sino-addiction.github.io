---
type Metric = {
  name: string;
  status: string;
  note: string;
};

type Props = {
  items: Metric[];
};

const { items } = Astro.props;

const getStatusClass = (status: string) => {
  if (status === "available") return "status-available";
  if (status === "integrating") return "status-integrating";
  return "status-planned";
};
---

<div class="grid gap-4 auto-rows-fr">
  {items.map((item, index) => (
    <article class="surface-card p-5 h-full flex flex-col justify-center w-full">
      <div class="flex items-center justify-between gap-3">
        <h3 class="card-title text-[18px] line-clamp-1 m-0">{item.name}</h3>
        <span class:list={["status-badge shrink-0", getStatusClass(item.status)]}>
          {item.status === "available" ? "可用" : item.status === "integrating" ? "整合中" : "规划中"}
        </span>
      </div>
      <p class="mt-3 text-[14px] leading-relaxed text-text-secondary w-full">{item.note}</p>
    </article>
  ))}
</div>
