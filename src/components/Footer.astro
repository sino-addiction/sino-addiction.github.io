---
import { siteData } from "../data/site";
---

<footer class="bg-surface-alt border-t border-border mt-12 pb-10 pt-16">
  <div class="page-wrap">
    <div class="grid gap-10 lg:grid-cols-[1.4fr_1fr] lg:items-start">
      <div>
        <h2 class="font-serif text-[22px] lg:text-[26px] leading-snug font-bold text-ink-deep">
          Sino-Addiction Neuroimaging Initiatives
        </h2>
        <p class="mt-4 max-w-2xl text-[15px] leading-[1.7] text-text-secondary">
          {siteData.description}
        </p>
      </div>

      <div class="space-y-6">
        <div class="flex flex-col">
          <p class="text-[13px] font-semibold text-text-muted uppercase tracking-wider mb-2">公共联络邮箱</p>
          <a href={`mailto:${siteData.contact.email}`} class="text-[18px] font-semibold text-accent hover:text-accent-hover transition-colors">
            {siteData.contact.email}
          </a>
          <p class="mt-2 text-[14px] leading-relaxed text-text-secondary opacity-90">{siteData.contact.note}</p>
        </div>

        <div class="flex flex-wrap gap-4 pt-4 border-t border-border/70">
          {siteData.footerLinks.map((link) => (
            <a href={link.href} class="text-[14px] font-medium text-text-secondary hover:text-ink-deep transition-colors" target={link.external ? "_blank" : undefined} rel={link.external ? "noreferrer" : undefined}>
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-3 border-t border-border/70 pt-6 text-[13px] text-text-muted md:flex-row md:items-center md:justify-between">
      <p>&copy; {new Date().getFullYear()} {siteData.siteName} ({siteData.siteShortName}).</p>
      <p>Powered by Astro.</p>
    </div>
  </div>
</footer>
