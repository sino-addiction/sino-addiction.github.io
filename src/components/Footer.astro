---
import { siteData } from "../data/site";
---

<footer class="page-wrap pb-8 pt-14">
  <div class="section-frame px-6 py-9 md:px-9">
    <div class="grid gap-8 lg:grid-cols-[1.4fr_1fr] lg:items-end">
      <div>
        <p class="eyebrow">SANI Network</p>
        <h2 class="zh-heading mt-5 max-w-3xl font-serif text-[2rem] leading-[2.5rem] font-bold text-primary-900">
          以标准化、可复现和多中心协作为核心，建设更可信的成瘾神经影像研究基础设施。
        </h2>
        <p class="mt-4 max-w-2xl text-base leading-7 text-secondary-600">
          站点提供联盟机制、项目流程、研究成果和加入方式的公开信息，后续将持续更新数据治理与协作资源。
        </p>
      </div>

      <div class="space-y-5">
        <div class="surface-card p-5">
          <p class="text-sm font-semibold text-muted-500">联系邮箱</p>
          <a href={`mailto:${siteData.contact.email}`} class="mt-2 block text-lg font-semibold text-accent-700 hover:text-accent-600">
            {siteData.contact.email}
          </a>
          <p class="mt-2 text-sm leading-6 text-secondary-600">{siteData.contact.note}</p>
        </div>

        <div class="flex flex-wrap gap-2">
          {siteData.footerLinks.map((link) => (
            <a href={link.href} class="btn-secondary !h-10 !px-4" target={link.external ? "_blank" : undefined} rel={link.external ? "noreferrer" : undefined}>
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-8 flex flex-col gap-3 border-t border-border-200 pt-5 text-sm text-muted-500 md:flex-row md:items-center md:justify-between">
      <p>&copy; 2026 {siteData.siteName} ({siteData.siteShortName}).</p>
      <p>Static site powered by Astro.</p>
    </div>
  </div>
</footer>
