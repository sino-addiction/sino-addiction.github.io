---
type IconName = "upload" | "check" | "share" | "database" | "play" | "users" | "sliders" | "shield" | "network" | "workflow" | "chart";

type Props = {
  name: IconName;
  class?: string;
};

const { name, class: className = "" } = Astro.props;
---

{
  name === "upload" ? (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <path d="M12 16V4" />
      <path d="m8 8 4-4 4 4" />
      <path d="M5 16.5V19a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5" />
      <path d="M7 16.5h10" />
    </svg>
  ) : name === "check" ? (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <path d="M20 6 9 17l-5-5" />
      <path d="M12 3.5a8.5 8.5 0 1 0 0 17 8.5 8.5 0 0 0 0-17Z" />
    </svg>
  ) : name === "share" ? (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <circle cx="6" cy="6" r="1.8" />
      <circle cx="18" cy="6" r="1.8" />
      <circle cx="12" cy="18" r="1.8" />
      <path d="M7.4 7.2 11 16" />
      <path d="m16.6 7.2-3.7 1.8" />
      <path d="M8 6.7h8" />
    </svg>
  ) : name === "database" ? (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <ellipse cx="12" cy="5.5" rx="6.5" ry="2.75" />
      <path d="M5.5 5.5v6.2c0 1.5 2.9 2.8 6.5 2.8s6.5-1.3 6.5-2.8V5.5" />
      <path d="M5.5 11.7v6.2c0 1.5 2.9 2.8 6.5 2.8s6.5-1.3 6.5-2.8v-6.2" />
    </svg>
  ) : name === "users" ? (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <circle cx="9" cy="8" r="3" />
      <path d="M3.8 19c.7-3.2 2.5-5 5.2-5s4.5 1.8 5.2 5" />
      <path d="M15 10.2a2.6 2.6 0 1 0 0-5" />
      <path d="M15.5 14.2c2.3.4 3.8 2 4.4 4.8" />
    </svg>
  ) : name === "sliders" ? (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <path d="M4 6h16" />
      <path d="M4 12h16" />
      <path d="M4 18h16" />
      <circle cx="8" cy="6" r="2" />
      <circle cx="15" cy="12" r="2" />
      <circle cx="11" cy="18" r="2" />
    </svg>
  ) : name === "shield" ? (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <path d="M12 3.5 19 6v5.2c0 4.2-2.5 7.3-7 9.3-4.5-2-7-5.1-7-9.3V6l7-2.5Z" />
      <path d="m8.8 12 2.1 2.1 4.4-4.7" />
    </svg>
  ) : name === "network" ? (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <circle cx="6" cy="7" r="2.3" />
      <circle cx="18" cy="7" r="2.3" />
      <circle cx="12" cy="17" r="2.3" />
      <path d="m8 8.4 2.5 6.1" />
      <path d="m16 8.4-2.5 6.1" />
      <path d="M8.4 7h7.2" />
    </svg>
  ) : name === "workflow" ? (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <rect x="4" y="4.5" width="5" height="5" rx="1.2" />
      <rect x="15" y="4.5" width="5" height="5" rx="1.2" />
      <rect x="9.5" y="14.5" width="5" height="5" rx="1.2" />
      <path d="M9 7h6" />
      <path d="M7 9.5v2.2c0 1.7 1.2 3.1 2.7 3.8" />
      <path d="M17 9.5v2.2c0 1.7-1.2 3.1-2.7 3.8" />
    </svg>
  ) : name === "chart" ? (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <path d="M4 19.5h16" />
      <path d="M6.5 16v-4" />
      <path d="M12 16V7.5" />
      <path d="M17.5 16v-7" />
      <path d="m6.5 10.5 4-3.2 3.1 2.4 3.9-4.2" />
    </svg>
  ) : (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class:list={["shrink-0", className]}
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    >
      <circle cx="12" cy="12" r="8.5" />
      <path d="M10 8.75 16 12l-6 3.25Z" fill="currentColor" stroke="none" />
    </svg>
  )
}
