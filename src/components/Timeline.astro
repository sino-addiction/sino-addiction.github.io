---
type Step = {
  title: string;
  description: string;
};

type Props = {
  steps: Step[];
};

const { steps } = Astro.props;
---

<div class="relative mt-8">
  <div class="space-y-6">
    {steps.map((step, index) => (
      <article class="surface-card flex flex-col md:flex-row md:items-start gap-6 p-6 md:p-8">
        <div class="flex items-center gap-4 md:w-1/4 shrink-0">
          <span class="inline-flex h-10 min-w-10 items-center justify-center rounded-lg bg-ink-deep text-[15px] font-bold text-white shadow-sm">
            {String(index + 1).padStart(2, "0")}
          </span>
          <div class="h-px w-12 bg-border md:hidden"></div>
        </div>
        <div class="flex-1">
          <h3 class="card-title text-ink-deep m-0 leading-snug">{step.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-text-secondary">{step.description}</p>
        </div>
      </article>
    ))}
  </div>
</div>
