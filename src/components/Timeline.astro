---
type Step = {
  title: string;
  description: string;
};

type Props = {
  steps: Step[];
};

const { steps } = Astro.props;
---

<div class="relative mt-10">
  <div class="space-y-6">
    {steps.map((step, index) => (
      <article class:list={["surface-card reveal p-6 md:p-7", index % 3 === 1 ? "delay-1" : index % 3 === 2 ? "delay-2" : ""]}>
        <div class="flex items-center gap-3">
          <span class="inline-flex h-9 min-w-9 items-center justify-center rounded-lg bg-primary-900 px-2 text-sm font-semibold text-white">
            {String(index + 1).padStart(2, "0")}
          </span>
          <div class="h-px flex-1 bg-border-200"></div>
        </div>
        <h3 class="zh-heading mt-5 font-serif text-2xl leading-8 font-bold text-primary-900">{step.title}</h3>
        <p class="mt-3 text-base leading-7 text-secondary-600">{step.description}</p>
      </article>
    ))}
  </div>
</div>
