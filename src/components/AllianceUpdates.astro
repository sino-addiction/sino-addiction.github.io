---
import SectionHeading from "./SectionHeading.astro";

type UpdateType = "新闻" | "项目" | "成果";

type UpdateItem = {
  type: UpdateType;
  title: string;
  summary: string;
  meta: string;
  href: string;
};

type Props = {
  items: UpdateItem[];
};

const { items } = Astro.props;
---

<section class="page-wrap section-shell pt-8">
  <div class="updates-shell">
    <SectionHeading
      eyebrow="Alliance Updates"
      title="联盟动态"
      description="聚合新闻、项目与研究成果，统一展示联盟近期工作进展。"
    />

    <div class="mt-8 flex flex-wrap items-center justify-between gap-3">
      <div class="flex flex-wrap gap-2" data-updates-filter>
        <button type="button" class="updates-filter is-active" data-filter="全部">全部</button>
        <button type="button" class="updates-filter" data-filter="新闻">新闻</button>
        <button type="button" class="updates-filter" data-filter="项目">项目</button>
        <button type="button" class="updates-filter" data-filter="成果">成果</button>
      </div>
      <div class="flex items-center gap-2">
        <button type="button" class="updates-nav-btn" data-updates-prev aria-label="上一组">‹</button>
        <button type="button" class="updates-nav-btn" data-updates-next aria-label="下一组">›</button>
      </div>
    </div>

    <div class="updates-track-wrap mt-6" data-updates-track>
      {items.map((item, index) => (
        <article class:list={["updates-card", index % 3 === 1 ? "delay-1" : index % 3 === 2 ? "delay-2" : "", "reveal"]} data-update-type={item.type}>
          <span class="status-badge status-integrating">{item.type}</span>
          <h3 class="zh-heading mt-4 font-serif text-2xl leading-8 font-bold text-primary-900">{item.title}</h3>
          <p class="mt-3 text-sm text-muted-500">{item.meta}</p>
          <p class="mt-4 flex-1 text-base leading-7 text-secondary-600">{item.summary}</p>
          <a href={item.href} class="btn-link mt-5">
            查看详情
            <span aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const track = document.querySelector("[data-updates-track]");
    if (!track) return;

    const prevBtn = document.querySelector("[data-updates-prev]");
    const nextBtn = document.querySelector("[data-updates-next]");
    const filterButtons = document.querySelectorAll("[data-filter]");

    const step = () => Math.max(track.clientWidth * 0.86, 280);

    prevBtn?.addEventListener("click", () => {
      track.scrollBy({ left: -step(), behavior: "smooth" });
    });

    nextBtn?.addEventListener("click", () => {
      track.scrollBy({ left: step(), behavior: "smooth" });
    });

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const target = button.getAttribute("data-filter");
        const cards = track.querySelectorAll("[data-update-type]");

        filterButtons.forEach((btn) => btn.classList.remove("is-active"));
        button.classList.add("is-active");

        cards.forEach((card) => {
          const type = card.getAttribute("data-update-type");
          if (target === "全部" || target === type) {
            card.removeAttribute("hidden");
          } else {
            card.setAttribute("hidden", "hidden");
          }
        });

        track.scrollTo({ left: 0, behavior: "smooth" });
      });
    });
  })();
</script>
