---
import { siteData } from "../data/site";
import { downloadEntries } from "../data/downloads";

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;

const isActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }

  return currentPath.startsWith(href);
};

const navigationLinks = siteData.navigation.filter((item) => !item.hidden);
---

<header class="site-header" data-site-header>
  <div class="nav-frame">
    <div class="hidden h-full w-full items-center justify-between lg:flex lg:gap-8">
      <a href="/" class="inline-flex items-center gap-4 shrink-0 hover:opacity-90 transition-opacity">
        <img src="/assets/logo-mark.png" alt="SANI" class="h-14 w-14 object-contain" />
        <span class="min-w-0 flex flex-col justify-center">
          <span class="block font-serif text-[20px] font-bold leading-tight text-ink-deep">{siteData.siteShortName}</span>
          <span class="block text-[11px] font-[600] uppercase tracking-[0.06em] text-text-muted mt-[2px] leading-[1.2] whitespace-nowrap">
            Sino-Addiction<br/>Neuroimaging Initiatives
          </span>
        </span>
      </a>

      <nav aria-label="主导航" class="min-w-0 h-full flex-1 flex justify-center">
        <ul class="flex min-w-0 items-center justify-center gap-2 whitespace-nowrap h-full">
          {navigationLinks.map((item) => (
            <li class="h-full flex items-center">
              <a href={item.href} class:list={["nav-link", isActive(item.href) ? "nav-link-active" : ""]}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="flex justify-end shrink-0 items-center gap-3">
        <details class="nav-download hidden lg:block" data-download-menu>
          <summary class="btn-secondary nav-download-trigger whitespace-nowrap">
            下载
            <svg
              class="nav-download-chevron"
              width="14"
              height="14"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </summary>

          <div class="nav-download-menu">
            {downloadEntries.map((item) => (
              <a
                href={item.href}
                download={item.filename}
                class="nav-download-item"
                title={item.description}
              >
                <span>{item.label}</span>
                <span aria-hidden="true">↓</span>
              </a>
            ))}
          </div>
        </details>

        <a href="/join-us" class="btn-primary whitespace-nowrap">
          加入我们
        </a>
      </div>
    </div>

    <details class="group py-4 w-full lg:hidden">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
        <span class="inline-flex items-center gap-3">
          <img src="/assets/logo-mark.png" alt="SANI" class="h-12 w-12 object-contain" />
          <span class="font-serif text-[20px] font-bold leading-none text-ink-deep">{siteData.siteShortName}</span>
        </span>
        <span class="btn-secondary px-4 text-xs h-9">菜单</span>
      </summary>

      <div class="mt-4 border-t border-border pt-4">
        <nav aria-label="移动端主导航">
          <ul class="grid gap-1">
            {navigationLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "flex min-h-11 items-center rounded-lg px-3 text-[15px] font-medium transition-colors",
                    isActive(item.href)
                      ? "bg-surface-alt text-ink-deep border border-border"
                      : "text-text-secondary hover:bg-surface-alt hover:text-ink-deep",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li>
              <details class="nav-mobile-download" data-download-menu>
                <summary class="nav-mobile-download-trigger">
                  <span>下载</span>
                  <svg
                    class="nav-download-chevron"
                    width="14"
                    height="14"
                    viewBox="0 0 20 20"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </summary>

                <div class="nav-mobile-download-menu">
                  {downloadEntries.map((item) => (
                    <a
                      href={item.href}
                      download={item.filename}
                      class="nav-mobile-download-item"
                      title={item.description}
                    >
                      <span>{item.label}</span>
                      <span aria-hidden="true">↓</span>
                    </a>
                  ))}
                </div>
              </details>
            </li>
            <li>
                <a href="/join-us" class="flex mt-3 justify-center items-center w-full btn-primary h-11 text-sm">加入我们</a>
            </li>
          </ul>
        </nav>
      </div>
    </details>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector("[data-site-header]");
    if (!header) return;

    const downloadMenus = Array.from(header.querySelectorAll("[data-download-menu]"));

    const closeMenus = (activeMenu) => {
      downloadMenus.forEach((menu) => {
        if (menu !== activeMenu) {
          menu.removeAttribute("open");
        }
      });
    };

    downloadMenus.forEach((menu) => {
      menu.addEventListener("toggle", () => {
        if (menu.hasAttribute("open")) {
          closeMenus(menu);
        }
      });
    });

    header.querySelectorAll("[data-download-menu] a").forEach((link) => {
      link.addEventListener("click", () => {
        downloadMenus.forEach((menu) => menu.removeAttribute("open"));
      });
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (!header.contains(target)) {
        downloadMenus.forEach((menu) => menu.removeAttribute("open"));
        return;
      }

      const clickedMenu = downloadMenus.find((menu) => menu.contains(target));
      if (clickedMenu) {
        closeMenus(clickedMenu);
        return;
      }

      downloadMenus.forEach((menu) => menu.removeAttribute("open"));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        downloadMenus.forEach((menu) => menu.removeAttribute("open"));
      }
    });

    const handleScroll = () => {
      if (window.scrollY > 12) {
        header.classList.add("is-scrolled");
      } else {
        header.classList.remove("is-scrolled");
      }
    };
    handleScroll();
    window.addEventListener("scroll", handleScroll, { passive: true });
  })();
</script>
