---
import { siteData } from "../data/site";

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;

const isActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }

  return currentPath.startsWith(href);
};
---

<header class="site-header px-4 md:px-6" data-site-header>
  <div class="nav-frame">
    <div class="hidden h-full items-center lg:grid lg:grid-cols-[260px_minmax(0,1fr)_190px] lg:gap-6">
      <a href="/" class="inline-flex items-center gap-3">
        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary-900 text-sm font-bold text-white">SA</span>
        <span class="min-w-0">
          <span class="block font-serif text-[1.35rem] font-bold leading-6 text-primary-900">{siteData.siteShortName}</span>
          <span class="block truncate text-[11px] font-medium uppercase tracking-[0.08em] text-muted-500">Sino Addiction Neuroimaging Initiative</span>
        </span>
      </a>

      <nav aria-label="主导航" class="min-w-0">
        <ul class="flex min-w-0 items-center justify-center gap-1 whitespace-nowrap">
          {siteData.navigation.map((item) => (
            <li>
              <a href={item.href} class:list={["nav-link", isActive(item.href) ? "nav-link-active" : ""]}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="flex justify-end">
        {siteData.portal.available && siteData.portal.href ? (
          <a href={siteData.portal.href} class="btn-secondary">
            {siteData.portal.label}
          </a>
        ) : (
          <span class="inline-flex h-11 items-center rounded-full border border-border-200 bg-surface-0 px-4 text-sm font-semibold text-secondary-600">
            {siteData.portal.label} · 即将开放
          </span>
        )}
      </div>
    </div>

    <details class="group py-4 lg:hidden">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
        <span class="inline-flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-900 text-sm font-bold text-white">SA</span>
          <span class="font-serif text-2xl font-bold leading-none text-primary-900">{siteData.siteShortName}</span>
        </span>
        <span class="btn-secondary px-4">菜单</span>
      </summary>

      <div class="mt-4 border-t border-border-200 pt-4">
        <nav aria-label="移动端主导航">
          <ul class="grid gap-1">
            {siteData.navigation.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "flex min-h-11 items-center rounded-lg px-3 text-base font-medium",
                    isActive(item.href)
                      ? "bg-soft-100 text-primary-900"
                      : "text-secondary-600 hover:bg-soft-100 hover:text-primary-900",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <p class="mt-4 rounded-lg border border-border-200 bg-surface-0 px-4 py-3 text-sm leading-6 text-secondary-600">{siteData.portal.note}</p>
      </div>
    </details>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector("[data-site-header]");
    if (!header) return;
    const handleScroll = () => {
      if (window.scrollY > 12) {
        header.classList.add("is-scrolled");
      } else {
        header.classList.remove("is-scrolled");
      }
    };
    handleScroll();
    window.addEventListener("scroll", handleScroll, { passive: true });
  })();
</script>
