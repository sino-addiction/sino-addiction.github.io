---
import { siteData } from "../data/site";

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;

const isActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }

  return currentPath.startsWith(href);
};
---

<header class="sticky top-0 z-50 px-4 pt-4 md:px-6">
  <div class="mx-auto max-w-7xl rounded-[1.65rem] border border-white/70 bg-white/70 px-5 py-4 shadow-[0_18px_40px_rgba(15,34,49,0.08)] backdrop-blur">
    <div class="hidden items-center justify-between gap-8 lg:flex">
      <a href="/" class="group flex items-center gap-4">
        <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-ink-950 text-lg font-semibold text-white shadow-[0_10px_30px_rgba(8,19,29,0.28)]">SA</span>
        <div>
          <p class="font-serif text-2xl font-semibold tracking-tight text-ink-950">{siteData.siteShortName}</p>
          <p class="text-sm tracking-[0.22em] text-ink-700 uppercase">Sino Addiction Neuroimaging Initiative</p>
        </div>
      </a>

      <nav aria-label="主导航">
        <ul class="flex items-center gap-2">
          {siteData.navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "rounded-full px-4 py-2 text-sm font-medium",
                  isActive(item.href)
                    ? "bg-ink-950 text-white shadow-[0_10px_24px_rgba(8,19,29,0.18)]"
                    : "text-ink-800 hover:bg-white hover:text-ink-950",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {siteData.portal.available && siteData.portal.href ? (
        <a
          href={siteData.portal.href}
          class="rounded-full border border-sage-400/35 bg-sage-500 px-5 py-2.5 text-sm font-semibold text-white shadow-[0_10px_24px_rgba(29,143,133,0.24)] hover:-translate-y-0.5 hover:bg-sage-400"
        >
          {siteData.portal.label}
        </a>
      ) : (
        <span class="rounded-full border border-ink-900/10 bg-mist-50 px-5 py-2.5 text-sm font-semibold text-ink-700">
          {siteData.portal.label} · 即将开放
        </span>
      )}
    </div>

    <details class="group lg:hidden">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
        <span class="flex items-center gap-3">
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-ink-950 font-semibold text-white">SA</span>
          <span>
            <span class="block font-serif text-xl font-semibold tracking-tight text-ink-950">{siteData.siteShortName}</span>
            <span class="block text-xs tracking-[0.22em] text-ink-700 uppercase">SANI</span>
          </span>
        </span>
        <span class="rounded-full border border-ink-900/10 px-4 py-2 text-sm font-medium text-ink-800 group-open:bg-ink-950 group-open:text-white">菜单</span>
      </summary>

      <div class="mt-4 space-y-4 border-t border-ink-900/10 pt-4">
        <nav aria-label="移动端主导航">
          <ul class="grid gap-2">
            {siteData.navigation.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "block rounded-2xl px-4 py-3 text-sm font-medium",
                    isActive(item.href)
                      ? "bg-ink-950 text-white"
                      : "bg-white text-ink-800 hover:bg-mist-50",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="rounded-2xl border border-ink-900/10 bg-mist-50 px-4 py-3 text-sm text-ink-700">
          <p class="font-semibold text-ink-900">{siteData.portal.label}</p>
          <p class="mt-1">{siteData.portal.note}</p>
        </div>
      </div>
    </details>
  </div>
</header>
