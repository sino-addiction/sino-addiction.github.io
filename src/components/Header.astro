---
import { siteData } from "../data/site";

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;

const isActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }

  return currentPath.startsWith(href);
};

const navigationLinks = siteData.navigation.filter((item) => !item.hidden);
---

<header class="site-header" data-site-header>
  <div class="nav-frame">
    <div class="hidden h-full w-full items-center justify-between lg:flex lg:gap-8">
      <a href="/" class="inline-flex items-center gap-4 shrink-0 hover:opacity-90 transition-opacity">
        <img src="/assets/logo-mark.png" alt="SANI" class="h-14 w-14 object-contain" />
        <span class="min-w-0 flex flex-col justify-center">
          <span class="block font-serif text-[20px] font-bold leading-tight text-ink-deep">{siteData.siteShortName}</span>
          <span class="block text-[11px] font-[600] uppercase tracking-[0.06em] text-text-muted mt-[2px] leading-[1.2] whitespace-nowrap">
            Sino-Addiction<br/>Neuroimaging Initiatives
          </span>
        </span>
      </a>

      <nav aria-label="主导航" class="min-w-0 h-full flex-1 flex justify-center">
        <ul class="flex min-w-0 items-center justify-center gap-2 whitespace-nowrap h-full">
          {navigationLinks.map((item) => (
            <li class="h-full flex items-center">
              <a href={item.href} class:list={["nav-link", isActive(item.href) ? "nav-link-active" : ""]}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="flex justify-end shrink-0">
        <a href="/join-us" class="btn-primary whitespace-nowrap">
          加入我们
        </a>
      </div>
    </div>

    <details class="group py-4 w-full lg:hidden">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
        <span class="inline-flex items-center gap-3">
          <img src="/assets/logo-mark.png" alt="SANI" class="h-12 w-12 object-contain" />
          <span class="font-serif text-[20px] font-bold leading-none text-ink-deep">{siteData.siteShortName}</span>
        </span>
        <span class="btn-secondary px-4 text-xs h-9">菜单</span>
      </summary>

      <div class="mt-4 border-t border-border pt-4">
        <nav aria-label="移动端主导航">
          <ul class="grid gap-1">
            {navigationLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "flex min-h-11 items-center rounded-lg px-3 text-[15px] font-medium transition-colors",
                    isActive(item.href)
                      ? "bg-surface-alt text-ink-deep border border-border"
                      : "text-text-secondary hover:bg-surface-alt hover:text-ink-deep",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li>
                <a href="/join-us" class="flex mt-3 justify-center items-center w-full btn-primary h-11 text-sm">加入我们</a>
            </li>
          </ul>
        </nav>
      </div>
    </details>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector("[data-site-header]");
    if (!header) return;
    const handleScroll = () => {
      if (window.scrollY > 12) {
        header.classList.add("is-scrolled");
      } else {
        header.classList.remove("is-scrolled");
      }
    };
    handleScroll();
    window.addEventListener("scroll", handleScroll, { passive: true });
  })();
</script>
