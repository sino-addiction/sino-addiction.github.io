---
type Props = {
  eyebrow?: string;
  title: string;
  description: string;
  label: string;
  href: string;
  external?: boolean;
};

const { eyebrow, title, description, label, href, external = false } = Astro.props;
---

<aside class="surface-card reveal p-7 md:p-8">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h3 class="mt-5 font-serif text-3xl font-semibold tracking-tight text-ink-950">{title}</h3>
  <p class="mt-4 max-w-2xl text-base leading-7 text-ink-700">{description}</p>
  <div class="mt-8">
    <a
      href={href}
      class="inline-flex items-center gap-2 rounded-full bg-ink-950 px-6 py-3 text-sm font-semibold text-white hover:-translate-y-0.5 hover:bg-ink-800"
      target={external ? "_blank" : undefined}
      rel={external ? "noreferrer" : undefined}
    >
      {label}
      <span aria-hidden="true">{external ? "↗" : "→"}</span>
    </a>
  </div>
</aside>
