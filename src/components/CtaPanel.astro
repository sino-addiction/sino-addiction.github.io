---
type Props = {
  eyebrow?: string;
  title: string;
  description: string;
  label: string;
  href: string;
  external?: boolean;
};

const { eyebrow, title, description, label, href, external = false } = Astro.props;
---

<aside class="surface-card reveal p-7 md:p-8">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h3 class="zh-heading mt-5 font-serif text-[1.75rem] leading-[2.3rem] font-bold tracking-tight text-primary-900">{title}</h3>
  <p class="mt-4 max-w-2xl text-base leading-7 text-secondary-600">{description}</p>
  <div class="mt-8">
    <a
      href={href}
      class="btn-secondary"
      target={external ? "_blank" : undefined}
      rel={external ? "noreferrer" : undefined}
    >
      {label}
      <span aria-hidden="true">{external ? "↗" : "→"}</span>
    </a>
  </div>
</aside>
