---
type Link = {
  label: string;
  href: string;
  external?: boolean;
};

type Props = {
  kicker?: string;
  title: string;
  subtitle: string;
  primaryCta?: Link;
  secondaryCta?: Link;
  compact?: boolean;
  accentLabel?: string[];
};

const { kicker, title, subtitle, primaryCta, secondaryCta, compact = false, accentLabel = [] } = Astro.props;
---

<section class:list={["page-wrap", compact ? "pt-6" : "pt-4"]}>
  <div class:list={[
    "hero-panel rounded-[20px] px-6 md:px-12",
    compact ? "py-10 md:py-16" : "py-16 md:py-24"
  ]}>
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_480px]">
      <div class="max-w-3xl">
        {kicker && <p class="eyebrow inline-flex">{kicker}</p>}
        <h1 class="hero-title zh-heading mt-6">{title}</h1>
        <p class="hero-subtitle">{subtitle}</p>

        {accentLabel.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-4 items-center border-l-2 border-border pl-4">
            {accentLabel.slice(0, 3).map((item) => (
              <span class="text-sm font-medium text-text-secondary">{item}</span>
            ))}
          </div>
        )}

        {(primaryCta || secondaryCta) && (
          <div class="mt-10 flex flex-wrap gap-4 items-center">
            {primaryCta && (
              <a href={primaryCta.href} class="btn-primary" target={primaryCta.external ? "_blank" : undefined} rel={primaryCta.external ? "noreferrer" : undefined}>
                {primaryCta.label}
              </a>
            )}
            {secondaryCta && (
              <a href={secondaryCta.href} class="btn-secondary" target={secondaryCta.external ? "_blank" : undefined} rel={secondaryCta.external ? "noreferrer" : undefined}>
                {secondaryCta.label}
              </a>
            )}
          </div>
        )}
      </div>

      <div class="hidden lg:block w-full">
        <!-- Structured Institution Diagram -->
        <div class="w-full relative rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <svg viewBox="0 0 400 320" class="w-full h-auto" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="SANI 组织架构">
            <!-- Background Lines -->
            <path d="M 200 40 L 200 240 M 80 140 L 320 140" stroke="#D7DFDB" stroke-width="2" stroke-dasharray="4 4" />
            
            <!-- Connectors -->
            <g stroke="#738391" stroke-width="2" fill="none">
              <path d="M 200 80 Q 200 110 120 120 T 80 140" />
              <path d="M 200 80 Q 200 110 280 120 T 320 140" />
              <path d="M 80 180 Q 80 210 140 220 T 200 240" />
              <path d="M 320 180 Q 320 210 260 220 T 200 240" />
            </g>

            <!-- Nodes -->
            <g>
              <!-- Center Top / Coordinator -->
              <rect x="130" y="40" width="140" height="48" rx="8" fill="#102132" />
              <text x="200" y="68" fill="#FFFFFF" font-size="14" font-weight="bold" font-family="Inter, sans-serif" text-anchor="middle">协调中心 / CC</text>
              
              <!-- Left Center -->
              <rect x="20" y="140" width="120" height="40" rx="6" fill="#1F6B66" fill-opacity="0.1" stroke="#1F6B66" stroke-width="1" />
              <text x="80" y="165" fill="#1F6B66" font-size="13" font-weight="600" font-family="Inter, sans-serif" text-anchor="middle">多中心队列</text>

              <!-- Right Center -->
              <rect x="260" y="140" width="120" height="40" rx="6" fill="#1F6B66" fill-opacity="0.1" stroke="#1F6B66" stroke-width="1" />
              <text x="320" y="165" fill="#1F6B66" font-size="13" font-weight="600" font-family="Inter, sans-serif" text-anchor="middle">分析与超算</text>

              <!-- Center Bottom -->
              <rect x="120" y="240" width="160" height="48" rx="8" fill="#F7F9F8" stroke="#738391" stroke-width="1.5" />
              <text x="200" y="268" fill="#162434" font-size="14" font-weight="bold" font-family="Inter, sans-serif" text-anchor="middle">联邦数据节点</text>
            </g>

            <!-- Subtle data points -->
            <circle cx="200" cy="110" r="4" fill="#22384B" />
            <circle cx="200" cy="210" r="4" fill="#22384B" />
            <circle cx="160" cy="140" r="4" fill="#22384B" />
            <circle cx="240" cy="140" r="4" fill="#22384B" />
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
