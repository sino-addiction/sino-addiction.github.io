---
type Link = {
  label: string;
  href: string;
  external?: boolean;
};

type Props = {
  kicker?: string;
  title: string;
  subtitle: string;
  primaryCta?: Link;
  secondaryCta?: Link;
  compact?: boolean;
  accentLabel?: string[];
};

const { kicker, title, subtitle, primaryCta, secondaryCta, compact = false, accentLabel = [] } = Astro.props;
---

<section class:list={["page-wrap pt-16 md:pt-28 pb-16 md:pb-20 flex flex-col items-center text-center", compact ? "pt-12 md:pt-16 pb-12" : ""]}>
  <div class="max-w-4xl w-full flex flex-col items-center">
    
    <h1 class="text-[36px] md:text-[48px] lg:text-[56px] font-serif font-bold text-ink-deep leading-[1.18] mb-4 text-balance px-4">
      {title}
    </h1>

    <h2 class="text-[18px] md:text-[22px] font-bold text-accent tracking-[0.05em] mb-10 px-4">
      Sino-Addiction Neuroimaging Initiatives
    </h2>
    
    <p class="text-[16px] md:text-[20px] leading-[1.7] text-text-secondary max-w-3xl text-balance px-4">
      {subtitle}
    </p>

    {accentLabel.length > 0 && (
      <div class="mt-10 flex flex-wrap gap-4 items-center justify-center">
        {accentLabel.slice(0, 3).map((item) => (
          <span class="text-[13px] font-[600] uppercase tracking-wider text-text-secondary border-b-2 border-accent pb-1">{item}</span>
        ))}
      </div>
    )}

    {(primaryCta || secondaryCta) && (
      <div class="mt-12 flex flex-wrap gap-4 items-center justify-center w-full">
        {primaryCta && (
          <a href={primaryCta.href} class="btn-primary" target={primaryCta.external ? "_blank" : undefined} rel={primaryCta.external ? "noreferrer" : undefined}>
            {primaryCta.label}
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn-secondary" target={secondaryCta.external ? "_blank" : undefined} rel={secondaryCta.external ? "noreferrer" : undefined}>
            {secondaryCta.label}
          </a>
        )}
      </div>
    )}
    
  </div>
</section>
