---
type Link = {
  label: string;
  href: string;
  external?: boolean;
};

type Props = {
  kicker?: string;
  title: string;
  subtitle: string;
  primaryCta?: Link;
  secondaryCta?: Link;
  compact?: boolean;
  accentLabel?: string[];
};

const { kicker, title, subtitle, primaryCta, secondaryCta, compact = false, accentLabel = [] } = Astro.props;
---

<section class:list={["mx-auto max-w-7xl px-4 md:px-6", compact ? "pt-8" : "pt-6"]}>
  <div class:list={["hero-gradient grid-glow relative overflow-hidden rounded-[2.25rem] border border-white/10 px-6 py-14 text-white shadow-[0_36px_90px_rgba(8,19,29,0.22)] md:px-10 lg:px-14", compact ? "md:py-16" : "md:py-20"]}>
    <div class="absolute inset-y-0 right-0 hidden w-80 bg-[radial-gradient(circle,_rgba(125,215,203,0.18),_transparent_72%)] lg:block"></div>
    <div class="relative max-w-4xl">
      {kicker && <p class="eyebrow border-white/10 bg-white/10 text-sage-300">{kicker}</p>}
      <h1 class="mt-5 max-w-4xl font-serif text-4xl font-semibold leading-tight tracking-tight text-balance md:text-6xl">
        {title}
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-white/78 md:text-xl">{subtitle}</p>

      {accentLabel.length > 0 && (
        <div class="mt-8 flex flex-wrap items-center gap-3 text-sm text-white/72">
          {accentLabel.map((item) => (
            <span class="rounded-full border border-white/10 bg-white/8 px-4 py-2">{item}</span>
          ))}
        </div>
      )}

      {(primaryCta || secondaryCta) && (
        <div class="mt-10 flex flex-wrap gap-4">
          {primaryCta && (
            <a
              href={primaryCta.href}
              class="rounded-full bg-sage-500 px-6 py-3 text-sm font-semibold text-white shadow-[0_12px_30px_rgba(71,185,173,0.2)] hover:-translate-y-0.5 hover:bg-sage-400"
              target={primaryCta.external ? "_blank" : undefined}
              rel={primaryCta.external ? "noreferrer" : undefined}
            >
              {primaryCta.label}
            </a>
          )}
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class="rounded-full border border-white/14 bg-white/8 px-6 py-3 text-sm font-semibold text-white hover:bg-white/14"
              target={secondaryCta.external ? "_blank" : undefined}
              rel={secondaryCta.external ? "noreferrer" : undefined}
            >
              {secondaryCta.label}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>
