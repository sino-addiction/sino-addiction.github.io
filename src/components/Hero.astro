---
type Link = {
  label: string;
  href: string;
  external?: boolean;
};

type Props = {
  kicker?: string;
  title: string;
  subtitle: string;
  primaryCta?: Link;
  secondaryCta?: Link;
  compact?: boolean;
  accentLabel?: string[];
};

const { kicker, title, subtitle, primaryCta, secondaryCta, compact = false, accentLabel = [] } = Astro.props;
---

<section class:list={["page-wrap", compact ? "pt-6" : "pt-8"]}>
  <div class:list={["section-frame px-6 md:px-10", compact ? "py-10 md:py-12" : "py-12 md:py-14"]}>
    <div class="max-w-4xl">
      {kicker && <p class="eyebrow">{kicker}</p>}
      <h1 class="hero-title zh-heading mt-5">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>

      {accentLabel.length > 0 && (
        <div class="mt-7 flex flex-wrap gap-2">
          {accentLabel.map((item) => (
            <span class="status-badge status-integrating">{item}</span>
          ))}
        </div>
      )}

      {(primaryCta || secondaryCta) && (
        <div class="mt-8 flex flex-wrap gap-3">
          {primaryCta && (
            <a href={primaryCta.href} class="btn-primary" target={primaryCta.external ? "_blank" : undefined} rel={primaryCta.external ? "noreferrer" : undefined}>
              {primaryCta.label}
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn-secondary" target={secondaryCta.external ? "_blank" : undefined} rel={secondaryCta.external ? "noreferrer" : undefined}>
              {secondaryCta.label}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>
