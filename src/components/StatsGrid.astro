---
type Stat = {
  label: string;
  value: string;
  note?: string;
};

type Props = {
  items: Stat[];
};

const { items } = Astro.props;
---

<div class="grid gap-6 md:grid-cols-3">
  {items.map((item, index) => (
    <article class:list={["surface-card reveal h-full p-6 md:p-7", index === 1 ? "delay-1" : index === 2 ? "delay-2" : ""]}>
      <div class="mb-5 h-1.5 w-14 rounded-full bg-soft-100"></div>
      <p class="font-serif text-[2.875rem] leading-[3.25rem] font-bold tracking-tight text-primary-900">{item.value}</p>
      <p class="mt-3 text-base font-semibold text-secondary-600">{item.label}</p>
      {item.note && <p class="mt-2 text-sm leading-6 text-muted-500">{item.note}</p>}
    </article>
  ))}
</div>
