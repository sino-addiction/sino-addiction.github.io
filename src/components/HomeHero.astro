---
import { siteData } from "../data/site";

type Link = {
  label: string;
  href: string;
  external?: boolean;
};

type Props = {
  kicker?: string;
  title: string;
  subtitle: string;
  primaryCta?: Link;
  secondaryCta?: Link;
};

const { kicker, title, subtitle, primaryCta, secondaryCta } = Astro.props;
---

<section class="page-wrap pt-4 md:pt-6">
  <div class="hero-panel px-6 py-12 md:px-10 md:py-14">
    <div class="grid items-start gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="max-w-3xl">
        {kicker && <p class="eyebrow">{kicker}</p>}
        <h1 class="hero-title zh-heading mt-6">{title}</h1>
        <p class="mt-3 text-sm font-semibold uppercase tracking-[0.06em] text-muted-500">{siteData.siteFullNameEn}</p>
        <p class="hero-subtitle">{subtitle}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          {primaryCta && (
            <a href={primaryCta.href} class="btn-primary" target={primaryCta.external ? "_blank" : undefined} rel={primaryCta.external ? "noreferrer" : undefined}>
              {primaryCta.label}
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn-secondary" target={secondaryCta.external ? "_blank" : undefined} rel={secondaryCta.external ? "noreferrer" : undefined}>
              {secondaryCta.label}
            </a>
          )}
        </div>
      </div>

      <aside class="kpi-panel reveal">
        <p class="text-xs font-semibold uppercase tracking-[0.08em] text-muted-500">Network Snapshot</p>
        <h2 class="zh-heading mt-3 font-serif text-2xl font-bold text-primary-900">联盟关键指标</h2>
        <div class="mt-6 space-y-4">
          {siteData.homepage.stats.map((stat, index) => (
            <article class:list={["kpi-item", index === 1 ? "delay-1" : index === 2 ? "delay-2" : ""]}>
              <p class="kpi-label">{stat.label}</p>
              <p class="kpi-value">{stat.value}</p>
              <p class="kpi-note">{stat.note}</p>
            </article>
          ))}
        </div>
      </aside>
    </div>
  </div>
</section>
