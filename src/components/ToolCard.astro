---
import type { OutputTool } from "../data/outputs";

type Props = {
  tool: OutputTool;
};

const { tool } = Astro.props;
---

<article class="surface-card flex h-full flex-col p-6 md:p-8 border-t-4 border-t-accent hover:shadow-md transition-shadow">
  <div class="flex items-start justify-between gap-4">
    <span class="inline-flex items-center rounded-full border border-border/70 bg-white/75 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-text-muted">
      {tool.sourceLabel}
    </span>
    <span class="text-[11px] font-bold uppercase tracking-[0.18em] text-text-muted">Tool</span>
  </div>

  <h3 class="card-title mt-4 text-[20px] leading-[1.35] text-ink-deep">{tool.name}</h3>
  <p class="mt-4 text-[15px] leading-relaxed text-text-secondary flex-1">{tool.description}</p>

  <div class="mt-6 flex flex-wrap gap-2">
    {tool.tags.map((tag) => (
      <span class="inline-flex items-center rounded-full border border-border bg-surface-alt px-3 py-1 text-[12px] font-medium text-text-secondary">
        {tag}
      </span>
    ))}
  </div>

  <div class="mt-6">
    <a href={tool.href} class="btn-link text-[14px]" target="_blank" rel="noreferrer">
      {tool.linkLabel}
      <span aria-hidden="true" class="ml-1 opacity-70">↗</span>
    </a>
  </div>
</article>
