---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"team">;
};

const { entry } = Astro.props;
---

<article class="surface-card reveal h-full p-6 text-center">
  <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-soft-100 text-2xl font-bold text-primary-900">
    {entry.data.name.slice(0, 1)}
  </div>
  <h3 class="zh-heading mt-5 font-serif text-2xl leading-8 font-bold tracking-tight text-primary-900">{entry.data.name}</h3>
  <p class="mt-2 text-xs font-semibold uppercase tracking-[0.06em] text-accent-700">{entry.data.role}</p>
  <p class="mt-3 text-base leading-7 text-secondary-600">{entry.data.institution}</p>
  <p class="mt-1 text-sm text-muted-500">{entry.data.city}</p>
  {entry.body && <p class="mt-4 text-sm leading-6 text-secondary-600">{entry.body}</p>}
</article>
