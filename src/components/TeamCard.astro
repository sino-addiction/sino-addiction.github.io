---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"team">;
};

const { entry } = Astro.props;
---

<article class="surface-card flex h-full flex-col p-6 items-center text-center">
  <div class="flex h-16 w-16 items-center justify-center rounded-full bg-surface-alt border border-border text-xl font-bold text-ink-deep shadow-sm">
    {entry.data.name.slice(0, 1)}
  </div>
  <h3 class="card-title line-clamp-1 mt-4">{entry.data.name}</h3>
  <p class="mt-2 text-[13px] font-semibold text-accent uppercase tracking-wider">{entry.data.role}</p>
  <p class="mt-2 text-[15px] leading-relaxed text-text-secondary">{entry.data.institution}</p>
  <p class="mt-1 text-[13px] text-text-muted">{entry.data.city}</p>
  {entry.body && <p class="mt-4 text-[14px] leading-relaxed text-text-secondary w-full border-t border-border pt-4">{entry.body}</p>}
</article>
